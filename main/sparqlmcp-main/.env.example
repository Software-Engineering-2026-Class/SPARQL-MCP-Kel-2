# Placeholder env file (copy to .env and fill in real values)

LOCAL_STORE=local_store/void_descriptions
FEDERATION_ENDPOINT=http://localhost:3030/ds/sparql
DEFAULT_SPARQL_ENDPOINT=https://sepses.ifs.tuwien.ac.at/sparql
FORCE_FEDERATION=false
SPARQL_TIMEOUT_SECONDS=60
SPARQL_VERIFY_SSL=true
SPARQL_CA_BUNDLE=
DEFAULT_QUERY_LIMIT=100
MAX_QUERY_CHARS=8000
VOID_CACHE_TTL_SECONDS=604800
VOID_HTTP_TIMEOUT_SECONDS=60
VOID_SPARQL_TIMEOUT_SECONDS=60
EXPOSED_TOOLS=run_sparql_query,get_void_descriptions

# LLM Provider
LLM_PROVIDER=openrouter

# OpenRouter.ai
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_MAX_TOKENS=800
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_TITLE=SPARQL-MCP Kelompok 2

# Backend API
CORS_ALLOW_ORIGINS=http://localhost:5173
ALLOWED_ENDPOINTS=
