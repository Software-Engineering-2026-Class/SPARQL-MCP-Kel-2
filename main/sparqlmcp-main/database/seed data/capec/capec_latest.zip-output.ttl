capec-res:CAPEC-260  a                capec:CAPEC ;
        dct:description               "This attack pattern has been deprecated as it is a duplicate of the existing attack pattern \"CAPEC-65 : Sniff Application Code\". Please refer to this other CAPEC going forward." ;
        dct:identifier                "260" ;
