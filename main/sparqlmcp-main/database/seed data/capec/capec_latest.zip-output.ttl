capec-res:CAPEC-158  a                 capec:CAPEC ;
        dct:description                "In this attack pattern, the adversary monitors network traffic between nodes of a public or multicast network in an attempt to capture sensitive information at the protocol level. Network sniffing applications can reveal TCP/IP, DNS, Ethernet, and other low-level network communication information. The adversary takes a passive role in this attack pattern and simply observes and analyzes the traffic. The adversary may precipitate or indirectly influence the content of the observed transaction, but is never the intended recipient of the target information." ;
        dct:identifier                 "158" ;
        dct:title                      "Sniffing Network Traffic" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/15869> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/15820170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/15820180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/15820151207> , <http://w3id.org/sepses/resource/capec/modificationHistory/15820151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/15820220929> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/158ChildOf157> ;
        capec:hasRelatedWeakness       cwe-res:CWE-311 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/15820140623> ;
        capec:mitigation               "Employ appropriate levels of segmentation to your network in accordance with best practices." , "Obfuscate network traffic through encryption to prevent its readability by network sniffers." ;
        capec:prerequisite             "The adversary must obtain a logical position on the network from intercepting target network traffic is possible. Depending on the network topology, traffic sniffing may be simple or challenging. If both the target sender and target recipient are members of a single subnet, the adversary must also be on that subnet in order to see their traffic communication." , "The target must be communicating on a network protocol visible by a network sniffing application." ;
        capec:resourceRequired         "A tool with the capability of presenting network communication traffic (e.g., Wireshark, tcpdump, Cain and Abel, etc.)." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

