capec-res:CAPEC-697  a                 capec:CAPEC ;
        dct:description                "\n            An adversary masquerades as a legitimate Dynamic Host Configuration Protocol (DHCP) server by spoofing DHCP traffic, with the goal of redirecting network traffic or denying service to DHCP.\n         " ;
        dct:identifier                 "697" ;
        dct:title                      "DHCP Spoofing" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/6971> , <http://w3id.org/sepses/resource/capec/Consequence/69777> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6972> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6973> , <http://w3id.org/sepses/resource/capec/Consequence/69799> , <http://w3id.org/sepses/resource/capec/Consequence/697140> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-737> , <http://w3id.org/sepses/resource/capec/reference/REF-738> , <http://w3id.org/sepses/resource/capec/reference/REF-739> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/697ChildOf194> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/697CanPrecede94> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/697CanPrecede158> ;
        capec:hasRelatedWeakness       cwe-res:CWE-923 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/69720220929> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Implementation: Port Security and DHCP snooping" , "Design: MAC-Forced Forwarding" , "Implementation: Network-based Intrusion Detection Systems" ;
        capec:prerequisite             "The adversary must have access to a machine within the target LAN which can send DHCP offers to the target." ;
        capec:resourceRequired         "The adversary requires access to a machine within the target LAN on a network which does not secure its DHCP traffic through MAC-Forced Forwarding, port security, etc." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "High" .

