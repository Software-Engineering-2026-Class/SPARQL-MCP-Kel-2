capec-res:CAPEC-609  a                 capec:CAPEC ;
        dct:description                "Cellular traffic for voice and data from mobile devices and retransmission devices can be intercepted via numerous methods. Malicious actors can deploy their own cellular tower equipment and intercept cellular traffic surreptitiously. Additionally, government agencies of adversaries and malicious actors can intercept cellular traffic via the telecommunications backbone over which mobile traffic is transmitted." ;
        dct:identifier                 "609" ;
        dct:title                      "Cellular Traffic Intercept" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/609349> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/60920190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/60920180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/60920190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/60920220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/60920151207> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/609ChildOf157> ;
        capec:hasRelatedWeakness       cwe-res:CWE-311 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/60920151109> ;
        capec:mitigation               "Encryption of all data packets emanating from the smartphone to a retransmission device via two encrypted tunnels with Suite B cryptography, all the way to the VPN gateway at the datacenter." ;
        capec:prerequisite             "None" ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Low" .

