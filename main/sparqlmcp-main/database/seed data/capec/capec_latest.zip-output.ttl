capec-res:CAPEC-448  a                 capec:CAPEC ;
        dct:description                "An adversary tampers with a DLL and embeds a computer virus into gaps between legitimate machine instructions. These gaps may be the result of compiler optimizations that pad memory blocks for performance gains. The embedded virus then attempts to infect any machine which interfaces with the product, and possibly steal private data or eavesdrop." ;
        dct:identifier                 "448" ;
        dct:title                      "Embed Virus into DLL" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/44887> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/44820190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/44820230124> , <http://w3id.org/sepses/resource/capec/modificationHistory/44820180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/44820210624> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/448ChildOf442> ;
        capec:hasRelatedWeakness       cwe-res:CWE-506 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/44820140623> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Leverage anti-virus products to detect and quarantine software with known virus." ;
        capec:prerequisite             "Access to the software currently deployed at a victim location. This access is often obtained by leveraging another attack pattern to gain permissions that the adversary wouldn't normally have." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "High" .

