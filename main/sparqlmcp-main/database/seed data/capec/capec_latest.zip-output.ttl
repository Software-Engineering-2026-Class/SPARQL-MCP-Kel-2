        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Fuzzing of API parameters (URL parameters, OS API parameters, protocol parameters)" .

capec-res:CAPEC-522  a                 capec:CAPEC ;
        dct:description                "An adversary replaces legitimate hardware in the system with faulty counterfeit or tampered hardware in the supply chain distribution channel, with purpose of causing malicious disruption or allowing for additional compromise when the system is deployed." ;
        dct:identifier                 "522" ;
        dct:title                      "Malicious Hardware Component Replacement" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/5221> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/5222> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/5223> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/52220220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/52220211021> , <http://w3id.org/sepses/resource/capec/modificationHistory/52220220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/52220151109> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-712> , <http://w3id.org/sepses/resource/capec/reference/REF-439> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/522ChildOf439> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/52220140623> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Prevent or detect tampering with critical hardware or firmware components while in transit through use of state-of-the-art anti-tamper devices." , "Use tamper-resistant and tamper-evident packaging when shipping critical components (e.g., plastic coating for circuit boards, tamper tape, paint, sensors, and/or seals for cases and containers) and inspect received system components for evidence of tampering." , "Ensure that all contractors and sub-suppliers use trusted means of shipping (e.g., bonded/cleared/vetted and insured couriers) to ensure that components, once purchased, are not subject to compromise during their delivery." ;
        capec:prerequisite             "Physical access to the system after it has left the manufacturer but before it is deployed at the victim location." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

