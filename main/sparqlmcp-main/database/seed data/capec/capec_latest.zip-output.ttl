capec-res:CAPEC-651  a                 capec:CAPEC ;
        dct:description                "An adversary intercepts a form of communication (e.g. text, audio, video) by way of software (e.g., microphone and audio recording application), hardware (e.g., recording equipment), or physical means (e.g., physical proximity). The goal of eavesdropping is typically to gain unauthorized access to sensitive information about the target for financial, personal, political, or other gains. Eavesdropping is different from a sniffing attack as it does not take place on a network-based communication channel (e.g., IP traffic). Instead, it entails listening in on the raw audio source of a conversation between two or more parties." ;
        dct:identifier                 "651" ;
        dct:title                      "Eavesdropping" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/651136> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/65120220929> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/651ChildOf117> ;
        capec:hasRelatedWeakness       cwe-res:CWE-200 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/65120140623> ;
        capec:mitigation               "If possible, physically disable the microphone on your machine if it is not needed." , "Implement proper software restriction policies to only allow authorized software on your environment. Use of anti-virus and other security monitoring and detecting tools can aid in this too. Closely monitor installed software for unusual behavior or activity, and implement patches as soon as they become available." , "Be mindful of your surroundings when discussing sensitive information in public areas." ;
        capec:prerequisite             "The adversary typically requires physical proximity to the target's environment, whether for physical eavesdropping or for placing recording equipment. This is not always the case for software-based eavesdropping, if the adversary has the capability to install malware on the target system that can activate a microphone and record audio digitally." ;
        capec:resourceRequired         "For logical eavesdropping, some equipment may be necessary (e.g., microphone, tape recorder, etc.). For physical eavesdropping, only proximity is required." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

<http://w3id.org/sepses/resource/capec/Consequence/131233>
        a                        capec:Consequence ;
        capec:consequenceImpact  "Resource Consumption" , "Unreliable Execution" ;
        capec:consequenceNote    "A successful resource leak exposure attack compromises the availability of the target system's services." ;
        capec:consequenceScope   "Availability" .

<http://w3id.org/sepses/resource/capec/Consequence/10277>
        a                        capec:Consequence ;
        capec:consequenceImpact  "Unreliable Execution" ;
        capec:consequenceScope   "Availability" .

capec-res:CAPEC-461  a                 capec:CAPEC ;
        dct:description                "An adversary utilizes a hash function extension/padding weakness, to modify the parameters passed to the web service requesting authentication by generating their own call in order to generate a legitimate signature hash (as described in the notes), without knowledge of the secret token sometimes provided by the web service." ;
        dct:identifier                 "461" ;
        dct:title                      "Web Services API Signature Forgery Leveraging Hash Function Extension Weakness" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/4612> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/4613> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/4611> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/46120180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/46120211021> , <http://w3id.org/sepses/resource/capec/modificationHistory/46120201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/46120220929> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-398> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/461ChildOf115> ;
        capec:hasRelatedWeakness       cwe-res:CWE-290 , cwe-res:CWE-328 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/46120140623> ;
        capec:mitigation               "Design: Use a secure message authentication code (MAC) function such as an HMAC-SHA1" ;
        capec:prerequisite             "An iterative hash function like MD5 and SHA1 is used." , "The API call signature is generated by concatenating the parameter list with the shared secret and hashing the result." , "Authentication tokens / secrets are shared between the server and the legitimate client" , "An attacker is able to intercept or in some other way gain access to the information passed between the legitimate client and the server in order to retrieve the hash value and length of the original message." , "The communication channel between the client and the server is not secured via channel security such as TLS" , "Web services check the signature of the API calls" ;
        capec:resourceRequired         "\n               Access to a function to produce a hash (e.g., MD5, SHA1)\n               Tools that allow the attacker to intercept a message between the client and the server, specifically the hash that is the signature and the length of the original message concatenated with the secret bytes\n            " ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

<http://w3id.org/sepses/resource/capec/modificationHistory/1520190930>
        a                               capec:ModificationHistory ;
        capec:modificationComment       "Updated Related_Attack_Patterns" ;
