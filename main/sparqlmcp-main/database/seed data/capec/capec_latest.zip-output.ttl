        a                        capec:Consequence ;
        capec:consequenceImpact  "Execute Unauthorized Commands" ;
        capec:consequenceNote    "Through Root/Jailbreak Detection Evasion via Hooking, the adversary compromises the integrity of the application." ;
        capec:consequenceScope   "Authorization" , "Integrity" .

