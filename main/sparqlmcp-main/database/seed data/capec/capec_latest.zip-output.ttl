        capec:attackStepPhase        "Exploit" ;
        capec:attackStepTechnique    "Create the symlink to the sensitive file such as configuration files, etc." .

capec-res:CAPEC-518  a                 capec:CAPEC ;
        dct:description                "An attacker with access to a manufacturer's documentation alters the descriptions of system capabilities with the intent of causing errors in derived system requirements, impacting the overall effectiveness and capability of the system, allowing an attacker to take advantage of the introduced system capability flaw once the system is deployed." ;
        dct:identifier                 "518" ;
        dct:title                      "Documentation Alteration to Produce Under-performing Systems" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/51820190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/51820151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/51820220222> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-715> , <http://w3id.org/sepses/resource/capec/reference/REF-439> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/518ChildOf447> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/51820140623> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Maintain backups of the document for recovery and verification." , "Avoid emailing important documents and configurations." , "Separate need-to-know information from system configuration information depending on the user." , "Ensure deleted files are actually deleted." , "Password protect documents and make them read-only for unauthorized users." , "Digitize documents and cryptographically sign them to verify authenticity." ;
        capec:prerequisite             "Access to the manufacturer's documentation." , "Advanced knowledge of software and hardware capabilities of a manufacturer's product." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

