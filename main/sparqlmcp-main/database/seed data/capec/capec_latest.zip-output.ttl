        capec:modificationName          "CAPEC Content Team" ;
        capec:modificationOrganization  "The MITRE Corporation" .

capec-res:CAPEC-318  a                 capec:CAPEC ;
        dct:description                "This OS fingerprinting probe tests to determine if the remote host echoes back the IP 'ID' value from the probe packet. An attacker sends a UDP datagram with an arbitrary IP 'ID' value to a closed port on the remote host to observe the manner in which this bit is echoed back in the ICMP error message. The identification field (ID) is typically utilized for reassembling a fragmented packet. Some operating systems or router firmware reverse the bit order of the ID field when echoing the IP Header portion of the original datagram within an ICMP error message." ;
        dct:identifier                 "318" ;
        dct:title                      "IP 'ID' Echoed Byte-Order Probe" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/318177> , <http://w3id.org/sepses/resource/capec/Consequence/31869> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/31820170501> , <http://w3id.org/sepses/resource/capec/modificationHistory/31820180731> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-33> , <http://w3id.org/sepses/resource/capec/reference/REF-130> , <http://w3id.org/sepses/resource/capec/reference/REF-212> , <http://w3id.org/sepses/resource/capec/reference/REF-128> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/318ChildOf312> ;
        capec:hasRelatedWeakness       cwe-res:CWE-200 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/31820140623> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "Low" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/6611>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Identify application with attack potential] The adversary searches for and identifies a mobile application that could be exploited for malicious purposes (e.g. banking, voting, or medical applications)." ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "Search application stores for mobile applications worth exploiting" .

