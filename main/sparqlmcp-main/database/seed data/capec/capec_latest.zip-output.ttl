<http://w3id.org/sepses/resource/capec/ExecutionFlow/6531>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Acquire known operating system credentials] The adversary must obtain known operating system credentials in order to access the target system, application, or service within the domain." ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "An adversary conducts a sniffing attack to steal operating system credentials as they are transmitted." , "An adversary leverages a key logger or phishing attack to steal user credentials as they are provided." , "An adversary examines outward-facing configuration and properties files to discover hardcoded credentials." , "An adversary gains access to a system/files and exfiltrates password hashes." , "An adversary purchases breached operating system username/password combinations or leaked hashed passwords from the dark web." .

