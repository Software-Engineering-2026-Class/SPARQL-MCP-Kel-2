capec-res:CAPEC-616  a                 capec:CAPEC ;
        dct:description                "An adversary provides a malicious version of a resource at a location that is similar to the expected location of a legitimate resource. After establishing the rogue location, the adversary waits for a victim to visit the location and access the malicious resource." ;
        dct:identifier                 "616" ;
        dct:title                      "Establish Rogue Location" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/616281> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/61620210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/61620220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/61620200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/61620170501> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/616ChildOf154> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/616CanPrecede691> ;
        capec:hasRelatedWeakness       cwe-res:CWE-200 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/61620151109> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:prerequisite             "A resource is expected to available to the user." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "Medium" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/104>
        a                            capec:AttackStep ;
        capec:attackStep             "4" ;
        capec:attackStepDescription  "[Overflow the buffer] Using the injection vector, the adversary injects the crafted overflow content into the buffer." ;
        capec:attackStepPhase        "Exploit" .

capec-res:CAPEC-426  a                 capec:CAPEC ;
        dct:description                "The adversary incites a behavior from the target by manipulating something of influence. This is commonly associated with financial, social, or ideological incentivization. Examples include monetary fraud, peer pressure, and preying on the target's morals or ethics. The most effective incentive against one target might not be as effective against another, therefore the adversary must gather information about the target's vulnerability to particular incentives." ;
        dct:identifier                 "426" ;
        dct:title                      "Influence via Incentives" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/426380> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/42620170804> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-348> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/426ChildOf416> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/42620140623> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "An organization should provide regular, robust cybersecurity training to its employees to prevent social engineering attacks." ;
        capec:prerequisite             "The adversary must have the means and knowledge of how to communicate with the target in some manner.The adversary must have knowledge of the incentives that would influence the actions of the specific target." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "Low" .

<http://w3id.org/sepses/resource/capec/reference/REF-77>
        a                     capec:Reference ;
        capec:referenceTitle  "Mozilla Firefox Add-ons" ;
        capec:referenceUrl    "https://addons.mozilla.org/en-US/firefox/addon/greasemonkey/" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/1041>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Find systems susceptible to the attack] Find systems that contain functionality that is accessed from both the internet zone and the local zone. There needs to be a way to supply input to that functionality from the internet zone and that original input needs to be used later on a page from a local zone." ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "Leverage knowledge of common local zone functionality on targeted platforms to guide attempted injection of code through relevant internet zone mechanisms. In some cases this may be due to standard system configurations enabling shared functionality between internet and local zones. The attacker can search for indicators that these standard configurations are in place." .

capec-res:CAPEC-236  a                capec:CAPEC ;
        dct:description               "This attack pattern has been deprecated as it did not have enough distinction from CAPEC-30 : Hijacking a Privileged Thread of Execution. Please refer to CAPEC-30 moving forward." ;
        dct:identifier                "236" ;
        dct:title                     "DEPRECATED: Catching exception throw/signal from privileged block" ;
        capec:abstraction             "Detailed" ;
