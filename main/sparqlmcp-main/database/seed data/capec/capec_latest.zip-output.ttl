        capec:attackStepPhase        "Explore" .

capec-res:CAPEC-276  a                 capec:CAPEC ;
        dct:description                "Inter-component protocols are used to communicate between different software and hardware modules within a single computer. Common examples are: interrupt signals and data pipes. Subverting the protocol can allow an adversary to impersonate others, discover sensitive information, control the outcome of a session, or perform other attacks. This type of attack targets invalid assumptions that may be inherent in implementers of the protocol, incorrect implementations of the protocol, or vulnerabilities in the protocol itself." ;
        dct:identifier                 "276" ;
        dct:title                      "Inter-component Protocol Manipulation" ;
        capec:abstraction              "Standard" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/27620180731> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/276ChildOf272> ;
        capec:hasRelatedWeakness       cwe-res:CWE-707 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/27620140623> ;
        capec:status                   "Draft" .

