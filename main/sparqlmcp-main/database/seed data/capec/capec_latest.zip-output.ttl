        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Develop code to be hooked into chosen target application] The adversary develops code or leverages existing code that will be hooked into the target application in order to evade Root/Jailbreak detection methods." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Test the code to see if it works." , "Develop code or leverage existing code to bypass Root/Jailbreak detection methods." , "Iteratively develop the code until Root/Jailbreak detection methods are evaded." .

