capec-res:CAPEC-27  a                  capec:CAPEC ;
        dct:description                "This attack leverages the use of symbolic links (Symlinks) in order to write to sensitive files. An attacker can create a Symlink link to a target file not otherwise accessible to them. When the privileged program tries to create a temporary file with the same name as the Symlink link, it will actually write to the target file pointed to by the attackers' Symlink link. If the attacker can insert malicious content in the temporary file they will be writing to the sensitive file by using the Symlink. The race occurs because the system checks if the temporary file exists, then creates the file. The attacker would typically create the Symlink during the interval between the check and the creation of the temporary file." ;
        dct:identifier                 "27" ;
        dct:title                      "Leveraging Race Conditions via Symbolic Links" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/272> , <http://w3id.org/sepses/resource/capec/Consequence/2765> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/271> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/274> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/273> , <http://w3id.org/sepses/resource/capec/Consequence/27110> , <http://w3id.org/sepses/resource/capec/Consequence/27134> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/2720200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/2720180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/2720170109> , <http://w3id.org/sepses/resource/capec/modificationHistory/2720190930> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-116> , <http://w3id.org/sepses/resource/capec/reference/REF-115> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/27ChildOf29> ;
        capec:hasRelatedWeakness       cwe-res:CWE-61 , cwe-res:CWE-667 , cwe-res:CWE-689 , cwe-res:CWE-367 , cwe-res:CWE-662 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/2720140623> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Follow the principle of least privilege when assigning access rights to files." , "Access to the directories should be restricted as to prevent attackers from manipulating the files. Denying access to a file can prevent an attacker from replacing that file with a link to a sensitive file." , "Use safe libraries when creating temporary files. For instance the standard library function mkstemp can be used to safely create temporary files. For shell scripts, the system utility mktemp does the same thing." , "Ensure good compartmentalization in the system to provide protected areas that can be trusted." ;
        capec:prerequisite             "The target host does insecure temporary file creation." , "Tainted data from the attacker is used and copied to temporary files." , "The attacker is able to create Symlink links on the target host." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

