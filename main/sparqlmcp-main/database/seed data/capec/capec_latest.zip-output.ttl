<http://w3id.org/sepses/resource/capec/ExecutionFlow/613>
        a                            capec:AttackStep ;
        capec:attackStep             "3" ;
        capec:attackStepDescription  "[Abuse the Victim's Session] Takeover the fixated session: Once the victim has achieved a higher level of privilege, possibly by logging into the application, the attacker can now take over the session using the fixated session identifier." ;
        capec:attackStepPhase        "Exploit" ;
        capec:attackStepTechnique    "The attacker loads the predefined session ID into their browser and browses to protected data or functionality." , "The attacker loads the predefined session ID into their software and utilizes functionality with the rights of the victim." .

