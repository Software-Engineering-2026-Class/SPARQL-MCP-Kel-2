capec-res:CAPEC-34  a                  capec:CAPEC ;
        dct:description                "\n            An adversary manipulates and injects malicious content, in the form of secret unauthorized HTTP responses, into a single HTTP response from a vulnerable or compromised back-end HTTP agent (e.g., web server) or into an already spoofed HTTP response from an adversary controlled domain/site.\n            See CanPrecede relationships for possible consequences.\n         " ;
        dct:identifier                 "34" ;
        dct:title                      "HTTP Response Splitting" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/3465> , <http://w3id.org/sepses/resource/capec/Consequence/34134> , <http://w3id.org/sepses/resource/capec/Consequence/34142> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/341> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/342> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/3420210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/3420200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/3420201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/3420220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/3420211021> , <http://w3id.org/sepses/resource/capec/modificationHistory/3420170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/3420180731> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-117> , <http://w3id.org/sepses/resource/capec/reference/REF-680> , <http://w3id.org/sepses/resource/capec/reference/REF-617> , <http://w3id.org/sepses/resource/capec/reference/REF-1> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/34CanPrecede115> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/34CanPrecede141> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/34CanPrecede148> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/34ChildOf220> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/34CanPrecede63> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/34CanPrecede154> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/34CanPrecede593> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/34PeerOf105> ;
        capec:hasRelatedWeakness       cwe-res:CWE-74 , cwe-res:CWE-113 , cwe-res:CWE-436 , cwe-res:CWE-138 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/3420140623> ;
        capec:indicator                "Differences in responses processed by the two agents with multiple responses to a single request in the web logs. This requires careful monitoring or a capable log analysis tool." ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Implementation: Utilize intermediary HTTP infrastructure capable of filtering and/or sanitizing user-input." , "Configuration: Install latest vendor security patches available for both intermediary and back-end HTTP infrastructure (i.e. proxies and web servers)" , "Configuration: Use the same web server software for front-end and back-end server." , "Design: evaluate HTTP agents prior to deployment for parsing/interpretation discrepancies." , "Configuration: Use HTTP/2 for back-end connections." , "Configuration: Ensure that HTTP infrastructure in the chain or network path utilize a strict uniform parsing process." , "Implementation: Utilize a Web Application Firewall (WAF) that has built-in mitigation to detect abnormal requests/responses." , "Configuration: back-end HTTP agents reject ambiguous requests and close the network connection." , "Configuration: Disable reuse of back-end connections." , "Configuration: front-end HTTP agents notice ambiguous requests." ;
        capec:prerequisite             "Differences in the way the two HTTP agents parse and interpret HTTP requests and its headers." , "A vulnerable or compromised server or domain/site capable of allowing adversary to insert/inject malicious content that will appear in the server's response to target HTTP agents (e.g., proxies and users' web browsers)." , "HTTP headers capable of being user-manipulated." , "HTTP agents running on HTTP/1.0 or HTTP/1.1 that allow for Keep Alive mode, Pipelined queries, and Chunked queries and responses." ;
        capec:resourceRequired         "Tools capable of monitoring HTTP messages, and crafting malicious HTTP messages and/or injecting malicious content into HTTP messages." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "High" .

