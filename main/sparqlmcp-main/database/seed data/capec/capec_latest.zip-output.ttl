capec-res:CAPEC-420  a                 capec:CAPEC ;
        dct:description                "The adversary leverages a perception of scarcity to persuade the target to perform an action or divulge information that is advantageous to the adversary. By conveying a perception of scarcity, or a situation of limited supply, the adversary aims to create a sense of urgency in the context of a target's decision-making process." ;
        dct:identifier                 "420" ;
        dct:title                      "Influence Perception of Scarcity" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/420371> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/42020170804> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-348> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/420ChildOf417> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/42020140623> ;
        capec:likelihoodOfAttack       "High" ;
        capec:mitigation               "An organization should provide regular, robust cybersecurity training to its employees to prevent social engineering attacks." ;
        capec:prerequisite             "The adversary must have the means and knowledge of how to communicate with the target in some manner." ;
        capec:resourceRequired         "None: No specialized resources are required to execute this type of attack." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "Low" .

