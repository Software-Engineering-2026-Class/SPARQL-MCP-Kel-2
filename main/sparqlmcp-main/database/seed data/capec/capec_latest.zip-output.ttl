capec-res:CAPEC-252  a                 capec:CAPEC ;
        dct:description                "The attacker loads and executes an arbitrary local PHP file on a target machine. The attacker could use this to try to load old versions of PHP files that have known vulnerabilities, to load PHP files that the attacker placed on the local machine during a prior attack, or to otherwise change the functionality of the targeted application in unexpected ways." ;
        dct:identifier                 "252" ;
        dct:title                      "PHP Local File Inclusion" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/2522> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2521> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2523> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/25220190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/25220211021> , <http://w3id.org/sepses/resource/capec/modificationHistory/25220201217> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-621> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/252ChildOf251> ;
        capec:hasRelatedWeakness       cwe-res:CWE-829 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/25220140623> ;
        capec:prerequisite             "The targeted PHP application must have a bug that allows an attacker to control which code file is loaded at some juncture." ;
        capec:resourceRequired         "The attacker needs to have enough access to the target application to control the identity of a locally included PHP file." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

