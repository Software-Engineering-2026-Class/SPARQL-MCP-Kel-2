<http://w3id.org/sepses/resource/capec/ExecutionFlow/6764>
        a                            capec:AttackStep ;
        capec:attackStep             "4" ;
        capec:attackStepDescription  "[Exploit NoSQL Injection vulnerability] After refining and adding various logic to NoSQL queries, craft and execute the underlying NoSQL query that will be used to attack the target system." ;
        capec:attackStepPhase        "Exploit" ;
        capec:attackStepTechnique    "Craft and Execute underlying NoSQL query" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/12>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Identify Functionality] At each step, the attacker notes the resource or functionality access mechanism invoked upon performing specific actions" ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "Use a packet sniffer to capture and record network traffic" , "Use the web inventory of all forms and inputs and apply attack data to those inputs." , "Execute the software in a debugger and record API calls into the operating system or important libraries. This might occur in an environment other than a production environment, in order to find weaknesses that can be exploited in a production environment." .

capec-res:CAPEC-521  a                 capec:CAPEC ;
        dct:description                "An attacker with access to a manufacturer's hardware manufacturing process documentation alters the design specifications, which introduces flaws advantageous to the attacker once the system is deployed." ;
        dct:identifier                 "521" ;
        dct:title                      "Hardware Design Specifications Are Altered" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/52120151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/52120220222> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-715> , <http://w3id.org/sepses/resource/capec/reference/REF-439> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/521ChildOf447> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/52120140623> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Maintain backups of the document for recovery and verification." , "Digitize documents and cryptographically sign them to verify authenticity." , "Separate need-to-know information from system configuration information depending on the user." , "Avoid emailing important documents and configurations." , "Ensure deleted files are actually deleted." , "Password protect documents and make them read-only for unauthorized users." ;
        capec:prerequisite             "Access to the manufacturer's documentation." , "Advanced knowledge of hardware capabilities of a manufacturer's product." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

