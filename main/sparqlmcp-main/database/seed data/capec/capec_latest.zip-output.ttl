capec-res:CAPEC-114  a                capec:CAPEC ;
        dct:description               "An attacker obtains unauthorized access to an application, service or device either through knowledge of the inherent weaknesses of an authentication mechanism, or by exploiting a flaw in the authentication scheme's implementation. In such an attack an authentication mechanism is functioning but a carefully controlled sequence of events causes the mechanism to grant access to the attacker." ;
        dct:identifier                "114" ;
        dct:title                     "Authentication Abuse" ;
        capec:abstraction             "Meta" ;
        capec:hasModificationHistory  <http://w3id.org/sepses/resource/capec/modificationHistory/11420220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/11420210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/11420151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/11420200730> ;
        capec:hasRelatedWeakness      cwe-res:CWE-287 , cwe-res:CWE-1244 ;
        capec:hasSubmissionHistory    <http://w3id.org/sepses/resource/capec/submissionHistory/11420140623> ;
        capec:prerequisite            "An authentication mechanism or subsystem implementing some form of authentication such as passwords, digest authentication, security certificates, etc. which is flawed in some way." ;
        capec:resourceRequired        "A client application, command-line access to a binary, or scripting language capable of interacting with the authentication mechanism." ;
        capec:status                  "Draft" ;
        capec:typicalSeverity         "Medium" .

