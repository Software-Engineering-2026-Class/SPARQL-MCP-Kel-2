<http://w3id.org/sepses/resource/capec/ExecutionFlow/2451>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Survey the application for user-controllable inputs] Using a browser or an automated tool, an adversary follows all public links and actions on a web site. They record all the links, the forms, the resources accessed and all other potential entry-points for the web application." ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "Use a proxy tool to record all links visited during a manual traversal of the web application." , "Use a spidering tool to follow and record all links and analyze the web pages to find entry points. Make special note of any links that include parameters in the URL." , "Use a browser to manually explore the website and analyze how it is constructed. Many browsers' plugins are available to facilitate the analysis or automate the discovery." .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/43>
        a                            capec:AttackStep ;
        capec:attackStep             "3" ;
        capec:attackStepDescription  "[Bypass access control] Using an alternate IP address encoding, the adversary will either access the application or give the alternate encoding as input, bypassing access control restrictions." ;
        capec:attackStepPhase        "Exploit" .

<http://w3id.org/sepses/resource/capec/Consequence/702103>
        a                        capec:Consequence ;
        capec:consequenceImpact  "Gain Privileges" ;
        capec:consequenceScope   "Authorization" , "Access Control" .

capec-res:CAPEC-552  a                 capec:CAPEC ;
        dct:description                "An adversary exploits a weakness in authentication to install malware that alters the functionality and information provide by targeted operating system API calls. Often referred to as rootkits, it is often used to hide the presence of programs, files, network connections, services, drivers, and other system components." ;
        dct:identifier                 "552" ;
        dct:title                      "Install Rootkit " ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/55220180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/55220190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/55220200730> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/552ChildOf542> ;
        capec:hasRelatedWeakness       cwe-res:CWE-284 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/55220151109> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Prevent adversary access to privileged accounts necessary to install rootkits." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

<http://w3id.org/sepses/resource/capec/modificationHistory/31920180731>
