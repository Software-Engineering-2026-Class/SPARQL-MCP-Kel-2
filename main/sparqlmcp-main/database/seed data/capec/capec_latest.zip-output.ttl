capec-res:CAPEC-536  a                 capec:CAPEC ;
        dct:description                "An attacker with access to data files and processes on a victim's system injects malicious data into critical operational data during configuration or recalibration, causing the victim's system to perform in a suboptimal manner that benefits the adversary." ;
        dct:identifier                 "536" ;
        dct:title                      "Data Injected During Configuration" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/5364> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/5363> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/5362> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/5361> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/53620170109> , <http://w3id.org/sepses/resource/capec/modificationHistory/53620151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/53620180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/53620200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/53620211021> , <http://w3id.org/sepses/resource/capec/modificationHistory/53620201217> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-439> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/536ChildOf176> ;
        capec:hasRelatedWeakness       cwe-res:CWE-284 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/53620140623> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Ensure that proper access control is implemented on all systems to prevent unauthorized access to system files and processes." ;
        capec:prerequisite             "The attacker must have previously compromised the victim's systems or have physical access to the victim's systems." , "Advanced knowledge of software and hardware capabilities of a manufacturer's product." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "High" .

