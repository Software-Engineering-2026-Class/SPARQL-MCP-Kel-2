        a                            capec:AttackStep ;
        capec:attackStep             "3" ;
        capec:attackStepDescription  "[Vary inputs, looking for malicious results] Depending on whether the application being exploited is a remote or local one, the attacker crafts the appropriate malicious input containing the path of the targeted file or other file system control syntax to be passed to the application" ;
        capec:attackStepPhase        "Experiment" .

capec-res:CAPEC-458  a                 capec:CAPEC ;
        dct:description                "An adversary inserts malicious logic into a product or technology via flashing the on-board memory with a code-base that contains malicious logic. Various attacks exist against the integrity of flash memory, the most direct being rootkits coded into the BIOS or chipset of a device." ;
        dct:identifier                 "458" ;
        dct:title                      "Flash Memory Attacks" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/45820220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/45820230124> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-394> , <http://w3id.org/sepses/resource/capec/reference/REF-379> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/458ChildOf456> ;
        capec:hasRelatedWeakness       cwe-res:CWE-1282 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/45820140623> ;
        capec:status                   "Draft" .

<http://w3id.org/sepses/resource/capec/skillRequired/65280>
        a                        capec:SkillRequired ;
        capec:isSkillRequiredOf  capec-res:CAPEC-652 ;
        capec:skillDescription   "Once an adversary obtains a known Kerberos credential, leveraging it is trivial." ;
        capec:skillLevel         "Low" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/1073>
        a                            capec:AttackStep ;
        capec:attackStep             "3" ;
        capec:attackStepDescription  "[Create a malicious script that pings the web server with HTTP TRACE request] The adversary creates a malicious script that will induce the victim's browser to issue an HTTP TRACE request to the destination system's web server. The script will further intercept the response from the web server, pick up sensitive information out of it, and forward to the site controlled by the adversary." ;
        capec:attackStepPhase        "Exploit" ;
        capec:attackStepTechnique    "The adversary's malicious script circumvents the httpOnly cookie attribute that prevents from hijacking the victim's session cookie directly using document.cookie and instead leverages the HTTP TRACE to catch this information from the header of the HTTP request once it is echoed back from the web server in the body of the HTTP TRACE response." .

capec-res:CAPEC-268  a                 capec:CAPEC ;
        dct:description                "The attacker injects, manipulates, deletes, or forges malicious log entries into the log file, in an attempt to mislead an audit of the log file or cover tracks of an attack. Due to either insufficient access controls of the log files or the logging mechanism, the attacker is able to perform such actions." ;
        dct:identifier                 "268" ;
        dct:title                      "Audit Log Manipulation" ;
        capec:abstraction              "Standard" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/26820170109> , <http://w3id.org/sepses/resource/capec/modificationHistory/26820220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/26820190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/26820190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/26820201217> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/268ChildOf161> ;
        capec:hasRelatedWeakness       cwe-res:CWE-117 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/26820140623> ;
        capec:prerequisite             "The target host insufficiently protects access to the logs or logging mechanisms." , "The target host is logging the action and data of the user." ;
        capec:resourceRequired         "\n               The attacker must understand how the logging mechanism works.\n               Optionally, the attacker must know the location and the format of individual entries of the log files.\n            " ;
        capec:status                   "Draft" .

<http://w3id.org/sepses/resource/capec/submissionHistory/42220140623>
        a                             capec:SubmissionHistory ;
        capec:submissionDate          "2014-06-23" ;
        capec:submissionName          "CAPEC Content Team" ;
