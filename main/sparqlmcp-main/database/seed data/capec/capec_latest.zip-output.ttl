        a       capec:RelatedAttackPattern ;
        capec:relatedAttackPatternCAPECId
                capec-res:CAPEC-242 ;
        capec:relatedAttackPatternNature
                "CanFollow" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/1322>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Try to create symlinks to different files] The adversary then uses a variety of techniques, such as monitoring or guessing to create symlinks to the files accessed by the target application in the directories which are identified in the explore phase." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "The adversary may need a little guesswork on the filenames on which the target application would operate." , "The adversary monitors the file operations performed by the target application using a tool like dtrace or FileMon. And the adversary can delay the operations by using \"sleep(2)\" and \"usleep()\" to prepare the appropriate conditions for the attack, or make the application perform expansive tasks (large files parsing, etc.) depending on the purpose of the application." , "The adversary tries to create symlinks to the various filenames." .

capec-res:CAPEC-517  a                 capec:CAPEC ;
        dct:description                "An attacker with access to a manufacturer's documentation, which include descriptions of advanced technology and/or specific components' criticality, alters the documents to circumvent dial-down functionality requirements. This alteration would change the interpretation of implementation and manufacturing techniques, allowing for advanced technologies to remain in place even though these technologies might be restricted to certain customers, such as nations on the terrorist watch list, giving the attacker on the receiving end of a shipped product access to an advanced technology that might otherwise be restricted." ;
        dct:identifier                 "517" ;
        dct:title                      "Documentation Alteration to Circumvent Dial-down" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/51720220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/51720151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/51720190930> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-439> , <http://w3id.org/sepses/resource/capec/reference/REF-715> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/517ChildOf447> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/51720140623> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Avoid emailing important documents and configurations." , "Ensure deleted files are actually deleted." , "Digitize documents and cryptographically sign them to verify authenticity." , "Password protect documents and make them read-only for unauthorized users." , "Maintain backups of the document for recovery and verification." ;
        capec:prerequisite             "Access to the manufacturer's documentation." , "Advanced knowledge of internal software and hardware components within manufacturer's development environment." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/4572>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Develop or Obtain malware and install on a USB device] The adversary develops or obtains the malicious software necessary to exploit the target system, which they then install on an external USB device such as a USB flash drive." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "The adversary can develop or obtain malware for to perform a variety of tasks such as sniffing network traffic or monitoring keystrokes." .

