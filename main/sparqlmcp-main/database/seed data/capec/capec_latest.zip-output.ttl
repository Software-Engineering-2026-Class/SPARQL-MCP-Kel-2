<http://w3id.org/sepses/resource/capec/ExecutionFlow/4573>
        a                            capec:AttackStep ;
        capec:attackStep             "3" ;
        capec:attackStepDescription  "[Connect or deceive a user into connecting the infected USB device] Once the malware has been placed on an external USB device, the adversary connects the device to the target system or deceives a user into connecting the device to the target system such as in a USB Drop Attack." ;
        capec:attackStepPhase        "Exploit" ;
        capec:attackStepTechnique    "The adversary connects the USB device to a specified target system or performs a USB Drop Attack, hoping a user will find and connect the USB device on their own. Once the device is connected, the malware executes giving the adversary access to network traffic, credentials, etc." .

<http://w3id.org/sepses/resource/capec/Consequence/654104>
        a                        capec:Consequence ;
        capec:consequenceImpact  "Gain Privileges" ;
        capec:consequenceScope   "Authentication" , "Access Control" .

capec-res:CAPEC-328  a                 capec:CAPEC ;
        dct:description                "This OS fingerprinting probe performs a checksum on any ASCII data contained within the data portion or a RST packet. Some operating systems will report a human-readable text message in the payload of a 'RST' (reset) packet when specific types of connection errors occur. RFC 1122 allows text payloads within reset packets but not all operating systems or routers implement this functionality." ;
        dct:identifier                 "328" ;
        dct:title                      "TCP 'RST' Flag Checksum Probe" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/328177> , <http://w3id.org/sepses/resource/capec/Consequence/32869> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/32820180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/32820170501> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-33> , <http://w3id.org/sepses/resource/capec/reference/REF-128> , <http://w3id.org/sepses/resource/capec/reference/REF-212> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/328ChildOf312> ;
        capec:hasRelatedWeakness       cwe-res:CWE-200 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/32820140623> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:prerequisite             "The ability to monitor and interact with network communications.Access to at least one host, and the privileges to interface with the network interface card." ;
        capec:resourceRequired         "A tool capable of sending and receiving packets from a remote system." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "Low" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/6621>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "The adversary tricks the victim into installing the Trojan Horse malware onto their system." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Conduct phishing attacks, drive-by malware installations, or masquerade malicious browser extensions as being legitimate." .

<http://w3id.org/sepses/resource/capec/Consequence/29265>
        a                        capec:Consequence ;
        capec:consequenceImpact  "Other" ;
        capec:consequenceScope   "Confidentiality" .

capec-res:CAPEC-138  a                 capec:CAPEC ;
        dct:description                "An adversary supplies a value to the target application which is then used by reflection methods to identify a class, method, or field. For example, in the Java programming language the reflection libraries permit an application to inspect, load, and invoke classes and their components by name. If an adversary can control the input into these methods including the name of the class/method/field or the parameters passed to methods, they can cause the targeted application to invoke incorrect methods, read random fields, or even to load and utilize malicious classes that the adversary created. This can lead to the application revealing sensitive information, returning incorrect results, or even having the adversary take control of the targeted application." ;
        dct:identifier                 "138" ;
        dct:title                      "Reflection Injection" ;
        capec:abstraction              "Standard" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/13820230124> , <http://w3id.org/sepses/resource/capec/modificationHistory/13820190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/13820170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/13820190930> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/138ChildOf137> ;
        capec:hasRelatedWeakness       cwe-res:CWE-470 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/13820140623> ;
        capec:prerequisite             "The target application must accept a string as user input, fail to sanitize characters that have a special meaning in the parameter encoding, and insert the user-supplied string in an encoding which is then processed." , "The target application must utilize reflection libraries and allow users to directly control the parameters to these methods. If the adversary can host classes where the target can invoke them, more powerful variants of this attack are possible." ;
        capec:resourceRequired         "None: No specialized resources are required to execute this type of attack." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Very High" .

