capec-res:CAPEC-49  a                  capec:CAPEC ;
        dct:description                "An adversary tries every possible value for a password until they succeed. A brute force attack, if feasible computationally, will always be successful because it will essentially go through all possible passwords given the alphabet used (lower case letters, upper case letters, numbers, symbols, etc.) and the maximum length of the password." ;
        dct:identifier                 "49" ;
        dct:title                      "Password Brute Forcing" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/492> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/491> , <http://w3id.org/sepses/resource/capec/Consequence/49134> , <http://w3id.org/sepses/resource/capec/Consequence/4965> , <http://w3id.org/sepses/resource/capec/Consequence/4969> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/4920220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/4920170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/4920190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/4920200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/4920180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/4920201217> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/49CanPrecede653> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/49CanPrecede560> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/49CanPrecede561> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/49CanPrecede600> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/49CanPrecede151> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/49ChildOf112> ;
        capec:hasRelatedWeakness       cwe-res:CWE-262 , cwe-res:CWE-309 , cwe-res:CWE-257 , cwe-res:CWE-308 , cwe-res:CWE-307 , cwe-res:CWE-263 , cwe-res:CWE-654 , cwe-res:CWE-521 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/4920140623> ;
        capec:indicator                "Many incorrect login attempts are detected by the system." ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Implement a password throttling mechanism. This mechanism should take into account both the IP address and the log in name of the user." , "Passwords need to be recycled to prevent aging, that is every once in a while a new password must be chosen." , "Put together a strong password policy and make sure that all user created passwords comply with it. Alternatively automatically generate strong passwords for users." ;
        capec:prerequisite             "The system uses password based authentication as the one factor authentication mechanism." , "An adversary needs to know a username to target." , "An application does not have a password throttling mechanism in place. A good password throttling mechanism will make it almost impossible computationally to brute force a password as it may either lock out the user after a certain number of incorrect attempts or introduce time out periods. Both of these would make a brute force attack impractical." ;
        capec:resourceRequired         "A powerful enough computer for the job with sufficient CPU, RAM and HD. Exact requirements will depend on the size of the brute force job and the time requirement for completion. Some brute forcing jobs may require grid or distributed computing (e.g. DES Challenge)." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

