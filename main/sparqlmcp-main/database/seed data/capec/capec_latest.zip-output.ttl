capec-res:CAPEC-441  a                capec:CAPEC ;
        dct:description               "An adversary installs or adds malicious logic (also known as malware) into a seemingly benign component of a fielded system. This logic is often hidden from the user of the system and works behind the scenes to achieve negative impacts. With the proliferation of mass digital storage and inexpensive multimedia devices, Bluetooth and 802.11 support, new attack vectors for spreading malware are emerging for things we once thought of as innocuous greeting cards, picture frames, or digital projectors. This pattern of attack focuses on systems already fielded and used in operation as opposed to systems and their components that are still under development and part of the supply chain." ;
        dct:identifier                "441" ;
        dct:title                     "Malicious Logic Insertion" ;
        capec:abstraction             "Meta" ;
        capec:hasConsequence          <http://w3id.org/sepses/resource/capec/Consequence/44187> ;
        capec:hasModificationHistory  <http://w3id.org/sepses/resource/capec/modificationHistory/44120180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/44120151109> ;
        capec:hasRelatedWeakness      cwe-res:CWE-284 ;
        capec:hasSubmissionHistory    <http://w3id.org/sepses/resource/capec/submissionHistory/44120140623> ;
        capec:likelihoodOfAttack      "Medium" ;
        capec:prerequisite            "Access to the component currently deployed at a victim location." ;
        capec:status                  "Stable" ;
        capec:typicalSeverity         "High" .

<http://w3id.org/sepses/resource/capec/reference/REF-92>
        a                               capec:Reference ;
        capec:referencePublicationYear  "2007" ;
        capec:referencePublisher        "Microsoft Corporation" ;
        capec:referenceTitle            "Malware Protection Center: Threat Research and Response" ;
        capec:referenceUrl              "https://www.microsoft.com/en-us/wdsi/threats/malware-encyclopedia-description?Name=Exploit%3AJava%2FByteVerify.C" .

capec-res:CAPEC-251  a                 capec:CAPEC ;
        dct:description                "The attacker forces an application to load arbitrary code files from the local machine. The attacker could use this to try to load old versions of library files that have known vulnerabilities, to load files that the attacker placed on the local machine during a prior attack, or to otherwise change the functionality of the targeted application in unexpected ways." ;
        dct:identifier                 "251" ;
        dct:title                      "Local Code Inclusion" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/251188> , <http://w3id.org/sepses/resource/capec/Consequence/251232> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/25120200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/25120180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/25120151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/25120201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/25120190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/25120170804> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-613> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/251ChildOf175> ;
        capec:hasRelatedWeakness       cwe-res:CWE-829 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/25120140623> ;
        capec:mitigation               "Implementation: Avoid passing user input to filesystem or framework API. If necessary to do so, implement a specific, allowlist approach." ;
        capec:prerequisite             "The targeted application must have a bug that allows an adversary to control which code file is loaded at some juncture." , "Some variants of this attack may require that old versions of some code files be present and in predictable locations." ;
        capec:resourceRequired         "The adversary needs to have enough access to the target application to control the identity of a locally included file. The attacker may also need to be able to upload arbitrary code files to the target machine, although any location for these files may be acceptable." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "Medium" .

