<http://w3id.org/sepses/resource/capec/ExecutionFlow/4994>
        a                            capec:AttackStep ;
        capec:attackStep             "4" ;
        capec:attackStepDescription  "[Intercept Implicit Intents] Once the malicious app is downloaded, the android device will forward any implicit intents from the target application to the malicious application, allowing the adversary to gaina access to the contents of the intent. The adversary can proceed with any attack using the contents of the intent." ;
        capec:attackStepPhase        "Exploit" ;
        capec:attackStepTechnique    "Gather sensitive information from the intercepted intent" , "Block the intent from reaching the desired location, causing a denial of service" , "Modify the contents of the intent and forward along to another application" .

