capec-res:CAPEC-231  a                 capec:CAPEC ;
        dct:description                "An adversary injects oversized serialized data payloads into a parser during data processing to produce adverse effects upon the parser such as exhausting system resources and arbitrary code execution." ;
        dct:identifier                 "231" ;
        dct:title                      "Oversized Serialized Data Payloads" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/2311> , <http://w3id.org/sepses/resource/capec/Consequence/231134> , <http://w3id.org/sepses/resource/capec/Consequence/23169> , <http://w3id.org/sepses/resource/capec/Consequence/23177> , <http://w3id.org/sepses/resource/capec/Consequence/231142> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2312> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/23120200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/23120210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/23120201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/23120190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/23120220929> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-89> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/231ChildOf130> ;
        capec:hasRelatedWeakness       cwe-res:CWE-112 , cwe-res:CWE-20 , cwe-res:CWE-770 , cwe-res:CWE-674 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/23120140623> ;
        capec:indicator                "Bad data is passed to the serialized data parser (possibly repeatedly), possibly making it crash or execute arbitrary code." ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Validate data against a valid schema or DTD prior to parsing." , "Pick a robust implementation of the serialized data parser." , "Carefully validate and sanitize all user-controllable serialized data prior to passing it to the parser routine. Ensure that the resultant data is safe to pass to the parser." , "Perform validation on canonical data." ;
        capec:prerequisite             "An application uses an parser for serialized data to perform transformation on user-controllable data." , "An application does not perform sufficient validation to ensure that user-controllable data is safe for a data parser." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

