capec-res:CAPEC-115  a                capec:CAPEC ;
        dct:description               "An attacker gains access to application, service, or device with the privileges of an authorized or privileged user by evading or circumventing an authentication mechanism. The attacker is therefore able to access protected data without authentication ever having taken place." ;
        dct:identifier                "115" ;
        dct:title                     "Authentication Bypass" ;
        capec:abstraction             "Meta" ;
        capec:hasModificationHistory  <http://w3id.org/sepses/resource/capec/modificationHistory/11520220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/11520201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/11520210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/11520151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/11520170804> ;
        capec:hasReference            <http://w3id.org/sepses/resource/capec/reference/REF-598> ;
        capec:hasRelatedWeakness      cwe-res:CWE-287 ;
        capec:hasSubmissionHistory    <http://w3id.org/sepses/resource/capec/submissionHistory/11520140623> ;
        capec:prerequisite            "An authentication mechanism or subsystem implementing some form of authentication such as passwords, digest authentication, security certificates, etc." ;
        capec:resourceRequired        "A client application, such as a web browser, or a scripting language capable of interacting with the target." ;
        capec:status                  "Draft" ;
        capec:typicalSeverity         "Medium" .

