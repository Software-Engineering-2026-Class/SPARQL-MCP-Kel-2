capec-res:CAPEC-572  a                 capec:CAPEC ;
        dct:description                "\n            An adversary modifies file contents by adding data to files for several reasons. Many different attacks could “follow” this pattern resulting in numerous outcomes. Adding data to a file could also result in a Denial of Service condition for devices with limited storage capacity.\n         " ;
        dct:identifier                 "572" ;
        dct:title                      "Artificially Inflate File Sizes" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/57265> , <http://w3id.org/sepses/resource/capec/Consequence/572110> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/57220200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/57220190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/57220210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/57220190930> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/572ChildOf165> ;
