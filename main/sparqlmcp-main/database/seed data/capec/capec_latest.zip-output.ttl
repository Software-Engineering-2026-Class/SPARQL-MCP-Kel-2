capec-res:CAPEC-144  a                 capec:CAPEC ;
        dct:description                "An adversary searches a targeted web site for web services that have not been publicized. This attack can be especially dangerous since unpublished but available services may not have adequate security controls placed upon them given that an administrator may believe they are unreachable." ;
        dct:identifier                 "144" ;
        dct:title                      "Detect Unpublicized Web Services" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/1444> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1443> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1442> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1441> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/14420211021> , <http://w3id.org/sepses/resource/capec/modificationHistory/14420190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/14420200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/14420230124> , <http://w3id.org/sepses/resource/capec/modificationHistory/14420151207> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/144ChildOf150> ;
        capec:hasRelatedWeakness       cwe-res:CWE-425 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/14420140623> ;
        capec:prerequisite             "The targeted web site must include unpublished services within its web tree. The nature of these services determines the severity of this attack." ;
        capec:resourceRequired         "Spidering tools to explore the target web site are extremely useful in this attack especially when attacking large sites. Some tools might also be able to automatically construct common service queries from known paths." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Low" .

