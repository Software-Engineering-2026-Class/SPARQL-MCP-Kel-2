<http://w3id.org/sepses/resource/capec/skillRequired/42670>
        a                        capec:SkillRequired ;
        capec:isSkillRequiredOf  capec-res:CAPEC-426 ;
        capec:skillDescription   "The adversary requires strong inter-personal and communication skills." ;
        capec:skillLevel         "Low" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/2793>
        a                            capec:AttackStep ;
        capec:attackStep             "3" ;
        capec:attackStepDescription  "[Manipulate SOAP parameters] The adversary manipulates SOAP parameters in a way that causes undesirable behavior for the server. This can result in denial of service, information disclosure, arbitrary code exection, and more." ;
        capec:attackStepPhase        "Exploit" ;
        capec:attackStepTechnique    "Insert XML metacharacters into data fields that could cause the server to go into an error state when parsing. This could lead to a denial of service." , "Create a recursive XML payload that will take up all of the memory on the server when parsed, resulting in a denial of service. This is known as the billion laughs attack." , "Insert a large amount of data into a field that should have a character limit, causing a buffer overflow." .

