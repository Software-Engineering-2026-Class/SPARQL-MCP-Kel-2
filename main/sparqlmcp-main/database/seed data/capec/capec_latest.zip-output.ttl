<http://w3id.org/sepses/resource/capec/ExecutionFlow/102>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Find injection vector] The adversary identifies an injection vector to deliver the excessive content to the targeted application's buffer." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Change the values of environment variables thought to be used by the application to contain excessive data. If the program is loading the value of the environment variable into a buffer, this could cause a crash and an attack vector will be found." .

capec-res:CAPEC-424  a                 capec:CAPEC ;
        dct:description                "The adversary influences the target's actions by leveraging the inherent human nature to assume behavior of others is appropriate. In situations of uncertainty, people tend to behave in ways they see others behaving. The adversary convinces the target of adopting behavior or actions that is advantageous to the adversary." ;
        dct:identifier                 "424" ;
        dct:title                      "Influence Perception of Consensus or Social Proof" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/424369> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/42420170804> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-348> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/424ChildOf417> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/42420140623> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "An organization should provide regular, robust cybersecurity training to its employees to prevent social engineering attacks." ;
        capec:prerequisite             "The adversary must have the means and knowledge of how to communicate with the target in some manner." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Low" .

