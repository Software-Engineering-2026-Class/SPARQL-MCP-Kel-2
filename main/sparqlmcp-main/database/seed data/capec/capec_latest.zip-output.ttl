capec-res:CAPEC-508  a                 capec:CAPEC ;
        dct:description                "In a shoulder surfing attack, an adversary observes an unaware individual's keystrokes, screen content, or conversations with the goal of obtaining sensitive information. One motive for this attack is to obtain sensitive information about the target for financial, personal, political, or other gains. From an insider threat perspective, an additional motive could be to obtain system/application credentials or cryptographic keys. Shoulder surfing attacks are accomplished by observing the content \"over the victim's shoulder\", as implied by the name of this attack." ;
        dct:identifier                 "508" ;
        dct:title                      "Shoulder Surfing" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/50889> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/508CanPrecede560> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/508ChildOf651> ;
        capec:hasRelatedWeakness       cwe-res:CWE-200 , cwe-res:CWE-359 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/50820200730> ;
        capec:likelihoodOfAttack       "High" ;
        capec:mitigation               "Pertaining to insider threats, ensure that sensitive information is not displayed to nor discussed around individuals without need-to-know access to said information." , "Be mindful of your surroundings when discussing or viewing sensitive information in public areas." ;
        capec:prerequisite             "The adversary typically requires physical proximity to the target's environment, in order to observe their screen or conversation. This may not be the case if the adversary is able to record the target and obtain sensitive information upon review of the recording." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

