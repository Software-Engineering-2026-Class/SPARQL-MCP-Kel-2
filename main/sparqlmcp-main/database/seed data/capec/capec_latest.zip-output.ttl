capec-res:CAPEC-652  a                 capec:CAPEC ;
        dct:description                "An adversary obtains (i.e. steals or purchases) legitimate Kerberos credentials (e.g. Kerberos service account userID/password or Kerberos Tickets) with the goal of achieving authenticated access to additional systems, applications, or services within the domain." ;
        dct:identifier                 "652" ;
        dct:title                      "Use of Known Kerberos Credentials" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/65298> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6523> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6525> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6521> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6524> , <http://w3id.org/sepses/resource/capec/Consequence/652135> , <http://w3id.org/sepses/resource/capec/Consequence/65265> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6522> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/65220220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/65220201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/65220220929> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-584> , <http://w3id.org/sepses/resource/capec/reference/REF-586> , <http://w3id.org/sepses/resource/capec/reference/REF-585> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/652CanPrecede151> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/652ChildOf560> ;
        capec:hasRelatedWeakness       cwe-res:CWE-654 , cwe-res:CWE-262 , cwe-res:CWE-522 , cwe-res:CWE-309 , cwe-res:CWE-307 , cwe-res:CWE-263 , cwe-res:CWE-836 , cwe-res:CWE-308 , cwe-res:CWE-294 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/65220200730> ;
        capec:indicator                "Data is being transferred and/or removed from systems/applications within the network." , "Messages from a legitimate user appear to contain suspicious links or communications not consistent with the user's normal behavior." , "Authentication attempts are originating from IP addresses or locations that are inconsistent with an account's normal IP addresses or locations." , "Authentication attempts use expired or invalid credentials." , "Suspicious or Malicious software is downloaded/installed on systems within the domain." ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Enable at least AES Kerberos encryption for tickets." , "Monitor system and domain logs for abnormal credential access." , "Ensure Kerberos service accounts are not reusing username/password combinations for multiple systems, applications, or services." , "Do not allow Kerberos service accounts to be a local administrator on more than one system." , "Create a strong password policy and ensure that your system enforces this policy for Kerberos service accounts." , "Deny remote use of Kerberos service account credentials to log into domain systems." , "Do not reuse Kerberos service account credentials across systems." ;
        capec:prerequisite             "The system/application uses one factor password-based authentication, SSO, and/or cloud-based authentication for Kerberos service accounts." , "The targeted network allows for network sniffing attacks to succeed." , "The system/application does not have a sound password policy that is being enforced for Kerberos service accounts." , "The system/application leverages Kerberos authentication." , "The system/application does not implement an effective password throttling mechanism for authenticating to Kerberos service accounts." ;
        capec:resourceRequired         "A valid Kerberos ticket or a known Kerberos service account credential." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

