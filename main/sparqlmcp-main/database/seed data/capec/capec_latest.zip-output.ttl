capec-res:CAPEC-270  a                 capec:CAPEC ;
        dct:description                "An adversary adds a new entry to the \"run keys\" in the Windows registry so that an application of their choosing is executed when a user logs in. In this way, the adversary can get their executable to operate and run on the target system with the authorized user's level of permissions. This attack is a good way for an adversary to run persistent spyware on a user's machine, such as a keylogger." ;
        dct:identifier                 "270" ;
        dct:title                      "Modification of Registry Run Keys" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/2701> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2702> , <http://w3id.org/sepses/resource/capec/Consequence/27096> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2703> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/27020200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/27020190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/27020211021> , <http://w3id.org/sepses/resource/capec/modificationHistory/27020220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/27020151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/27020180731> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/270ChildOf203> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/270CanPrecede646> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/270CanPrecede568> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/270CanPrecede529> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/270CanFollow555> ;
        capec:hasRelatedWeakness       cwe-res:CWE-15 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/27020140623> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Identify programs that may be used to acquire process information and block them by using a software restriction policy or tools that restrict program execution by using a process allowlist." ;
        capec:prerequisite             "The adversary must have gained access to the target system via physical or logical means in order to carry out this attack." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "Medium" .

