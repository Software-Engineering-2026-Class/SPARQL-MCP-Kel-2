capec-res:CAPEC-387  a                 capec:CAPEC ;
        dct:description                "An adversary manipulates either egress or ingress data from a client within an application framework in order to change the content of messages and thereby circumvent the expected application logic." ;
        dct:identifier                 "387" ;
        dct:title                      "Navigation Remapping To Propagate Malicious Content" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/38720220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/38720190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/38720210624> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-327> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/387ChildOf386> ;
        capec:hasRelatedWeakness       cwe-res:CWE-311 , cwe-res:CWE-471 , cwe-res:CWE-345 , cwe-res:CWE-346 , cwe-res:CWE-602 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/38720140623> ;
        capec:prerequisite             "Targeted software is utilizing application framework APIs" ;
        capec:resourceRequired         "A software program that allows the use of adversary-in-the-middle communications between the client and server, such as a man-in-the-middle proxy." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

