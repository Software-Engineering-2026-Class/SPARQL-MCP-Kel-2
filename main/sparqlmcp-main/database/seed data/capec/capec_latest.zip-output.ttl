capec-res:CAPEC-599  a                 capec:CAPEC ;
        dct:description                "In this attack pattern, the adversary transmits disruptive signals in the direction of the target's consumer-level satellite dish (as opposed to the satellite itself). The transmission disruption occurs in a more targeted range. Portable terrestrial jammers have a range of 3-5 kilometers in urban areas and 20 kilometers in rural areas. This technique requires a terrestrial jammer that is more powerful than the frequencies sent from the satellite." ;
        dct:identifier                 "599" ;
        dct:title                      "Terrestrial Jamming" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/599262> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/59920230124> , <http://w3id.org/sepses/resource/capec/modificationHistory/59920190404> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-462> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/599ChildOf195> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/59920170112> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:resourceRequired         "\n               A terrestrial satellite jammer with a signal more powerful than that of the satellite attempting to communicate with the target.\n               The adversary must know the location of the target satellite dish.\n            " ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

