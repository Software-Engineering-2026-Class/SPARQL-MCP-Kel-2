<http://w3id.org/sepses/resource/capec/ExecutionFlow/1071>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Determine if HTTP Trace is enabled] Determine if HTTP Trace is enabled at the web server with which the victim has an active session" ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "An adversary may issue an HTTP Trace request to the target web server and observe if the response arrives with the original request in the body of the response." .

