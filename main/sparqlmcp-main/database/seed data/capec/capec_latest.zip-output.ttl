        capec:modificationOrganization  "The MITRE Corporation" .

capec-res:CAPEC-216  a                 capec:CAPEC ;
        dct:description                "An adversary manipulates a setting or parameter on communications channel in order to compromise its security. This can result in information exposure, insertion/removal of information from the communications stream, and/or potentially system compromise." ;
        dct:identifier                 "216" ;
        dct:title                      "Communication Channel Manipulation" ;
        capec:abstraction              "Meta" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/216268> , <http://w3id.org/sepses/resource/capec/Consequence/216253> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/21620170501> , <http://w3id.org/sepses/resource/capec/modificationHistory/21620230124> , <http://w3id.org/sepses/resource/capec/modificationHistory/21620210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/21620151207> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/216CanPrecede94> ;
        capec:hasRelatedWeakness       cwe-res:CWE-306 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/21620140623> ;
        capec:mitigation               "Design the communication system such that it associates proper authentication/authorization with each channel/message." , "Encrypt all sensitive communications using properly-configured cryptography." ;
        capec:prerequisite             "The channel on which the target communicates must be vulnerable to interception (e.g., adversary in the middle attack - CAPEC-94)." , "The target application must leverage an open communications channel." ;
        capec:resourceRequired         "A tool that is capable of viewing network traffic and generating custom inputs to be used in the attack." ;
        capec:status                   "Stable" .

