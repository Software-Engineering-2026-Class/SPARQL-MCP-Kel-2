capec-res:CAPEC-459  a                 capec:CAPEC ;
        dct:description                "An adversary exploits a weakness resulting from using a hashing algorithm with weak collision resistance to generate certificate signing requests (CSR) that contain collision blocks in their \"to be signed\" parts. The adversary submits one CSR to be signed by a trusted certificate authority then uses the signed blob to make a second certificate appear signed by said certificate authority. Due to the hash collision, both certificates, though different, hash to the same value and so the signed blob works just as well in the second certificate. The net effect is that the adversary's second X.509 certificate, which the Certification Authority has never seen, is now signed and validated by that Certification Authority." ;
        dct:identifier                 "459" ;
        dct:title                      "Creating a Rogue Certification Authority Certificate" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/4591> , <http://w3id.org/sepses/resource/capec/Consequence/459104> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/4592> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/4593> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/45920220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/45920201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/45920170501> , <http://w3id.org/sepses/resource/capec/modificationHistory/45920200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/45920220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/45920180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/45920210624> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-395> , <http://w3id.org/sepses/resource/capec/reference/REF-587> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/459ChildOf473> ;
        capec:hasRelatedWeakness       cwe-res:CWE-327 , cwe-res:CWE-295 , cwe-res:CWE-290 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/45920140623> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Certification Authorities need to stop using deprecated or cryptographically insecure hashing algorithms to hash the certificates that they are about to sign. Instead they should be using stronger hashing functions such as SHA-256 or SHA-512." ;
        capec:prerequisite             "Certification Authority is using a hash function with insufficient collision resistance to generate the certificate hash to be signed" ;
        capec:resourceRequired         "Knowledge of a certificate authority that uses hashing algorithms with poor collision resistance" , "A valid certificate request and a malicious certificate request with identical hash values" ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Very High" .

