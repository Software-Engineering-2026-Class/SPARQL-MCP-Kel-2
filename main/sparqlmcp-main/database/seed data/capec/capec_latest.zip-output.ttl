<http://w3id.org/sepses/resource/capec/ExecutionFlow/2153>
        a                            capec:AttackStep ;
        capec:attackStep             "3" ;
        capec:attackStepDescription  "[Observe the outcome] Observe the outputs to the inputs fed into the system by fuzzers and see if there are any log or error messages that might provide information to map the application" ;
        capec:attackStepPhase        "Experiment" .

