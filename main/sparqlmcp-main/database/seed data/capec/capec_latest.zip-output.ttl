capec-res:CAPEC-321  a                 capec:CAPEC ;
        dct:description                "This OS fingerprinting probe tests the target system's assignment of TCP sequence numbers. One common way to test TCP Sequence Number generation is to send a probe packet to an open port on the target and then compare the how the Sequence Number generated by the target relates to the Acknowledgement Number in the probe packet. Different operating systems assign Sequence Numbers differently, so a fingerprint of the operating system can be obtained by categorizing the relationship between the acknowledgement number and sequence number as follows: 1) the Sequence Number generated by the target is Zero, 2) the Sequence Number generated by the target is the same as the acknowledgement number in the probe, 3) the Sequence Number generated by the target is the acknowledgement number plus one, or 4) the Sequence Number is any other non-zero number." ;
        dct:identifier                 "321" ;
        dct:title                      "TCP Sequence Number Probe" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/32169> , <http://w3id.org/sepses/resource/capec/Consequence/321177> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/32120180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/32120170501> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-128> , <http://w3id.org/sepses/resource/capec/reference/REF-212> , <http://w3id.org/sepses/resource/capec/reference/REF-33> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/321ChildOf312> ;
        capec:hasRelatedWeakness       cwe-res:CWE-200 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/32120140623> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:prerequisite             "The ability to monitor and interact with network communications.Access to at least one host, and the privileges to interface with the network interface card." ;
        capec:resourceRequired         "A tool capable of sending and receiving packets from a remote system." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "Low" .

<http://w3id.org/sepses/resource/capec/reference/REF-745>
        a                      capec:Reference ;
        capec:referenceAuthor  "Dan Maloney" ;
        capec:referenceTitle   "Exposing Computer Monitor Side-Channel Vulnerabilities with TempestSDR" ;
        capec:referenceUrl     "https://hackaday.com/2020/07/15/exposing-computer-monitor-side-channel-vulnerabilities-with-tempestsdr/" .

capec-res:CAPEC-131  a                capec:CAPEC ;
        dct:description               "An adversary utilizes a resource leak on the target to deplete the quantity of the resource available to service legitimate requests." ;
        dct:identifier                "131" ;
        dct:title                     "Resource Leak Exposure" ;
        capec:abstraction             "Meta" ;
        capec:hasConsequence          <http://w3id.org/sepses/resource/capec/Consequence/131233> ;
        capec:hasModificationHistory  <http://w3id.org/sepses/resource/capec/modificationHistory/13120170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/13120220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/13120201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/13120170501> , <http://w3id.org/sepses/resource/capec/modificationHistory/13120210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/13120200730> ;
        capec:hasRelatedWeakness      cwe-res:CWE-404 ;
        capec:hasSubmissionHistory    <http://w3id.org/sepses/resource/capec/submissionHistory/13120140623> ;
        capec:likelihoodOfAttack      "Medium" ;
        capec:mitigation              "Memory should always be allocated/freed using matching functions (e.g., malloc/free, new/delete, etc.)" , "If possible, leverage coding language(s) that do not allow this weakness to occur (e.g., Java, Ruby, and Python all perform automatic garbage collection that releases memory for objects that have been deallocated)." , "Implement best practices with respect to memory management, including the freeing of all allocated resources at all exit points and ensuring consistency with how and where memory is freed in a function." ;
        capec:prerequisite            "The target must have a resource leak that the adversary can repeatedly trigger." ;
        capec:resourceRequired        "None: No specialized resources are required to execute this type of attack." ;
        capec:status                  "Stable" ;
        capec:typicalSeverity         "Medium" .

