capec-res:CAPEC-679  a                 capec:CAPEC ;
        dct:description                "\n            An adversary takes advantage of missing or incorrectly configured access control within memory to read/write data or inject malicious code into said memory.\n         " ;
        dct:identifier                 "679" ;
        dct:title                      "Exploitation of Improperly Configured or Implemented Memory Protections" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/67965> , <http://w3id.org/sepses/resource/capec/Consequence/679134> , <http://w3id.org/sepses/resource/capec/Consequence/67969> , <http://w3id.org/sepses/resource/capec/Consequence/679176> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-687> , <http://w3id.org/sepses/resource/capec/reference/REF-690> , <http://w3id.org/sepses/resource/capec/reference/REF-668> , <http://w3id.org/sepses/resource/capec/reference/REF-689> , <http://w3id.org/sepses/resource/capec/reference/REF-692> , <http://w3id.org/sepses/resource/capec/reference/REF-691> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/679ChildOf1> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/679ChildOf180> ;
        capec:hasRelatedWeakness       cwe-res:CWE-1252 , cwe-res:CWE-1326 , cwe-res:CWE-1274 , cwe-res:CWE-1222 , cwe-res:CWE-1312 , cwe-res:CWE-1282 , cwe-res:CWE-1260 , cwe-res:CWE-1257 , cwe-res:CWE-1316 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/67920211021> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Ensure that protected and unprotected memory ranges are isolated and do not overlap." , "Ensure that original and mirrored memory regions apply the same protections." , "If memory regions must overlap, leverage memory priority schemes if memory regions can overlap." , "Ensure immutable code or data is programmed into ROM or write-once memory." ;
        capec:prerequisite             "Access to the hardware being leveraged." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Very High" .

