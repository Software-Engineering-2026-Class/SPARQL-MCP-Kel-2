capec-res:CAPEC-698  a                 capec:CAPEC ;
        dct:description                "\n            An adversary directly installs or tricks a user into installing a malicious extension into existing trusted software, with the goal of achieving a variety of negative technical impacts.\n         " ;
        dct:identifier                 "698" ;
        dct:title                      "Install Malicious Extension" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/6981> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6982> , <http://w3id.org/sepses/resource/capec/Consequence/69899> , <http://w3id.org/sepses/resource/capec/Consequence/698185> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6983> , <http://w3id.org/sepses/resource/capec/Consequence/69895> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-741> , <http://w3id.org/sepses/resource/capec/reference/REF-740> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/698ChildOf542> ;
        capec:hasRelatedWeakness       cwe-res:CWE-507 , cwe-res:CWE-829 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/69820220929> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Confirm extensions/plugins are legitimate and not malware masquerading as a legitimate extension/plugin." , "Implement an extension/plugin allow list, based on the given security policy." , "If applicable, confirm extensions/plugins are properly signed by the official developers." , "Ensure the underlying software leveraging the extension/plugin (including operating systems) is up-to-date." , "Only install extensions/plugins from official/verifiable sources." , "For web browsers, close sessions when finished to prevent malicious extensions/plugins from executing the the background." ;
        capec:prerequisite             "The adversary must craft malware based on the type of software and system(s) they intend to exploit." , "If the adversary intends to install the malicious extension themself, they must first compromise the target machine via some other means." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "High" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/6991>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Survey Target] The adversary surveys the target location, looking for exposed display cables and locations to hide an SDR. This also includes looking for display cables or monitors placed close to a wall, where the SDR can be in range while behind the wall. The adversary also attempts to discover the resolution and refresh rate of the targeted display." ;
        capec:attackStepPhase        "Explore" .

