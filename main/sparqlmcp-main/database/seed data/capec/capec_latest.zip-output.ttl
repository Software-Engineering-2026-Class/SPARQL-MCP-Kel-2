        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Survey the target] Using a browser or an automated tool, an attacker records all instance of web services to process XML requests." ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "Use an automated tool to record all instances of URLs to process XML requests." , "Use a browser to manually explore the website and analyze how the application processes XML requests." .

capec-res:CAPEC-666  a                 capec:CAPEC ;
        dct:description                "An adversary uses Bluetooth flooding to transfer large packets to Bluetooth enabled devices over the L2CAP protocol with the goal of creating a DoS. This attack must be carried out within close proximity to a Bluetooth enabled device." ;
        dct:identifier                 "666" ;
        dct:title                      "BlueSmacking" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/6661> , <http://w3id.org/sepses/resource/capec/Consequence/666113> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6663> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6662> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/66620220929> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-655> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/666ChildOf125> ;
        capec:hasRelatedWeakness       cwe-res:CWE-404 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/66620210624> ;
        capec:indicator                "Performance is degraded or halted by incoming L2CAP packets." ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "When using Bluetooth, set it to hidden or non-discoverable mode." , "Disable Bluetooth when not being used." ;
        capec:prerequisite             "The system/application has Bluetooth enabled." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/154>
        a                            capec:AttackStep ;
        capec:attackStep             "4" ;
        capec:attackStepDescription  "[Use malicious command delimiters] The attacker uses combinations of payload and carefully placed command delimiters to attack the software." ;
        capec:attackStepPhase        "Exploit" .

capec-res:CAPEC-476  a                 capec:CAPEC ;
        dct:description                "An attacker exploits a weakness in the parsing or display code of the recipient software to generate a data blob containing a supposedly valid signature, but the signer's identity is falsely represented, which can lead to the attacker manipulating the recipient software or its victim user to perform compromising actions." ;
        dct:identifier                 "476" ;
        dct:title                      "Signature Spoofing by Misrepresentation" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/47620190404> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-414> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/476ChildOf473> ;
        capec:hasRelatedWeakness       cwe-res:CWE-290 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/47620140623> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Ensure the application is using parsing and data display techniques that will accurately display control characters, international symbols and markings, and ultimately recognize potential homograph attacks." ;
        capec:prerequisite             "Recipient is using signature verification software that does not clearly indicate potential homographs in the signer identity.Recipient is using signature verification software that contains a parsing vulnerability, or allows control characters in the signer identity field, such that a signature is mistakenly displayed as valid and from a known or authoritative signer." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

