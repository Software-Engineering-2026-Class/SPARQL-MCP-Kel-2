capec-res:CAPEC-639  a                 capec:CAPEC ;
        dct:description                "An adversary obtains unauthorized information due to improperly protected files. If an application stores sensitive information in a file that is not protected by proper access control, then an adversary can access the file and search for sensitive information." ;
        dct:identifier                 "639" ;
        dct:title                      "Probe System Files" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/63969> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/63920220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/63920200730> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/639ChildOf545> ;
        capec:hasRelatedWeakness       cwe-res:CWE-552 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/63920180504> ;
        capec:mitigation               "Verify that files have proper access controls set, and reduce the storage of sensitive information to only what is necessary." ;
        capec:prerequisite             "An adversary has access to the file system of a system." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "Medium" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/6932>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Spoof package popularity] The adversary provides their malicious package to a package manager and uses the source code repository URL identified in Step 1 to spoof the popularity of the package. This malicious package may also closely resemble the legitimate package whose statistics are being utilized." ;
        capec:attackStepPhase        "Experiment" .

