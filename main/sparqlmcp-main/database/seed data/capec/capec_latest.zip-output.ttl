capec-res:CAPEC-480  a                 capec:CAPEC ;
        dct:description                "An adversary gains access to an application, service, or device with the privileges of an authorized or privileged user by escaping the confines of a virtualized environment. The adversary is then able to access resources or execute unauthorized code within the host environment, generally with the privileges of the user running the virtualized process. Successfully executing an attack of this type is often the first step in executing more complex attacks." ;
        dct:identifier                 "480" ;
        dct:title                      "Escaping Virtualization" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/4803> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/4801> , <http://w3id.org/sepses/resource/capec/Consequence/480164> , <http://w3id.org/sepses/resource/capec/Consequence/480115> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/4802> , <http://w3id.org/sepses/resource/capec/Consequence/480121> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/48020201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/48020210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/48020211021> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/480ChildOf115> ;
        capec:hasRelatedWeakness       cwe-res:CWE-693 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/48020190930> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Ensure virtualization software is current and up-to-date." , "Abide by the least privilege principle to avoid assigning users more privileges than necessary." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Very High" .

<http://w3id.org/sepses/resource/capec/Consequence/18077>
        a                        capec:Consequence ;
        capec:consequenceImpact  "Unreliable Execution" ;
        capec:consequenceScope   "Availability" .

capec-res:CAPEC-290  a                 capec:CAPEC ;
        dct:description                "An adversary enumerates the MX records for a given via a DNS query. This type of information gathering returns the names of mail servers on the network. Mail servers are often not exposed to the Internet but are located within the DMZ of a network protected by a firewall. A side effect of this configuration is that enumerating the MX records for an organization my reveal the IP address of the firewall or possibly other internal systems. Attackers often resort to MX record enumeration when a DNS Zone Transfer is not possible." ;
        dct:identifier                 "290" ;
        dct:title                      "Enumerate Mail Exchange (MX) Records" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/29065> , <http://w3id.org/sepses/resource/capec/Consequence/290177> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/29020180731> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-33> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/290ChildOf309> ;
        capec:hasRelatedWeakness       cwe-res:CWE-200 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/29020140623> ;
        capec:prerequisite             "The adversary requires access to a DNS server that will return the MX records for a network." ;
        capec:resourceRequired         "A command-line utility or other application capable of sending requests to the DNS server is necessary." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "Low" .

<http://w3id.org/sepses/resource/capec/Consequence/597418>
        a                        capec:Consequence ;
        capec:consequenceImpact  "Modify Data" ;
        capec:consequenceNote    "The attacker may be able to overwrite or create critical files, such as programs, libraries, or important data. If the targeted file is used for a security mechanism, then the attacker may be able to bypass that mechanism. For example, appending a new account at the end of a password file may allow an attacker to bypass authentication." ;
        capec:consequenceScope   "Integrity" .

