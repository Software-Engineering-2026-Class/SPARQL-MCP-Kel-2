capec-res:CAPEC-256  a                 capec:CAPEC ;
        dct:description                "An attacker sends a SOAP request with an array whose actual length exceeds the length indicated in the request. If the server processing the transmission naively trusts the specified size, then an attacker can intentionally understate the size of the array, possibly resulting in a buffer overflow if the server attempts to read the entire data set into the memory it allocated for a smaller array." ;
        dct:identifier                 "256" ;
        dct:title                      "SOAP Array Overflow" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/2561> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2562> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2563> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2564> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/25620211021> , <http://w3id.org/sepses/resource/capec/modificationHistory/25620201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/25620190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/25620170804> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-102> , <http://w3id.org/sepses/resource/capec/reference/REF-103> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/256ChildOf100> ;
        capec:hasRelatedWeakness       cwe-res:CWE-805 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/25620140623> ;
        capec:mitigation               "If the server either verifies the correctness of the stated array size or if the server stops processing an array once the stated number of elements have been read, regardless of the actual array size, then this attack will fail. The former detects the malformed SOAP message while the latter ensures that the server does not attempt to load more data than was allocated for." ;
        capec:prerequisite             "The targeted SOAP server must trust that the array size as stated in messages it receives is correct, but read through the entire content of the message regardless of the stated size of the array." ;
        capec:resourceRequired         "The attacker must be able to craft malformed SOAP messages, specifically, messages with arrays where the stated array size understates the actual size of the array in the message." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

