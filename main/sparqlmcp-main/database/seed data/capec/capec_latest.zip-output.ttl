<http://w3id.org/sepses/resource/capec/ExecutionFlow/762>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Survey the Application to Identify User-controllable Inputs] The attacker surveys the target application to identify all user-controllable inputs, possibly as a valid and authenticated user" ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "Spider web sites for all available links, entry points to the web site." , "Manually explore application and inventory all application inputs" .

