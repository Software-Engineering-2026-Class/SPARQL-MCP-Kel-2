capec-res:CAPEC-600  a                 capec:CAPEC ;
        dct:description                "\n            An adversary tries known username/password combinations against different systems, applications, or services to gain additional authenticated access. Credential Stuffing attacks rely upon the fact that many users leverage the same username/password combination for multiple systems, applications, and services.\n         " ;
        dct:identifier                 "600" ;
        dct:title                      "Credential Stuffing" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/60098> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6005> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6003> , <http://w3id.org/sepses/resource/capec/Consequence/60065> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6004> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6002> , <http://w3id.org/sepses/resource/capec/Consequence/600135> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6001> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/60020201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/60020220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/60020220929> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-567> , <http://w3id.org/sepses/resource/capec/reference/REF-569> , <http://w3id.org/sepses/resource/capec/reference/REF-568> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/600CanPrecede151> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/600CanPrecede653> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/600ChildOf560> ;
        capec:hasRelatedWeakness       cwe-res:CWE-654 , cwe-res:CWE-263 , cwe-res:CWE-307 , cwe-res:CWE-522 , cwe-res:CWE-309 , cwe-res:CWE-262 , cwe-res:CWE-308 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/60020200730> ;
        capec:indicator                "Many invalid login attempts are coming from the same machine (same IP address) or for multiple user accounts within short succession." , "Login attempts are originating from IP addresses or locations that are inconsistent with the user's normal IP addresses or locations." , "The login attempts use passwords that have been used previously by the user account in question." ;
        capec:likelihoodOfAttack       "High" ;
        capec:mitigation               "Create a strong password policy and ensure that your system enforces this policy." , "Do not allow accounts to be a local administrator on more than one system." , "Leverage multi-factor authentication for all authentication services and prior to granting an entity access to the domain network." , "Monitor system and domain logs for abnormal credential access." , "Implement an intelligent password throttling mechanism. Care must be taken to assure that these mechanisms do not excessively enable account lockout attacks such as CAPEC-2." , "Deny remote use of local admin credentials to log into domain systems." , "Do not reuse local administrator account credentials across systems." , "Ensure users are not reusing username/password combinations for multiple systems, applications, or services." ;
        capec:prerequisite             "The system/application does not implement an effective password throttling mechanism." , "The system/application uses one factor password based authentication, SSO, and/or cloud-based authentication." , "The system/application does not have a sound password policy that is being enforced." , "The adversary possesses a list of known user accounts and corresponding passwords that may exist on the target." ;
        capec:resourceRequired         "A custom script that leverages the credential list to launch the attack." , "A machine with sufficient resources for the job (e.g. CPU, RAM, HD)." , "A known list of username/password combinations." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "High" .

