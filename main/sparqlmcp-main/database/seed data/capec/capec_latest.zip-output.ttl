        a                            capec:AttackStep ;
        capec:attackStep             "3" ;
        capec:attackStepDescription  "Once the Adversary determines that an SQL injection is possible, they must ensure that the requirements for the attack are met. These are a high privileged session user and batched query support. This is done in similar ways to discovering if an SQL injection is possible." ;
        capec:attackStepPhase        "Experiment" .

