capec-res:CAPEC-82  a                 capec:CAPEC ;
        dct:description               "This attack pattern has been deprecated as it a generalization of CAPEC-230: XML Nested Payloads, CAPEC-231: XML Oversized Payloads, and CAPEC-147: XML Ping of Death. Please refer to these CAPECs going forward." ;
        dct:identifier                "82" ;
        dct:title                     "DEPRECATED: Violating Implicit Assumptions Regarding XML Content (aka XML Denial of Service (XDoS))" ;
        capec:abstraction             "Standard" ;
        capec:hasModificationHistory  <http://w3id.org/sepses/resource/capec/modificationHistory/8220190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/8220180731> ;
        capec:hasSubmissionHistory    <http://w3id.org/sepses/resource/capec/submissionHistory/8220140623> ;
        capec:status                  "Deprecated" .

capec-res:CAPEC-621  a                 capec:CAPEC ;
        dct:description                "An attacker may intercept and log encrypted transmissions for the purpose of analyzing metadata such as packet timing and sizes. Although the actual data may be encrypted, this metadata may reveal valuable information to an attacker. Note that this attack is applicable to VOIP data as well as application data, especially for interactive apps that require precise timing and low-latency (e.g. thin-clients)." ;
        dct:identifier                 "621" ;
        dct:title                      "Analysis of Packet Timing and Sizes" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/621135> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/62120180731> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/621ChildOf189> ;
        capec:hasRelatedWeakness       cwe-res:CWE-201 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/62120151109> ;
        capec:mitigation               "Distort packet sizes and timing at VPN layer by adding padding to normalize packet sizes and timing delays to reduce information leakage via timing." ;
        capec:prerequisite             "Use of untrusted communication paths enables an attacker to intercept and log communications, including metadata such as packet timing and sizes." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Low" .

