        capec:referenceUrl              "http://projects.webappsec.org/Insufficient+Anti-automation" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/863>
        a                            capec:AttackStep ;
        capec:attackStep             "3" ;
        capec:attackStepDescription  "[Craft malicious XSS URL] Once the adversary has determined which parameters are vulnerable to XSS, they will craft a malicious URL containing the XSS exploit. The adversary can have many goals, from stealing session IDs, cookies, credentials, and page content from the victim." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Change a URL parameter which is used in an HTTP header to include a malicious script tag. Because it is in the header it may bypass validation." , "Send information gathered from the malicious script to a remote endpoint." .

