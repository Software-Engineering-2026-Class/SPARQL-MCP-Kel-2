<http://w3id.org/sepses/resource/capec/ExecutionFlow/23>
        a                            capec:AttackStep ;
        capec:attackStep             "3" ;
        capec:attackStepDescription  "[Lock Out Accounts] Perform lockout procedure for all accounts that the attacker wants to lock out." ;
        capec:attackStepPhase        "Exploit" ;
        capec:attackStepTechnique    "For each user ID to be locked out, perform the lockout procedure discovered in the first step." .

capec-res:CAPEC-532  a                 capec:CAPEC ;
        dct:description                "An attacker with access to download and update system software sends a maliciously altered BIOS to the victim or victim supplier/integrator, which when installed allows for future exploitation." ;
        dct:identifier                 "532" ;
        dct:title                      "Altered Installed BIOS" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/53220180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/53220210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/53220151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/53220220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/53220200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/53220220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/53220190930> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-439> , <http://w3id.org/sepses/resource/capec/reference/REF-716> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/532ChildOf444> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/53220140623> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Deploy strong code integrity policies to allow only authorized apps to run." , "Use hardware security modules/trusted platform modules to verify authenticity using hardware-based cryptography." , "Maintain a highly secure build and update infrastructure by immediately applying security patches for OS and software, implementing mandatory integrity controls to ensure only trusted tools run, and requiring multi-factor authentication for admins." , "Sign update packages and BIOS patches." , "Use endpoint detection and response solutions that can automaticalkly detect and remediate suspicious activities." , "Require SSL for update channels and implement certificate transparency based verification." ;
        capec:prerequisite             "Access to the download and update system(s) used to deliver BIOS images." , "Advanced knowledge about the installed target system design." , "Advanced knowledge about the download and update installation processes." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "High" .

