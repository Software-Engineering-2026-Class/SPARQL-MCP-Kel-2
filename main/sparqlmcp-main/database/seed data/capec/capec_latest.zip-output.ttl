capec-res:CAPEC-628  a                 capec:CAPEC ;
        dct:description                "A common form of a GPS spoofing attack, commonly termed a carry-off attack begins with an adversary broadcasting signals synchronized with the genuine signals observed by the target receiver. The power of the counterfeit signals is then gradually increased and drawn away from the genuine signals. Over time, the adversary can carry the target away from their intended destination and toward a location chosen by the adversary." ;
        dct:identifier                 "628" ;
        dct:title                      "Carry-Off GPS Attack" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/62820170501> , <http://w3id.org/sepses/resource/capec/modificationHistory/62820180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/62820190404> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-489> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/628ChildOf627> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/62820151109> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:prerequisite             "The target must be relying on valid GPS signal to perform critical operations." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/6921>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Identify target] The adversary must first identify a target repository for them to spoof. Typically, this will be a popular and widely used repository, as to increase the amount of victims a successful attack will exploit." ;
        capec:attackStepPhase        "Explore" .

