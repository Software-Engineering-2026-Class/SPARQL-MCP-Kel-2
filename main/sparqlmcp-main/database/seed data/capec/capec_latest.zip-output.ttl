                capec-res:CAPEC-97 ;
        capec:relatedAttackPatternNature
                "ChildOf" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/2212>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Host malicious file on a server] The adversary will create a web server that contains a malicious file. This file will be extremely large, so that if a web service were to try to load it, the service would most likely hang." , "[Craft malicious data] Using the serialization language that the web service takes as input, the adversary will craft data that links to the malicious file using an external entity reference to the URL of the file." ;
        capec:attackStepPhase        "Experiment" .

capec-res:CAPEC-313  a                 capec:CAPEC ;
        dct:description                "An adversary engages in activity to detect the version or type of OS software in a an environment by passively monitoring communication between devices, nodes, or applications. Passive techniques for operating system detection send no actual probes to a target, but monitor network or client-server communication between nodes in order to identify operating systems based on observed behavior as compared to a database of known signatures or values. While passive OS fingerprinting is not usually as reliable as active methods, it is generally better able to evade detection." ;
        dct:identifier                 "313" ;
        dct:title                      "Passive OS Fingerprinting" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/313134> , <http://w3id.org/sepses/resource/capec/Consequence/31369> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/31320180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/31320170501> , <http://w3id.org/sepses/resource/capec/modificationHistory/31320220929> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-130> , <http://w3id.org/sepses/resource/capec/reference/REF-128> , <http://w3id.org/sepses/resource/capec/reference/REF-33> , <http://w3id.org/sepses/resource/capec/reference/REF-212> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/313ChildOf224> ;
        capec:hasRelatedWeakness       cwe-res:CWE-200 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/31320140623> ;
        capec:likelihoodOfAttack       "High" ;
        capec:prerequisite             "The ability to monitor network communications.Access to at least one host, and the privileges to interface with the network interface card." ;
        capec:resourceRequired         "Any tool capable of monitoring network communications, like a packet sniffer (e.g., Wireshark)" ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "Low" .

