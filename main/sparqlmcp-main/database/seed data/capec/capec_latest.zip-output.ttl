capec-res:CAPEC-134  a                 capec:CAPEC ;
        dct:description                "An adversary manipulates the headers and content of an email message by injecting data via the use of delimiter characters native to the protocol." ;
        dct:identifier                 "134" ;
        dct:title                      "Email Injection" ;
        capec:abstraction              "Standard" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/13420201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/13420220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/13420190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/13420190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/13420170804> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/134ChildOf137> ;
        capec:hasRelatedWeakness       cwe-res:CWE-150 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/13420140623> ;
        capec:prerequisite             "The target application must allow the user to send email to some recipient, to specify the content at least one header field in the message, and must fail to sanitize against the injection of command separators." , "The adversary must have the ability to access the target mail application." ;
        capec:resourceRequired         "None: No specialized resources are required to execute this type of attack." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

