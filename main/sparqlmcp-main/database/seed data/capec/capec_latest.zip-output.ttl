capec-res:CAPEC-598  a                 capec:CAPEC ;
        dct:description                "An adversary sends a malicious (\"NXDOMAIN\" (\"No such domain\") code, or DNS A record) response to a target's route request before a legitimate resolver can. This technique requires an On-path or In-path device that can monitor and respond to the target's DNS requests. This attack differs from BGP Tampering in that it directly responds to requests made by the target instead of polluting the routing the target's infrastructure uses." ;
        dct:identifier                 "598" ;
        dct:title                      "DNS Spoofing" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/59820220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/59820230124> , <http://w3id.org/sepses/resource/capec/modificationHistory/59820190404> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-479> , <http://w3id.org/sepses/resource/capec/reference/REF-477> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/598ChildOf194> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/59820170104> ;
        capec:mitigation               "Implementation: DNSSEC" , "Implementation: Utilize a .onion domain with Tor support" , "Design: Include \"hosts file\"/IP address in the application" , "Design: Avoid dependence on DNS" , "Implementation: DNS-hold-open" ;
        capec:prerequisite             "On/In Path Device" ;
        capec:status                   "Draft" .

