capec-res:CAPEC-649  a                 capec:CAPEC ;
        dct:description                "An adversary adds a space character to the end of a file extension and takes advantage of an application that does not properly neutralize trailing special elements in file names. This extra space, which can be difficult for a user to notice, affects which default application is used to operate on the file and can be leveraged by the adversary to control execution." ;
        dct:identifier                 "649" ;
        dct:title                      "Adding a Space to a File Extension" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/649142> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/64920200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/64920190404> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/649ChildOf635> ;
        capec:hasRelatedWeakness       cwe-res:CWE-46 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/64920180531> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "File extensions should be checked to see if non-visible characters are being included." ;
        capec:prerequisite             "The use of the file must be controlled by the file extension." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

