capec-res:CAPEC-695  a                 capec:CAPEC ;
        dct:description                "\n            An adversary takes advantage of the redirect property of directly linked Version Control System (VCS) repositories to trick users into incorporating malicious code into their applications.\n         " ;
        dct:identifier                 "695" ;
        dct:title                      "Repo Jacking" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/69590> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6951> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6953> , <http://w3id.org/sepses/resource/capec/Consequence/695185> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6952> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/69520230124> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-722> , <http://w3id.org/sepses/resource/capec/reference/REF-733> , <http://w3id.org/sepses/resource/capec/reference/REF-734> , <http://w3id.org/sepses/resource/capec/reference/REF-732> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/695ChildOf616> ;
        capec:hasRelatedWeakness       cwe-res:CWE-829 , cwe-res:CWE-494 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/69520220929> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Implement \"vendoring\" (i.e., including third-party dependencies locally) and leverage automated testing techniques (e.g., static analysis) to determine if the software behaves maliciously." , "Leverage automated tools, such as Checkmarx's \"ChainJacking\" tool, to determine susceptibility to Repo Jacking attacks." , "Utilize version pinning and lock files to prevent use of maliciously modified repositories." , "Leverage dedicated package managers instead of directly linking to VCS repositories." ;
        capec:prerequisite             "A repository owner/maintainer who has recently changed their username or deleted their account" , "Identification of a popular repository that may be directly referenced in numerous software applications" ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "High" .

