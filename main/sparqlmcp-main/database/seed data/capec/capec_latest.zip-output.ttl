        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Gain access to XML schema] The adversary gains access to the XML schema so that they can modify the contents." ;
        capec:attackStepPhase        "Experiment" ;
