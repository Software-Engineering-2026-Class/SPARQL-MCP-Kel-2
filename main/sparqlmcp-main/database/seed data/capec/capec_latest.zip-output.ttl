<http://w3id.org/sepses/resource/capec/ExecutionFlow/5973>
        a                            capec:AttackStep ;
        capec:attackStep             "3" ;
        capec:attackStepDescription  "[Attempt variations on input parameters] Using manual or automated means, an adversary attempts varying absolute file paths on all found user input locations and observes the responses." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Access a specific drive letter or windows volume letter by specifying \"C:dirname\" for example" , "Access common files in root directories such as \"/bin\", \"/boot\", \"/lib\", or \"/home\"" , "Access a known Windows UNC share by specifying \"\\\\UNC\\share\\name\" for example" .

