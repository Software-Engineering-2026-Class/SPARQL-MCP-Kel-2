        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/61020190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/61020170804> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/610ChildOf240> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/61020151109> ;
        capec:mitigation               "Commercial defensive technology to detect and alert to any attempts to modify mobile technology data flows or to inject new data into existing data flows and signaling data." ;
        capec:prerequisite             "None" ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "High" .

