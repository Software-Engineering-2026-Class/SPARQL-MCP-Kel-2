<http://w3id.org/sepses/resource/capec/ExecutionFlow/6614>
        a                            capec:AttackStep ;
        capec:attackStep             "4" ;
        capec:attackStepDescription  "[Execute the application and evade Root/Jailbreak detection methods] The application executes with the self-signed certificate, while believing it contains a trusted certificate. This now allows the adversary to evade Root/Jailbreak detection via code hooking or other methods." ;
        capec:attackStepPhase        "Exploit" ;
        capec:attackStepTechnique    "Optional: Hook code into the target application." .

