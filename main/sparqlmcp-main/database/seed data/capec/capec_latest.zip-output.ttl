<http://w3id.org/sepses/resource/capec/ExecutionFlow/2042>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Attempt to Access Cache] Once the cache has been discovered, the adversary attempts to access the cached data. This often requires previous access to a machine hosting the target application." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Use priviledge escalation to access cache files that might have strict privileges." , "If the application cache is encrypted with weak encryption, attempt to understand the encryption technique and break the encryption." .

capec-res:CAPEC-143  a                 capec:CAPEC ;
        dct:description                "An adversary searches a targeted web site for web pages that have not been publicized. In doing this, the adversary may be able to gain access to information that the targeted site did not intend to make public." ;
        dct:identifier                 "143" ;
        dct:title                      "Detect Unpublicized Web Pages" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/1434> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1433> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1432> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1431> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/14320200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/14320211021> , <http://w3id.org/sepses/resource/capec/modificationHistory/14320190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/14320151207> , <http://w3id.org/sepses/resource/capec/modificationHistory/14320230124> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/143ChildOf150> ;
        capec:hasRelatedWeakness       cwe-res:CWE-425 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/14320140623> ;
        capec:prerequisite             "The targeted web site must include pages within its published tree that are not connected to its tree of links. The sensitivity of the content of these pages determines the severity of this attack." ;
        capec:resourceRequired         "Spidering tools to explore the target web site are extremely useful in this attack especially when attacking large sites. Some tools might also be able to automatically construct common page locations from known paths." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Low" .

