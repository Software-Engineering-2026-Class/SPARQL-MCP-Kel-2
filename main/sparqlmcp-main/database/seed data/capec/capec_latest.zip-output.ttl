capec-res:CAPEC-132  a                 capec:CAPEC ;
        dct:description                "An adversary positions a symbolic link in such a manner that the targeted user or application accesses the link's endpoint, assuming that it is accessing a file with the link's name." ;
        dct:identifier                 "132" ;
        dct:title                      "Symlink Attack" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/132164> , <http://w3id.org/sepses/resource/capec/Consequence/132100> , <http://w3id.org/sepses/resource/capec/Consequence/132115> , <http://w3id.org/sepses/resource/capec/Consequence/132121> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1323> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1322> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1321> , <http://w3id.org/sepses/resource/capec/Consequence/13265> , <http://w3id.org/sepses/resource/capec/Consequence/13269> , <http://w3id.org/sepses/resource/capec/Consequence/13277> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/13220170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/13220151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/13220200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/13220220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/13220220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/13220190404> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-13> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/132ChildOf159> ;
        capec:hasRelatedWeakness       cwe-res:CWE-59 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/13220140623> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Design: Check for the existence of files to be created, if in existence verify they are neither symlinks nor hard links before opening them." , "Implementation: Use randomly generated file names for temporary files. Give the files restrictive permissions." ;
        capec:prerequisite             "The targeted application must perform the desired activities on a file without checking whether the file is a symbolic link or not. The adversary must be able to predict the name of the file the target application is modifying and be able to create a new symbolic link where that file would appear." ;
        capec:resourceRequired         "None: No specialized resources are required to execute this type of attack. The only requirement is the ability to create the necessary symbolic link." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

