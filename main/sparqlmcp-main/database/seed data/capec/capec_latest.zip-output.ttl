<http://w3id.org/sepses/resource/capec/ExecutionFlow/4612>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Attempt adding padding to parameters] An adversary tests if they can simply add padding to the parameters of a request such that the request is technically changed, with the hash remaining the same" ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Exploit the hash function extension / padding weakness with only padding to test the weakness" .

