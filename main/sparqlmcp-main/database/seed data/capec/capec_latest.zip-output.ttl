capec-res:CAPEC-452  a                 capec:CAPEC ;
        dct:description                "An adversary inserts malicious logic into hardware, typically in the form of a computer virus or rootkit. This logic is often hidden from the user of the hardware and works behind the scenes to achieve negative impacts. This pattern of attack focuses on hardware already fielded and used in operation as opposed to hardware that is still under development and part of the supply chain." ;
        dct:identifier                 "452" ;
        dct:title                      "Infected Hardware" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/45287> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/45220230124> , <http://w3id.org/sepses/resource/capec/modificationHistory/45220190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/45220210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/45220180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/45220190404> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/452ChildOf441> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/45220140623> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:prerequisite             "Access to the hardware currently deployed at a victim location." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "High" .

