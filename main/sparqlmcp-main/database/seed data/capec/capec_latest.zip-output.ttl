capec-res:CAPEC-584  a                 capec:CAPEC ;
        dct:description                "An adversary suppresses the Border Gateway Protocol (BGP) advertisement for a route so as to render the underlying network inaccessible. The BGP protocol helps traffic move throughout the Internet by selecting the most efficient route between Autonomous Systems (AS), or routing domains. BGP is the basis for interdomain routing infrastructure, providing connections between these ASs. By suppressing the intended AS routing advertisements and/or forcing less effective routes for traffic to ASs, the adversary can deny availability for the target network." ;
        dct:identifier                 "584" ;
        dct:title                      "BGP Route Disabling" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/584174> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/58420201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/58420190930> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-466> , <http://w3id.org/sepses/resource/capec/reference/REF-465> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/584ChildOf582> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/58420170112> ;
        capec:mitigation               "Implement Secure BGP (S-BGP protocol), which improves authorization and authentication capabilities based on public-key cryptography." , "Implement Ingress filters to check the validity of received routes. However, this relies on the accuracy of Internet Routing Registries (IRRs) databases which are often not well-maintained." ;
        capec:prerequisite             "The adversary must have control of a router that can modify, drop, or introduce spoofed BGP updates.The adversary can convince" ;
        capec:resourceRequired         "BGP Router" ;
        capec:status                   "Draft" .

