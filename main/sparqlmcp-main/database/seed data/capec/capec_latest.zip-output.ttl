capec-res:CAPEC-667  a                 capec:CAPEC ;
        dct:description                "An adversary disguises the MAC address of their Bluetooth enabled device to one for which there exists an active and trusted connection and authenticates successfully. The adversary can then perform malicious actions on the target Bluetooth device depending on the target’s capabilities." ;
        dct:identifier                 "667" ;
        dct:title                      "Bluetooth Impersonation AttackS (BIAS)" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/6673> , <http://w3id.org/sepses/resource/capec/Consequence/667229> , <http://w3id.org/sepses/resource/capec/Consequence/667118> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6672> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6671> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/66720220929> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/667ChildOf616> ;
        capec:hasRelatedWeakness       cwe-res:CWE-290 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/66720210624> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Change default PIN passwords and always use one when connecting." , "Disable Bluetooth in public places." , "Verify incoming Bluetooth connections; do not automatically trust." ;
        capec:prerequisite             "Knowledge of a target device's list of trusted connections." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

