<http://w3id.org/sepses/resource/capec/ExecutionFlow/273>
        a                            capec:AttackStep ;
        capec:attackStep             "3" ;
        capec:attackStepDescription  "[Verify ability to write to filesystem] The attacker verifies ability to write to the target host's file system." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "On platforms that differentiate between file creation and file modification, if the target file that the application writes to already exists, attempt to modify it." , "Create a file that does not exist in the target directory (e.g. \"touch temp.txt\" in UNIX-like systems)" , "Verify permissions on target directory" .

capec-res:CAPEC-595  a                 capec:CAPEC ;
        dct:description                "In this attack pattern, an adversary injects a connection reset packet to one or both ends of a target's connection. The attacker is therefore able to have the target and/or the destination server sever the connection without having to directly filter the traffic between them." ;
        dct:identifier                 "595" ;
        dct:title                      "Connection Reset" ;
        capec:abstraction              "Standard" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/59520190404> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/595ChildOf594> ;
        capec:hasRelatedWeakness       cwe-res:CWE-940 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/59520170104> ;
        capec:prerequisite             "This attack requires the ability to monitor the target's network connection." ;
        capec:status                   "Draft" .

