capec-res:CAPEC-674  a                 capec:CAPEC ;
        dct:description                "\n            An adversary alters the functionality of a field-programmable gate array (FPGA) by causing an FPGA configuration memory chip reload in order to introduce a malicious function that could result in the FPGA performing or enabling malicious functions on a host system. Prior to the memory chip reload, the adversary alters the program for the FPGA by adding a function to impact system operation.\n         " ;
        dct:identifier                 "674" ;
        dct:title                      "Design for FPGA Maliciously Altered" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/67475> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/67420220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/67420220929> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-439> , <http://w3id.org/sepses/resource/capec/reference/REF-660> , <http://w3id.org/sepses/resource/capec/reference/REF-662> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/674ChildOf447> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/67420210624> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Conduct detailed vendor assessment before acquiring COTS hardware." , "Utilize DMEA’s (Defense Microelectronics Activity) Trusted Foundry Program members for acquisition of microelectronic components." , "Require that provenance of COTS microelectronic components be known whenever procured." , "Ensure that each supplier performing hardware development implements comprehensive, security-focused configuration management including for FPGA programming and program uploads to FPGA chips." ;
        capec:prerequisite             "An adversary would need to have access to FPGA programming/configuration-related systems in a chip maker’s development environment where FPGAs can be initially configured prior to delivery to a customer or have access to such systems in a customer facility where end-user FPGA configuration/reconfiguration can be performed." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "High" .

