capec-res:CAPEC-648  a                 capec:CAPEC ;
        dct:description                "An adversary gathers sensitive information by exploiting the system's screen capture functionality. Through screenshots, the adversary aims to see what happens on the screen over the course of an operation. The adversary can leverage information gathered in order to carry out further attacks." ;
        dct:identifier                 "648" ;
        dct:title                      "Collect Data from Screen Capture" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/648195> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/64820220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/64820190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/64820200730> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/648ChildOf150> ;
        capec:hasRelatedWeakness       cwe-res:CWE-267 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/64820180731> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "While screen capture is a legitimate and practical function, certain situations and context may require the disabling of this feature." , "Identify potentially malicious software that may have functionality to acquire screen captures, and audit and/or block it by using allowlist tools." ;
        capec:prerequisite             "The adversary must have obtained logical access to the system by some means (e.g., via obtained credentials or planting malware on the system)." ;
        capec:resourceRequired         "None: No specialized resources are required to execute this type of attack." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

<http://w3id.org/sepses/resource/capec/modificationHistory/6520200730>
        a                               capec:ModificationHistory ;
        capec:modificationComment       "Updated Prerequisites" ;
        capec:modificationDate          "2020-07-30" ;
        capec:modificationName          "CAPEC Content Team" ;
        capec:modificationOrganization  "The MITRE Corporation" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/6941>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[System Locale Information Discovery] The adversary examines system information from various sources such as registry and native API functions and correlates the gathered information to infer the geographical location of the target system" ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "Native API Requests: Parse the outputs of Windows API functions GetTimeZoneInformation, GetUserDefaultUILanguage, GetSystemDefaultUILanguage, GetKeyboardLayoutList and GetUserDefaultLangID to obtain information about languages, keyboard layouts, and timezones installed on the system or on macOS or Linux systems, query locale to obtain the $LANG environment variable and view keyboard layout information or use timeanddatectl status to show the system clock settings." , "Registry Query: Query the registry key HKEY_LOCAL_MACHINE\\SYSTEM\\CurrentControlSet\\Control\\ContentIndex\\Language\\Language_Dialect on Windows to obtain system language, Computer\\HKEY_CURRENT_USER\\Keyboard Layout\\Preload to obtain the hexadecimal language IDs of the current user's preloaded keyboard layouts, and Computer\\HKEY_LOCAL_MACHINE\\SYSTEM\\CurrentControlSet\\Control\\TimeZoneInformation to obtain the system timezone configuration" , "Read Configuration Files: For macOS and Linux-based systems, view the /etc/vconsole.conf file to get information about the keyboard mapping and console font." .

<http://w3id.org/sepses/resource/capec/skillRequired/22292>
        a                        capec:SkillRequired ;
        capec:isSkillRequiredOf  capec-res:CAPEC-222 ;
        capec:skillDescription   "Crafting the proper malicious site and luring the victim to this site is not a trivial task." ;
        capec:skillLevel         "High" .

<http://w3id.org/sepses/resource/capec/skillRequired/174226>
        a                        capec:SkillRequired ;
        capec:isSkillRequiredOf  capec-res:CAPEC-174 ;
        capec:skillDescription   "The adversary need inject values into the global parameters to the Flash file and understand the parent HTML document DOM structure. The adversary needs to be smart enough to convince the victim to click on their crafted link." ;
        capec:skillLevel         "Medium" .

