<http://w3id.org/sepses/resource/capec/ExecutionFlow/6981>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Identify target(s)] The adversary must first identify target software that allows for extensions/plugins and which they wish to exploit, such as a web browser or desktop application. To increase the attack space, this will often be popular software with a large user-base." ;
        capec:attackStepPhase        "Explore" .

