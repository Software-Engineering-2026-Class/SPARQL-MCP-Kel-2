capec-res:CAPEC-181  a                 capec:CAPEC ;
        dct:description                "An attacker creates a transparent overlay using flash in order to intercept user actions for the purpose of performing a clickjacking attack. In this technique, the Flash file provides a transparent overlay over HTML content. Because the Flash application is on top of the content, user actions, such as clicks, are caught by the Flash application rather than the underlying HTML. The action is then interpreted by the overlay to perform the actions the attacker wishes." ;
        dct:identifier                 "181" ;
        dct:title                      "Flash File Overlay" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/18120190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/18120190404> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/181ChildOf103> ;
        capec:hasRelatedWeakness       cwe-res:CWE-1021 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/18120140623> ;
        capec:prerequisite             "The victim's browser must support invisible Flash overlays." , "The victim must be tricked into navigating to the attackers' decoy site and performing the actions on the decoy page." ;
        capec:resourceRequired         "The attacker must be able to force the Flash overlay over the decoy content." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

