<http://w3id.org/sepses/resource/capec/ExecutionFlow/2072>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Determine which functionality to disable or remove] The adversary tries to determine which functionality to disable or remove through reverse-engineering from the list of functionality identified in the Explore phase." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "The adversary reverse engineers the client-side code to determine which functionality to disable or remove." .

<http://w3id.org/sepses/resource/capec/submissionHistory/42520140623>
        a                             capec:SubmissionHistory ;
