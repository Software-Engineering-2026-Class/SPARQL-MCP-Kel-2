capec-res:CAPEC-678  a                 capec:CAPEC ;
        dct:description                "\n            During the system build process, the system is deliberately misconfigured by the alteration of the build data. Access to system configuration data files and build processes is susceptible to deliberate misconfiguration of the system.\n         " ;
        dct:identifier                 "678" ;
        dct:title                      "System Build Data Maliciously Altered" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/67874> , <http://w3id.org/sepses/resource/capec/Consequence/67883> , <http://w3id.org/sepses/resource/capec/Consequence/67896> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/67820230124> , <http://w3id.org/sepses/resource/capec/modificationHistory/67820220929> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-439> , <http://w3id.org/sepses/resource/capec/reference/REF-660> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/678ChildOf444> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/67820211021> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Harden centralized repositories against attack." , "Maintain configuration control over operational systems." , "Implement configuration management security practices that protect the integrity of software and associated data." , "Establish acceptance criteria for configuration management check-in to assure integrity." , "Monitor and control access to the configuration management system." , "Plan for and audit the security of configuration management administration processes." ;
        capec:prerequisite             "An adversary has access to the data files and processes used for executing system configuration and performing the build." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/6971>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Determine Exsisting DHCP lease] An adversary observes network traffic and waits for an existing DHCP lease to expire on a target machine in the LAN." ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "Adversary observes LAN traffic for DHCP solicitations" .

