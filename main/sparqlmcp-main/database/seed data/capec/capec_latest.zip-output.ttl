capec-res:CAPEC-555  a                 capec:CAPEC ;
        dct:description                "This pattern of attack involves an adversary that uses stolen credentials to leverage remote services such as RDP, telnet, SSH, and VNC to log into a system. Once access is gained, any number of malicious activities could be performed." ;
        dct:identifier                 "555" ;
        dct:title                      "Remote Services with Stolen Credentials" ;
        capec:abstraction              "Standard" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/55520180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/55520220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/55520200730> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/555ChildOf560> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/555CanPrecede151> ;
        capec:hasRelatedWeakness       cwe-res:CWE-308 , cwe-res:CWE-521 , cwe-res:CWE-522 , cwe-res:CWE-309 , cwe-res:CWE-294 , cwe-res:CWE-262 , cwe-res:CWE-263 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/55520151109> ;
        capec:mitigation               "Disable RDP, telnet, SSH and enable firewall rules to block such traffic. Limit users and accounts that have remote interactive login access. Remove the Local Administrators group from the list of groups allowed to login through RDP. Limit remote user permissions. Use remote desktop gateways and multifactor authentication for remote logins." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "Very High" .

