        capec:submissionOrganization  "The MITRE Corporation" .

capec-res:CAPEC-173  a                capec:CAPEC ;
        dct:description               "An adversary is able to disguise one action for another and therefore trick a user into initiating one type of action when they intend to initiate a different action. For example, a user might be led to believe that clicking a button will submit a query, but in fact it downloads software. Adversaries may perform this attack through social means, such as by simply convincing a victim to perform the action or relying on a user's natural inclination to do so, or through technical means, such as a clickjacking attack where a user sees one interface but is actually interacting with a second, invisible, interface." ;
        dct:identifier                "173" ;
        dct:title                     "Action Spoofing" ;
        capec:abstraction             "Meta" ;
        capec:hasConsequence          <http://w3id.org/sepses/resource/capec/Consequence/173258> ;
        capec:hasModificationHistory  <http://w3id.org/sepses/resource/capec/modificationHistory/17320170501> , <http://w3id.org/sepses/resource/capec/modificationHistory/17320201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/17320230124> ;
        capec:hasRelatedWeakness      cwe-res:CWE-451 ;
        capec:hasSubmissionHistory    <http://w3id.org/sepses/resource/capec/submissionHistory/17320140623> ;
        capec:likelihoodOfAttack      "High" ;
        capec:mitigation              "An organization should provide regular, robust cybersecurity training to its employees." , "Avoid interacting with suspicious sites or clicking suspicious links." ;
        capec:prerequisite            "The adversary must have the means to control a user's interface to present them with a decoy action as well as the actual malicious action. Simple versions of this attack can be performed using web pages requiring only that the adversary be able to host (or control) content that the user visits." , "The adversary must convince the victim into performing the decoy action." ;
        capec:status                  "Stable" ;
        capec:typicalSeverity         "Very High" .

