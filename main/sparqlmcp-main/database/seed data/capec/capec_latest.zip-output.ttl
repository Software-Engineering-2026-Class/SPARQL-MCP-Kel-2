        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "An adversary uses the response from the target to determine the port's state. If a RST packet is received the target port is either closed or the ACK was sent out-of-sync. If no response is received, the target is likely using a stateful firewall." ;
