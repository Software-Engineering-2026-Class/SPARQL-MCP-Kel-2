<http://w3id.org/sepses/resource/capec/ExecutionFlow/1391>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Fingerprinting of the operating system] In order to perform a valid path traversal, the adversary needs to know what the underlying OS is so that the proper file seperator is used." ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "TCP/IP Fingerprinting. The adversary uses various software to make connections or partial connections and observe idiosyncratic responses from the operating system. Using those responses, they attempt to guess the actual operating system." , "Port mapping. Identify ports that the system is listening on, and attempt to identify inputs and protocol types on those ports." , "Induce errors to find informative error messages" .

capec-res:CAPEC-586  a                capec:CAPEC ;
        dct:description               "An adversary attempts to exploit an application by injecting additional, malicious content during its processing of serialized objects. Developers leverage serialization in order to convert data or state into a static, binary format for saving to disk or transferring over a network. These objects are then deserialized when needed to recover the data/state. By injecting a malformed object into a vulnerable application, an adversary can potentially compromise the application by manipulating the deserialization process. This can result in a number of unwanted outcomes, including remote code execution." ;
        dct:identifier                "586" ;
        dct:title                     "Object Injection" ;
        capec:abstraction             "Meta" ;
        capec:hasConsequence          <http://w3id.org/sepses/resource/capec/Consequence/586248> , <http://w3id.org/sepses/resource/capec/Consequence/586164> , <http://w3id.org/sepses/resource/capec/Consequence/586192> ;
        capec:hasModificationHistory  <http://w3id.org/sepses/resource/capec/modificationHistory/58620201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/58620200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/58620180731> ;
        capec:hasReference            <http://w3id.org/sepses/resource/capec/reference/REF-468> ;
        capec:hasRelatedWeakness      cwe-res:CWE-502 ;
        capec:hasSubmissionHistory    <http://w3id.org/sepses/resource/capec/submissionHistory/58620170206> ;
        capec:likelihoodOfAttack      "Medium" ;
        capec:mitigation              "\n               Implementation: Validate object before deserialization process\n            " , "\n               Implementation: Avoid having unnecessary types or gadgets available that can be leveraged for malicious ends. Use an allowlist of acceptable classes.\n            " , "\n               Implementation: Keep session state on the server, when possible.\n            " , "\n               Design: Limit which types can be deserialized.\n            " ;
        capec:prerequisite            "The target application must unserialize data before validation." ;
        capec:status                  "Draft" ;
        capec:typicalSeverity         "High" .

