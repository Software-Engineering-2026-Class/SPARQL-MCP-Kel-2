capec-res:CAPEC-230  a                 capec:CAPEC ;
        dct:description                "Applications often need to transform data in and out of a data format (e.g., XML and YAML) by using a parser. It may be possible for an adversary to inject data that may have an adverse effect on the parser when it is being processed. Many data format languages allow the definition of macro-like structures that can be used to simplify the creation of complex structures. By nesting these structures, causing the data to be repeatedly substituted, an adversary can cause the parser to consume more resources while processing, causing excessive memory consumption and CPU utilization." ;
        dct:identifier                 "230" ;
        dct:title                      "Serialized Data with Nested Payloads" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/230142> , <http://w3id.org/sepses/resource/capec/Consequence/230134> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2302> , <http://w3id.org/sepses/resource/capec/Consequence/23077> , <http://w3id.org/sepses/resource/capec/Consequence/23069> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2301> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/23020211021> , <http://w3id.org/sepses/resource/capec/modificationHistory/23020200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/23020210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/23020190930> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-89> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/230ChildOf130> ;
        capec:hasRelatedWeakness       cwe-res:CWE-674 , cwe-res:CWE-770 , cwe-res:CWE-20 , cwe-res:CWE-112 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/23020140623> ;
        capec:indicator                "Bad data is passed to the data parser (possibly repeatedly), possibly making it crash or execute arbitrary code." ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Perform validation on canonical data." , "Pick a robust implementation of the data parser." , "Carefully validate and sanitize all user-controllable data prior to passing it to the data parser routine. Ensure that the resultant data is safe to pass to the data parser." ;
        capec:prerequisite             "An application does not perform sufficient validation to ensure that user-controllable data is not malicious." , "An application's user-controllable data is expressed in a language that supports subsitution." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

