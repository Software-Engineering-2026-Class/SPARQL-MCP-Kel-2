<http://w3id.org/sepses/resource/capec/ExecutionFlow/1472>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Launch a resource depletion attack] The attacker delivers a large number of small XML messages to the target URLs found in the explore phase at a sufficiently rapid rate. It causes denial of service to the target application." ;
        capec:attackStepPhase        "Exploit" ;
        capec:attackStepTechnique    "Send a large number of crafted small XML messages to the target URL." .

