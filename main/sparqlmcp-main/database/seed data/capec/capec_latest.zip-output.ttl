capec-res:CAPEC-497  a                 capec:CAPEC ;
        dct:description                "An adversary engages in probing and exploration activities to determine if common key files exists. Such files often contain configuration and security parameters of the targeted application, system or network. Using this knowledge may often pave the way for more damaging attacks." ;
        dct:identifier                 "497" ;
        dct:title                      "File Discovery" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/49769> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/49720200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/49720201217> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/497ChildOf169> ;
        capec:hasRelatedWeakness       cwe-res:CWE-200 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/49720190930> ;
        capec:likelihoodOfAttack       "High" ;
        capec:mitigation               "Leverage file protection mechanisms to render these files accessible only to authorized parties." ;
        capec:prerequisite             "The adversary must know the location of these common key files." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Very Low" .

