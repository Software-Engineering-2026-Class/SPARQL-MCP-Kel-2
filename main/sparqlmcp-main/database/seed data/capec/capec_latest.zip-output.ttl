<http://w3id.org/sepses/resource/capec/ExecutionFlow/432>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Determine which character encodings are accepted by the application/system] The attacker then needs to provide various character encodings to the application/system and determine which ones are accepted. The attacker will need to observe the application's/system's response to the encoded data to determine whether the data was interpreted properly." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Determine whether UTF-8 encoding is accepted by the application/system." , "Determine whether URL encoding is accepted by the application/system." , "Determine if any other encodings are accepted by the application/system." , "Determine whether UTF-16 encoding is accepted by the application/system." , "Determine which escape characters are accepted by the application/system. A common escape character is the backslash character, '\\'" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/242>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Attempt injections] Try to feed overly long data to the system. This can be done manually or a dynamic tool (black box) can be used to automate this. An attacker can also use a custom script for that purpose." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Fuzzing of communications protocols" , "Brute force attack through black box penetration test tool." , "Manual testing of possible inputs with attack data." .

capec-res:CAPEC-564  a                 capec:CAPEC ;
        dct:description                "Operating system allows logon scripts to be run whenever a specific user or users logon to a system. If adversaries can access these scripts, they may insert additional code into the logon script. This code can allow them to maintain persistence or move laterally within an enclave because it is executed every time the affected user or users logon to a computer. Modifying logon scripts can effectively bypass workstation and enclave firewalls. Depending on the access configuration of the logon scripts, either local credentials or a remote administrative account may be necessary." ;
        dct:identifier                 "564" ;
        dct:title                      "Run Software at Logon" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/56420201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/56420180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/56420210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/56420190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/56420200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/56420220929> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/564ChildOf542> ;
        capec:hasRelatedWeakness       cwe-res:CWE-284 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/56420151109> ;
        capec:mitigation               "Restrict write access to logon scripts to necessary administrators." ;
        capec:status                   "Draft" .

