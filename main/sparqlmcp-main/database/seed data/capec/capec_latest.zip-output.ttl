<http://w3id.org/sepses/resource/capec/ExecutionFlow/1822>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Determine the application's susceptibility to Flash injection] Determine the application's susceptibility to Flash injection. For each URL identified in the explore phase, the attacker attempts to use various techniques such as direct load asfunction, controlled evil page/host, Flash HTML injection, and DOM injection to determine whether the application is susceptible to Flash injection." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Test the page using Flash HTML injection, \"'><img src='asfunction:getURL,javascript:gotRoot(\"\")//.jpg' >" , "Test the page using controlled evil page/host, http://example.com/evil.swf" , "Test the page using direct load asfunction, getURL,javascript:gotRoot(\"\")///d.jpg" , "Test the page using DOM injection, (gotRoot(''))" .

