capec-res:CAPEC-153  a                capec:CAPEC ;
        dct:description               "An attacker exploits a weakness in input validation by controlling the format, structure, and composition of data to an input-processing interface. By supplying input of a non-standard or unexpected form an attacker can adversely impact the security of the target." ;
        dct:identifier                "153" ;
        dct:title                     "Input Data Manipulation" ;
        capec:abstraction             "Meta" ;
        capec:hasModificationHistory  <http://w3id.org/sepses/resource/capec/modificationHistory/15320170109> , <http://w3id.org/sepses/resource/capec/modificationHistory/15320170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/15320220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/15320190404> ;
        capec:hasRelatedWeakness      cwe-res:CWE-20 ;
        capec:hasSubmissionHistory    <http://w3id.org/sepses/resource/capec/submissionHistory/15320140623> ;
        capec:prerequisite            "The target must accept user data for processing and the manner in which this data is processed must depend on some aspect of the format or flags that the attacker can control." ;
        capec:resourceRequired        "None: No specialized resources are required to execute this type of attack." ;
        capec:status                  "Draft" ;
        capec:typicalSeverity         "Medium" .

