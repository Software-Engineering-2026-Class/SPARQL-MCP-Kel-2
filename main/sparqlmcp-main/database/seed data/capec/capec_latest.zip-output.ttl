<http://w3id.org/sepses/resource/capec/submissionHistory/1220140623>
        a                             capec:SubmissionHistory ;
        capec:submissionDate          "2014-06-23" ;
        capec:submissionName          "CAPEC Content Team" ;
        capec:submissionOrganization  "The MITRE Corporation" .

capec-res:CAPEC-196  a                 capec:CAPEC ;
        dct:description                "An attacker creates a false but functional session credential in order to gain or usurp access to a service. Session credentials allow users to identify themselves to a service after an initial authentication without needing to resend the authentication information (usually a username and password) with every message. If an attacker is able to forge valid session credentials they may be able to bypass authentication or piggy-back off some other authenticated user's session. This attack differs from Reuse of Session IDs and Session Sidejacking attacks in that in the latter attacks an attacker uses a previous or existing credential without modification while, in a forging attack, the attacker must create their own credential, although it may be based on previously observed credentials." ;
        dct:identifier                 "196" ;
        dct:title                      "Session Credential Falsification through Forging" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/196164> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1962> , <http://w3id.org/sepses/resource/capec/Consequence/19669> , <http://w3id.org/sepses/resource/capec/Consequence/19665> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1963> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1961> , <http://w3id.org/sepses/resource/capec/Consequence/196121> , <http://w3id.org/sepses/resource/capec/Consequence/196115> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/19620190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/19620180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/19620200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/19620220929> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-62> , <http://w3id.org/sepses/resource/capec/reference/REF-63> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/196CanPrecede384> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/196ChildOf21> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/196CanPrecede61> ;
        capec:hasRelatedWeakness       cwe-res:CWE-664 , cwe-res:CWE-384 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/19620140623> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Implementation: Regenerate and destroy session identifiers when there is a change in the level of privilege: This ensures that even though a potential victim may have followed a link with a fixated identifier, a new one is issued when the level of privilege changes." , "Implementation: Use session IDs that are difficult to guess or brute-force: One way for the attackers to obtain valid session IDs is by brute-forcing or guessing them. By choosing session identifiers that are sufficiently random, brute-forcing or guessing becomes very difficult." ;
        capec:prerequisite             "The targeted application must use session credentials to identify legitimate users. Session identifiers that remains unchanged when the privilege levels change. Predictable session identifiers." ;
        capec:resourceRequired         "Attackers may require tools to craft messages containing their forged credentials, and ability to send HTTP request to a web application." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

