capec-res:CAPEC-191  a                 capec:CAPEC ;
        dct:description                "\n            An adversary engages in activities to discover any sensitive constants present within the compiled code of an executable. These constants may include literal ASCII strings within the file itself, or possibly strings hard-coded into particular routines that can be revealed by code refactoring methods including static and dynamic analysis.\n         " ;
        dct:identifier                 "191" ;
        dct:title                      "Read Sensitive Constants Within an Executable" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/19120200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/19120170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/19120220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/19120190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/19120151109> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-52> , <http://w3id.org/sepses/resource/capec/reference/REF-51> , <http://w3id.org/sepses/resource/capec/reference/REF-53> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/191ChildOf167> ;
        capec:hasRelatedWeakness       cwe-res:CWE-798 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/19120140623> ;
        capec:prerequisite             "Access to a binary or executable such that it can be analyzed by various utilities." ;
        capec:resourceRequired         "Binary analysis programs such as 'strings' or 'grep', or hex editors." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Low" .

<http://w3id.org/sepses/resource/capec/skillRequired/676188>
        a                        capec:SkillRequired ;
        capec:isSkillRequiredOf  capec-res:CAPEC-676 ;
        capec:skillDescription   "For keyword and JavaScript injection attacks, it is fairly simple for someone with basic NoSQL knowledge to perform NoSQL injection, once the target's technology stack has been determined." ;
        capec:skillLevel         "Low" .

