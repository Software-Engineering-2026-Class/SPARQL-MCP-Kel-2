capec-res:CAPEC-242  a                capec:CAPEC ;
        dct:description               "An adversary exploits a weakness in input validation on the target to inject new code into that which is currently executing. This differs from code inclusion in that code inclusion involves the addition or replacement of a reference to a code file, which is subsequently loaded by the target and used as part of the code of some application." ;
        dct:identifier                "242" ;
        dct:title                     "Code Injection" ;
        capec:abstraction             "Meta" ;
        capec:hasConsequence          <http://w3id.org/sepses/resource/capec/Consequence/242273> ;
        capec:hasModificationHistory  <http://w3id.org/sepses/resource/capec/modificationHistory/24220170501> , <http://w3id.org/sepses/resource/capec/modificationHistory/24220190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/24220201217> ;
        capec:hasReference            <http://w3id.org/sepses/resource/capec/reference/REF-612> ;
        capec:hasRelatedWeakness      cwe-res:CWE-94 ;
        capec:hasSubmissionHistory    <http://w3id.org/sepses/resource/capec/submissionHistory/24220140623> ;
        capec:likelihoodOfAttack      "High" ;
        capec:mitigation              "Perform input validation for all content." , "Ensure all input content that is delivered to client is sanitized against an acceptable content specification." , "Enforce regular patching of software." , "Utilize strict type, character, and encoding enforcement" ;
        capec:prerequisite            "The target software does not validate user-controlled input such that the execution of a process may be altered by sending code in through legitimate data channels, using no other mechanism." ;
        capec:status                  "Stable" ;
        capec:typicalSeverity         "High" .

