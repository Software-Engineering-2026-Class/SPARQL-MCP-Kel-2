capec-res:CAPEC-654  a                 capec:CAPEC ;
        dct:description                "An adversary, through a previously installed malicious application, impersonates a credential prompt in an attempt to steal a user's credentials." ;
        dct:identifier                 "654" ;
        dct:title                      "Credential Prompt Impersonation" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/6541> , <http://w3id.org/sepses/resource/capec/Consequence/654104> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6542> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/65420220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/65420220222> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/654ChildOf504> ;
        capec:hasRelatedWeakness       cwe-res:CWE-1021 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/65420200730> ;
        capec:indicator                "Credential prompts that appear illegitimate or unexpected." ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "The only known mitigation to this attack is to avoid installing the malicious application on the device. However, to impersonate a running task the malicious application does need the GET_TASKS permission to be able to query the task list, and being suspicious of applications with that permission can help." ;
        capec:prerequisite             "A legitimate task must exist that an adversary can impersonate to glean credentials." , "The adversary must already have access to the target system via some means." ;
        capec:resourceRequired         "Malware or some other means to initially comprise the target system." , "Additional malware to impersonate a legitimate credential prompt." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "High" .

