capec-res:CAPEC-222  a                 capec:CAPEC ;
        dct:description                "In an iFrame overlay attack the victim is tricked into unknowingly initiating some action in one system while interacting with the UI from seemingly completely different system." ;
        dct:identifier                 "222" ;
        dct:title                      "iFrame Overlay" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/222115> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2222> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2221> , <http://w3id.org/sepses/resource/capec/Consequence/22265> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2223> , <http://w3id.org/sepses/resource/capec/Consequence/222164> , <http://w3id.org/sepses/resource/capec/Consequence/222121> , <http://w3id.org/sepses/resource/capec/Consequence/22269> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/22220180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/22220190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/22220190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/22220170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/22220200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/22220220929> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-84> , <http://w3id.org/sepses/resource/capec/reference/REF-85> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/222ChildOf103> ;
        capec:hasRelatedWeakness       cwe-res:CWE-1021 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/22220140623> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Operation: If using the Firefox browser, use the NoScript plug-in that will help forbid iFrames." , "Operation: When maintaining an authenticated session with a privileged target system, do not use the same browser to navigate to unfamiliar sites to perform other activities. Finish working with the target system and logout first before proceeding to other tasks." , "Configuration: Disable iFrames in the Web browser." ;
        capec:prerequisite             "The victim is communicating with the target application via a web based UI and not a thick client. The victim's browser security policies allow iFrames. The victim uses a modern browser that supports UI elements like clickable buttons (i.e. not using an old text only browser). The victim has an active session with the target system. The target system's interaction window is open in the victim's browser and supports the ability for initiating sensitive actions on behalf of the user in the target system." ;
        capec:resourceRequired         "None: No specialized resources are required to execute this type of attack." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

