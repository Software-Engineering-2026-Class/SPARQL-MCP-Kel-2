        capec:referenceUrl        "https://www.owasp.org/www-project-web-security-testing-guide/latest/4-Web_Application_Security_Testing/11-Client-side_Testing/08-Testing_for_Cross_Site_Flashing.html" .

capec-res:CAPEC-201  a                 capec:CAPEC ;
        dct:description                "An adversary creates a serialized data file (e.g. XML, YAML, etc...) that contains an external data reference. Because serialized data parsers may not validate documents with external references, there may be no checks on the nature of the reference in the external data. This can allow an adversary to open arbitrary files or connections, which may further lead to the adversary gaining access to information on the system that they would normally be unable to obtain." ;
        dct:identifier                 "201" ;
        dct:title                      "Serialized Data External Linking" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/2012> , <http://w3id.org/sepses/resource/capec/Consequence/20169> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2013> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2011> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/20120180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/20120200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/20120211021> , <http://w3id.org/sepses/resource/capec/modificationHistory/20120201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/20120170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/20120220929> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-74> , <http://w3id.org/sepses/resource/capec/reference/REF-73> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/201ChildOf122> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/201ChildOf278> ;
        capec:hasRelatedWeakness       cwe-res:CWE-829 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/20120140623> ;
        capec:likelihoodOfAttack       "High" ;
        capec:mitigation               "Configure the serialized data processor to only retrieve external entities from trusted sources." ;
        capec:prerequisite             "The target must follow external data references without validating the validity of the reference target." ;
        capec:resourceRequired         "None: No specialized resources are required to execute this type of attack." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

