capec-res:CAPEC-400  a                 capec:CAPEC ;
        dct:description                "An attacker uses methods to deactivate a passive RFID tag for the purpose of rendering the tag, badge, card, or object containing the tag unresponsive. RFID tags are used primarily for access control, inventory, or anti-theft devices. The purpose of attacking the RFID chip is to disable or damage the chip without causing damage to the object housing it." ;
        dct:identifier                 "400" ;
        dct:title                      "RFID Chip Deactivation or Destruction" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/40020190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/40020220222> ;
