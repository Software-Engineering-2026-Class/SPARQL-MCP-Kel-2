        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/596ChildOf595> ;
        capec:hasRelatedWeakness       cwe-res:CWE-940 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/59620170103> ;
        capec:prerequisite             "An On/In Path Device" ;
        capec:status                   "Draft" .

