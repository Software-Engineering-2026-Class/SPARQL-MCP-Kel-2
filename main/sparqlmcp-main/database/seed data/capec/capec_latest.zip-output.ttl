<http://w3id.org/sepses/resource/capec/ExecutionFlow/5041>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Determine suitable tasks to exploit] Determine what tasks exist on the target system that may result in a user providing sensitive information." ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "Determine what tasks prompt a user for their credentials." , "Determine what tasks may prompt a user to authorize a process to execute with elevated privileges." .

