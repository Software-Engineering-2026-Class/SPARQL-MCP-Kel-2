<http://w3id.org/sepses/resource/capec/ExecutionFlow/4992>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Create a malicious app] The adversary must create a malicious android app meant to intercept implicit intents from a target application" ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Specify the type of intent wished to be intercepted in the malicious app's manifest file using an intent filter" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/1552>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Attempt to read temporary files] An adversary will attempt to read any temporary files they may have discovered through normal means." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Using a remote shell into an application, read temporary files and send out information remotely if necessary" , "Attempt to get the file by querying the file path to a web server" , "Recover temporary information from a user's browser cache" .

