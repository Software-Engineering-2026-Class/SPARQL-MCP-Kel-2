capec-res:CAPEC-122  a                 capec:CAPEC ;
        dct:description                "An adversary is able to exploit features of the target that should be reserved for privileged users or administrators but are exposed to use by lower or non-privileged accounts. Access to sensitive information and functionality must be controlled to ensure that only authorized users are able to access these resources." ;
        dct:identifier                 "122" ;
        dct:title                      "Privilege Abuse" ;
        capec:abstraction              "Meta" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/12265> , <http://w3id.org/sepses/resource/capec/Consequence/12273> , <http://w3id.org/sepses/resource/capec/Consequence/12269> , <http://w3id.org/sepses/resource/capec/Consequence/122121> , <http://w3id.org/sepses/resource/capec/Consequence/122115> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/12220201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/12220190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/12220220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/12220220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/12220210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/12220200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/12220170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/12220151207> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/122CanPrecede664> ;
        capec:hasRelatedWeakness       cwe-res:CWE-269 , cwe-res:CWE-1317 , cwe-res:CWE-732 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/12220140623> ;
        capec:likelihoodOfAttack       "High" ;
        capec:mitigation               "Configure account privileges such privileged/administrator functionality is not exposed to non-privileged/lower accounts." ;
        capec:prerequisite             "The adversary must have access to the target, albeit with an account that is less privileged than would be appropriate for the targeted resources." , "The target must have misconfigured their access control mechanisms such that sensitive information, which should only be accessible to more trusted users, remains accessible to less trusted users." ;
        capec:resourceRequired         "None: No specialized resources are required to execute this type of attack. The ability to access the target is required." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

capec-res:CAPEC-2  a                   capec:CAPEC ;
        dct:description                "An attacker leverages the security functionality of the system aimed at thwarting potential attacks to launch a denial of service attack against a legitimate system user. Many systems, for instance, implement a password throttling mechanism that locks an account after a certain number of incorrect log in attempts. An attacker can leverage this throttling mechanism to lock a legitimate user out of their own account. The weakness that is being leveraged by an attacker is the very security feature that has been put in place to counteract attacks." ;
        dct:identifier                 "2" ;
        dct:title                      "Inducing Account Lockout" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/22> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/21> , <http://w3id.org/sepses/resource/capec/Consequence/2110> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/23> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/220180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/220200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/220210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/220190404> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/2ChildOf212> ;
        capec:hasRelatedWeakness       cwe-res:CWE-645 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/220140623> ;
        capec:likelihoodOfAttack       "High" ;
        capec:mitigation               "When implementing security features, consider how they can be misused and made to turn on themselves." , "Implement intelligent password throttling mechanisms such as those which take IP address into account, in addition to the login name." ;
        capec:prerequisite             "The system has a lockout mechanism." , "An attacker must be able to reproduce behavior that would result in an account being locked." ;
        capec:resourceRequired         "Computer with access to the login portion of the target system" ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

