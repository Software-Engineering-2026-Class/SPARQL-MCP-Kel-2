capec-res:CAPEC-524  a                 capec:CAPEC ;
        dct:description                "An attacker alters or establishes rogue processes in an integration facility in order to insert maliciously altered components into the system. The attacker would then supply the malicious components. This would allow for malicious disruption or additional compromise when the system is deployed." ;
        dct:identifier                 "524" ;
        dct:title                      "Rogue Integration Procedures" ;
        capec:abstraction              "Standard" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/52420220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/52420151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/52420200730> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-716> , <http://w3id.org/sepses/resource/capec/reference/REF-439> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/524ChildOf439> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/52420140623> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Maintain strong physical system access controls and monitor networks and physical facilities for insider threats." , "Develop an incident response process, disclose supply chain incidents and notify customers with accurate and timely information." , "Maintain a highly secure build and update infrastructure by immediately applying security patches for OS and software, implementing mandatory integrity controls to ensure only trusted tools run, and requiring multi-factor authentication for admins." , "Deploy strong code integrity policies to allow only authorized apps to run." , "Use endpoint detection and response solutions that can automaticalkly detect and remediate suspicious activities." , "Require SSL for update channels and implement certificate transparency based verification." , "Sign everything, including configuration files, XML files and packages." ;
        capec:prerequisite             "Physical access to an integration facility that prepares the system before it is deployed at the victim location." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

