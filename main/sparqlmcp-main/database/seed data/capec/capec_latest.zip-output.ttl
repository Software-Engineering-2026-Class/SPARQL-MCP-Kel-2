<http://w3id.org/sepses/resource/capec/skillRequired/184258>
        a                        capec:SkillRequired ;
        capec:isSkillRequiredOf  capec-res:CAPEC-184 ;
        capec:skillDescription   "Manual or user-assisted attacks require deceptive mechanisms to trick the user into clicking a link or downloading and installing software. Automated update attacks require the attacker to host a payload and then trigger the installation of the payload code." ;
        capec:skillLevel         "Medium" .

capec-res:CAPEC-642  a                 capec:CAPEC ;
        dct:description                "Adversaries know that certain binaries will be regularly executed as part of normal processing. If these binaries are not protected with the appropriate file system permissions, it could be possible to replace them with malware. This malware might be executed at higher system permission levels. A variation of this pattern is to discover self-extracting installation packages that unpack binaries to directories with weak file permissions which it does not clean up appropriately. These binaries can be replaced by malware, which can then be executed." ;
        dct:identifier                 "642" ;
        dct:title                      "Replace Binaries" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/64220201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/64220190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/64220200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/64220220929> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/642ChildOf17> ;
        capec:hasRelatedWeakness       cwe-res:CWE-732 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/64220180531> ;
        capec:mitigation               "Insure that binaries commonly used by the system have the correct file permissions. Set operating system policies that restrict privilege elevation of non-Administrators. Use auditing tools to observe changes to system services." ;
        capec:prerequisite             "The attacker must be able to place the malicious binary on the target machine." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

