capec-res:CAPEC-477  a                 capec:CAPEC ;
        dct:description                "An attacker exploits the underlying complexity of a data structure that allows for both signed and unsigned content, to cause unsigned data to be processed as though it were signed data." ;
        dct:identifier                 "477" ;
        dct:title                      "Signature Spoofing by Mixing Signed and Unsigned Content" ;
        capec:abstraction              "Detailed" ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/477ChildOf473> ;
        capec:hasRelatedWeakness       cwe-res:CWE-693 , cwe-res:CWE-311 , cwe-res:CWE-319 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/47720140623> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Ensure the application is fully patched and does not allow the processing of unsigned data as if it is signed data." ;
        capec:prerequisite             "Signer and recipient are using complex data storage structures that allow for a mix between signed and unsigned data" , "Recipient is using signature verification software that does not maintain separation between signed and unsigned data once the signature has been verified." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/1092>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Probe for ORM Injection vulnerabilities] The attacker injects ORM syntax into user-controllable data inputs of the application to determine if it is possible modify data query structure and content." ;
        capec:attackStepPhase        "Explore" .

capec-res:CAPEC-287  a                 capec:CAPEC ;
        dct:description                "An adversary uses a SYN scan to determine the status of ports on the remote target. SYN scanning is the most common type of port scanning that is used because of its many advantages and few drawbacks. As a result, novice attackers tend to overly rely on the SYN scan while performing system reconnaissance. As a scanning method, the primary advantages of SYN scanning are its universality and speed." ;
        dct:identifier                 "287" ;
        dct:title                      "TCP SYN Scan" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/2872> , <http://w3id.org/sepses/resource/capec/Consequence/287173> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2871> , <http://w3id.org/sepses/resource/capec/Consequence/287177> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/28720180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/28720220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/28720201217> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-128> , <http://w3id.org/sepses/resource/capec/reference/REF-34> , <http://w3id.org/sepses/resource/capec/reference/REF-33> , <http://w3id.org/sepses/resource/capec/reference/REF-130> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/287ChildOf300> ;
        capec:hasRelatedWeakness       cwe-res:CWE-200 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/28720140623> ;
        capec:prerequisite             "This scan type is not possible with some operating systems (Windows XP SP 2). On Linux and Unix systems it requires root privileges to use raw sockets." ;
        capec:resourceRequired         "The ability to send TCP SYN segments to a host during network reconnaissance via the use of a network mapper or scanner, or via raw socket programming in a scripting language. Packet injection tools are also useful for this purpose. Depending upon the method used it may be necessary to sniff the network in order to see the response." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "Low" .

