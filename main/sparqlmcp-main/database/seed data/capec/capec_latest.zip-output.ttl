capec-res:CAPEC-478  a                 capec:CAPEC ;
        dct:description                "An adversary exploits a weakness in access control to modify the execution parameters of a Windows service. The goal of this attack is to execute a malicious binary in place of an existing service." ;
        dct:identifier                 "478" ;
        dct:title                      "Modification of Windows Service Configuration" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/4781> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/4782> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/4783> , <http://w3id.org/sepses/resource/capec/Consequence/478214> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/47820211021> , <http://w3id.org/sepses/resource/capec/modificationHistory/47820200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/47820190404> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/478ChildOf203> ;
        capec:hasRelatedWeakness       cwe-res:CWE-284 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/47820180425> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Ensure proper permissions are set for Registry hives to prevent users from modifying keys for system components that may lead to privilege escalation." ;
        capec:prerequisite             "The adversary must have the capability to write to the Windows Registry on the targeted system." ;
        capec:resourceRequired         "None: No specialized resources are required to execute this type of attack." ;
        capec:status                   "Usable" ;
        capec:typicalSeverity          "High" .

