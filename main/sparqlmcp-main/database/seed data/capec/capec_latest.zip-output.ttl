capec-res:CAPEC-699  a                 capec:CAPEC ;
        dct:description                "An Adversary can eavesdrop on the content of an external monitor through the air without modifying any cable or installing software, just capturing this signal emitted by the cable or video port, with this the attacker will be able to impact the confidentiality of the data without being detected by traditional security tools" ;
        dct:identifier                 "699" ;
        dct:title                      "Eavesdropping on a Monitor" ;
        capec:abstraction              "Meta" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/6992> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6993> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6991> , <http://w3id.org/sepses/resource/capec/Consequence/69969> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-744> , <http://w3id.org/sepses/resource/capec/reference/REF-745> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/699ChildOf651> ;
        capec:hasRelatedWeakness       cwe-res:CWE-1300 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/69920230124> ;
        capec:indicator                "The target will not observe any indicators of the attack from the computer user’s perspective. The only indication of this attack would be a visible SDR with antenna that can be seen in close proximity to a display cable which is not normally present. This requires that the target is aware of what SDRs look like and can recognize that it may be out of place." ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Implement: Use wireless technologies to connect to external display devices." , "Design: Lock away the video cables, making it difficult for the attacker to access the cables and place the antenna near them (If the distance condition between the antenna and display port/cable is not satisfied, the attack will not be possible)." , "Implement: Use a protocol that encrypts the video signal; in case the signal is intercepted the signal is protected by the encryption." , "Enhance: Increase the number of electromagnetic shield layers in the display ports and cables to contain or reduce the intensity of the leaked signal." ;
        capec:prerequisite             "Physical access to the target location and devices" , "Victim should use an external monitor device" ;
        capec:resourceRequired         "SDR device set with the correspondent antenna" , "Computer with SDR Software" ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

<http://w3id.org/sepses/resource/capec/modificationHistory/52820220222>
        a                               capec:ModificationHistory ;
        capec:modificationComment       "Updated Description, Extended_Description" ;
