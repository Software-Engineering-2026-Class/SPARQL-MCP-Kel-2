        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Find injection vector] The adversary attempts to use the API, and if they can they send a large amount of data to see if the buffer overflow attack really does work." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Provide large input to a program or application and observe the behavior. If there is a crash, this means that a buffer overflow attack is possible." .

capec-res:CAPEC-591  a                 capec:CAPEC ;
        dct:description                "This type of attack is a form of Cross-Site Scripting (XSS) where a malicious script is \"reflected\" off a vulnerable web application and then executed by a victim's browser. The process starts with an adversary delivering a malicious script to a victim and convincing the victim to send the script to the vulnerable web application." ;
        dct:identifier                 "591" ;
        dct:title                      "Reflected XSS" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/591305> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/5914> , <http://w3id.org/sepses/resource/capec/Consequence/591166> , <http://w3id.org/sepses/resource/capec/Consequence/591313> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/5911> , <http://w3id.org/sepses/resource/capec/Consequence/591200> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/5913> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/5912> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/59120190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/59120220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/59120170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/59120201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/59120190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/59120220222> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-604> , <http://w3id.org/sepses/resource/capec/reference/REF-476> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/591ChildOf63> ;
        capec:hasRelatedWeakness       cwe-res:CWE-79 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/59120170415> ;
        capec:likelihoodOfAttack       "High" ;
        capec:mitigation               "Use browser technologies that do not allow client-side scripting." , "Ensure that all user-supplied input is validated before use." , "Utilize strict type, character, and encoding enforcement." ;
        capec:prerequisite             "An application that fail to adequately sanitize or encode untrusted input." , "An application that leverages a client-side web browser with scripting enabled." ;
        capec:resourceRequired         "None: No specialized resources are required to execute this type of attack." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "Very High" .

