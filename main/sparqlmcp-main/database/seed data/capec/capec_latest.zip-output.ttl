capec-res:CAPEC-221  a                 capec:CAPEC ;
        dct:description                "This attack takes advantage of the entity replacement property of certain data serialization languages (e.g., XML, YAML, etc.) where the value of the replacement is a URI. A well-crafted file could have the entity refer to a URI that consumes a large amount of resources to create a denial of service condition. This can cause the system to either freeze, crash, or execute arbitrary code depending on the URI." ;
        dct:identifier                 "221" ;
        dct:title                      "Data Serialization External Entities Blowup" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/2212> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2211> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2214> , <http://w3id.org/sepses/resource/capec/Consequence/221176> , <http://w3id.org/sepses/resource/capec/Consequence/22177> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/22120211021> , <http://w3id.org/sepses/resource/capec/modificationHistory/22120200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/22120180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/22120170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/22120220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/22120201217> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/221ChildOf231> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/221ChildOf278> ;
        capec:hasRelatedWeakness       cwe-res:CWE-611 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/22120140623> ;
        capec:mitigation               "This attack may be mitigated by tweaking the serialized data parser to not resolve external entities. If external entities are needed, then implement a custom resolver that has a request timeout, data retrieval limit, and restrict resources it can retrieve locally." , "This attack may be mitigated by tweaking the XML parser to not resolve external entities. If external entities are needed, then implement a custom XmlResolver that has a request timeout, data retrieval limit, and restrict resources it can retrieve locally." ;
        capec:prerequisite             "A server that has an implementation that accepts entities containing URI values." ;
        capec:status                   "Draft" .

