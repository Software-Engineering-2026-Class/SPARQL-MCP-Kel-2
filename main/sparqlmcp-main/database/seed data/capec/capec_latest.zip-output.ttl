<http://w3id.org/sepses/resource/capec/ExecutionFlow/5653>
        a                            capec:AttackStep ;
        capec:attackStep             "3" ;
        capec:attackStepDescription  "[Brute force password] Given the finite space of possible passwords dictated by information determined in the previous steps, try each password for all known user accounts until the target grants access." ;
        capec:attackStepPhase        "Exploit" ;
        capec:attackStepTechnique    "Manually or automatically enter the first password for each known user account through the target's interface. In most systems, start with the shortest and simplest possible passwords, because most users tend to select such passwords if allowed to do so." , "Iterate through the remaining passwords for each known user account." .

capec-res:CAPEC-504  a                 capec:CAPEC ;
        dct:description                "An adversary, through a previously installed malicious application, impersonates an expected or routine task in an attempt to steal sensitive information or leverage a user's privileges." ;
        dct:identifier                 "504" ;
        dct:title                      "Task Impersonation" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/5042> , <http://w3id.org/sepses/resource/capec/Consequence/504104> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/5041> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/50420190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/50420220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/50420180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/50420190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/50420200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/50420220929> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-434> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/504ChildOf173> ;
        capec:hasRelatedWeakness       cwe-res:CWE-1021 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/50420140623> ;
        capec:indicator                "Credential or permission elevation prompts that appear illegitimate or unexpected." ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "The only known mitigation to this attack is to avoid installing the malicious application on the device. However, to impersonate a running task the malicious application does need the GET_TASKS permission to be able to query the task list, and being suspicious of applications with that permission can help." ;
        capec:prerequisite             "A legitimate task must exist that an adversary can impersonate to glean credentials." , "The user's privileges allow them to execute certain tasks with elevated privileges." , "The adversary must already have access to the target system via some means." ;
        capec:resourceRequired         "Malware or some other means to initially comprise the target system." , "Additional malware to impersonate a legitimate task." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "High" .

