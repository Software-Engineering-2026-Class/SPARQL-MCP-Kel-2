<http://w3id.org/sepses/resource/capec/ExecutionFlow/1623>
        a                            capec:AttackStep ;
        capec:attackStep             "3" ;
        capec:attackStepDescription  "[Send modified hidden fields to server-side] Once the adversary has found hidden fields in the client-side, they will modify the values of these hidden fields one by one and then interact with the web application so that this data is sent to the server-side. The adversary observes the response from the server to determine if the values of each hidden field are being validated." ;
        capec:attackStepPhase        "Experiment" .

capec-res:CAPEC-89  a                  capec:CAPEC ;
        dct:description                "A pharming attack occurs when the victim is fooled into entering sensitive data into supposedly trusted locations, such as an online bank site or a trading platform. An attacker can impersonate these supposedly trusted sites and have the victim be directed to their site rather than the originally intended one. Pharming does not require script injection or clicking on malicious links for the attack to succeed." ;
        dct:identifier                 "89" ;
        dct:title                      "Pharming" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/893> , <http://w3id.org/sepses/resource/capec/Consequence/8969> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/892> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/891> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/894> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/8920151207> , <http://w3id.org/sepses/resource/capec/modificationHistory/8920170501> , <http://w3id.org/sepses/resource/capec/modificationHistory/8920220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/8920190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/8920170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/8920201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/8920200730> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/89ChildOf151> ;
        capec:hasRelatedWeakness       cwe-res:CWE-350 , cwe-res:CWE-346 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/8920140623> ;
        capec:likelihoodOfAttack       "High" ;
        capec:mitigation               "End users must ensure that they provide sensitive information only to websites that they trust, over a secure connection with a valid certificate issued by a well-known certificate authority." , "All sensitive information must be handled over a secure connection." , "Known vulnerabilities in DNS or router software or in operating systems must be patched as soon as a fix has been released and tested." ;
        capec:prerequisite             "A website that handles sensitive information but does not use a secure connection and a certificate that is valid is also prone to pharming" , "Vulnerable DNS software or improperly protected hosts file or router that can be poisoned" ;
        capec:resourceRequired         "None: No specialized resources are required to execute this type of attack. Having knowledge of the way the target site has been structured, in order to create a fake version, is required. Poisoning the resolver requires knowledge of a vulnerability that can be exploited." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Very High" .

