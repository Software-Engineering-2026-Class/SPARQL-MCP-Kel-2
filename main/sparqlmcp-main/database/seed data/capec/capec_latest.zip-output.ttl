capec-res:CAPEC-454  a                capec:CAPEC ;
        dct:description               "This attack pattern has been deprecated as it is a duplicate of CAPEC-452 : Malicious Logic Insertion into Product Hardware. Please refer to this other pattern going forward." ;
        dct:identifier                "454" ;
