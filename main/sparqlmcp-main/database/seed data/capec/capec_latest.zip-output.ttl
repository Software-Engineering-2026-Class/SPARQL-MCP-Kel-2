capec-res:CAPEC-590  a                 capec:CAPEC ;
        dct:description                "An adversary performing this type of attack drops packets destined for a target IP address. The aim is to prevent access to the service hosted at the target IP address." ;
        dct:identifier                 "590" ;
        dct:title                      "IP Address Blocking" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/590164> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/59020170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/59020190404> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-475> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/590ChildOf603> ;
        capec:hasRelatedWeakness       cwe-res:CWE-300 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/59020170112> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Have a large pool of backup IPs built into the application and support proxy capability in the application." ;
        capec:prerequisite             "This attack requires the ability to conduct deep packet inspection with an In-Path device that can drop the targeted traffic and/or connection." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

