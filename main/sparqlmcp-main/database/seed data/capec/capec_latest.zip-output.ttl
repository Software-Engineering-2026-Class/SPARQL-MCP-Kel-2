<http://w3id.org/sepses/resource/capec/ExecutionFlow/21>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Investigate account lockout behavior of system] Investigate the security features present in the system that may trigger an account lockout" ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Obtain user account in system and attempt to lock it out by sending malformed or incorrect data repeatedly" , "Analyze system documentation to find list of events that could potentially cause account lockout" , "Determine another user's login ID, and attempt to brute force the password (or other credentials) for it a predetermined number of times, or until the system provides an indication that the account is locked out." .

capec-res:CAPEC-530  a                 capec:CAPEC ;
        dct:description                "An attacker provides a counterfeit component during the procurement process of a lower-tier component supplier to a sub-system developer or integrator, which is then built into the system being upgraded or repaired by the victim, allowing the attacker to cause disruption or additional compromise." ;
        dct:identifier                 "530" ;
        dct:title                      "Provide Counterfeit Component" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/53020151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/53020220222> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-703> , <http://w3id.org/sepses/resource/capec/reference/REF-698> , <http://w3id.org/sepses/resource/capec/reference/REF-439> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/530ChildOf531> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/53020140623> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "There are various methods to detect if the component is a counterfeit. See section II of [REF-703] for many techniques." ;
        capec:prerequisite             "Advanced knowledge about the target system and sub-components." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

