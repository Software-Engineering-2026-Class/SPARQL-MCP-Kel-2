capec-res:CAPEC-107  a                 capec:CAPEC ;
        dct:description                "Cross Site Tracing (XST) enables an adversary to steal the victim's session cookie and possibly other authentication credentials transmitted in the header of the HTTP request when the victim's browser communicates to a destination system's web server." ;
        dct:identifier                 "107" ;
        dct:title                      "Cross Site Tracing" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/10769> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1071> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1074> , <http://w3id.org/sepses/resource/capec/Consequence/10765> , <http://w3id.org/sepses/resource/capec/Consequence/107134> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1073> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1075> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1072> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/10720220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/10720170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/10720170501> , <http://w3id.org/sepses/resource/capec/modificationHistory/10720200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/10720201217> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-3> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/107ChildOf593> ;
        capec:hasRelatedWeakness       cwe-res:CWE-693 , cwe-res:CWE-648 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/10720140623> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Patch web browser against known security origin policy bypass exploits." , "Administrators should disable support for HTTP TRACE at the destination's web server. Vendors should disable TRACE by default." ;
        capec:prerequisite             "The destination system is susceptible to XSS or an adversary can leverage some other weakness to bypass the same origin policy" , "HTTP is used as the communication protocol between the server and the client" , "HTTP TRACE is enabled on the web server" , "Scripting is enabled in the client's browser" ;
        capec:resourceRequired         "None: No specialized resources are required to execute this type of attack." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Very High" .

