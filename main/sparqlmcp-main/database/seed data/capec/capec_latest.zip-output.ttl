<http://w3id.org/sepses/resource/capec/ExecutionFlow/5003>
        a                            capec:AttackStep ;
        capec:attackStep             "3" ;
        capec:attackStepDescription  "[Get the victim to download and run the application] An adversary needs to get the victim to willingly download and run the application." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Pay for App Store advertisements" , "Promote the application on social media, either through accounts made by the adversary or by paying for other accounts to advertise." .

