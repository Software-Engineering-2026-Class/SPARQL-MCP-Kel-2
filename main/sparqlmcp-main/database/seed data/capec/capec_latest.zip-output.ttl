        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Find Session IDs] The attacker interacts with the target host and finds that session IDs are used to authenticate users." ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "An attacker makes many anonymous connections and records the session IDs assigned." , "An attacker makes authorized connections and records the session tokens or credentials issued." .

