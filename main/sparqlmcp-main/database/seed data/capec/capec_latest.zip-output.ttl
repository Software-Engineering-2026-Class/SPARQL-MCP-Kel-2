capec-res:CAPEC-94  a                  capec:CAPEC ;
        dct:description                "\n            An adversary targets the communication between two components (typically client and server), in order to alter or obtain data from transactions. A general approach entails the adversary placing themself within the communication channel between the two components.\n         " ;
        dct:identifier                 "94" ;
        dct:title                      "Adversary in the Middle (AiTM)" ;
        capec:abstraction              "Meta" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/942> , <http://w3id.org/sepses/resource/capec/Consequence/9465> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/941> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/943> , <http://w3id.org/sepses/resource/capec/Consequence/9469> , <http://w3id.org/sepses/resource/capec/Consequence/94134> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/9420190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/9420180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/9420201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/9420190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/9420200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/9420210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/9420220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/9420220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/9420170804> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-634> , <http://w3id.org/sepses/resource/capec/reference/REF-633> , <http://w3id.org/sepses/resource/capec/reference/REF-553> , <http://w3id.org/sepses/resource/capec/reference/REF-636> , <http://w3id.org/sepses/resource/capec/reference/REF-635> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/94CanPrecede668> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/94CanPrecede151> ;
        capec:hasRelatedWeakness       cwe-res:CWE-294 , cwe-res:CWE-290 , cwe-res:CWE-287 , cwe-res:CWE-300 , cwe-res:CWE-593 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/9420140623> ;
        capec:likelihoodOfAttack       "High" ;
        capec:mitigation               "Use Strong mutual authentication to always fully authenticate both ends of any communications channel." , "Encrypt communications using cryptography (e.g., SSL/TLS)" , "Exchange public keys using a secure channel" , "Ensure Public Keys are signed by a Certificate Authority" ;
        capec:prerequisite             "An attacker is able to identify the nature and mechanism of communication between the two target components." , "There are two components communicating with each other." , "The communication occurs in clear (not encrypted) or with insufficient and spoofable encryption." , "Strong mutual authentication is not used between the two target components yielding opportunity for attacker interposition." , "An attacker can eavesdrop on the communication between the target components." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "Very High" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/311>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Obtain copy of cookie] The adversary first needs to obtain a copy of the cookie. The adversary may be a legitimate end user wanting to escalate privilege, or could be somebody sniffing on a network to get a copy of HTTP cookies." ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "Steal cookie via a cross-site scripting attack." , "Obtain cookie using a utility such as the Firefox Cookie Manager, Chrome DevTools or AnEC Cookie Editor." , "Sniff cookie using a network sniffer such as Wireshark" , "Guess cookie contents if it contains predictable information." .

