capec-res:CAPEC-219  a                 capec:CAPEC ;
        dct:description                "An attacker subverts an intermediate system used to process XML content and forces the intermediate to modify and/or re-route the processing of the content. XML Routing Detour Attacks are Adversary in the Middle type attacks (CAPEC-94). The attacker compromises or inserts an intermediate system in the processing of the XML message. For example, WS-Routing can be used to specify a series of nodes or intermediaries through which content is passed. If any of the intermediate nodes in this route are compromised by an attacker they could be used for a routing detour attack. From the compromised system the attacker is able to route the XML process to other nodes of their choice and modify the responses so that the normal chain of processing is unaware of the interception. This system can forward the message to an outside entity and hide the forwarding and processing from the legitimate processing systems by altering the header information." ;
        dct:identifier                 "219" ;
        dct:title                      "XML Routing Detour Attacks" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/21969> , <http://w3id.org/sepses/resource/capec/Consequence/21965> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2191> , <http://w3id.org/sepses/resource/capec/Consequence/219115> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2192> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2193> , <http://w3id.org/sepses/resource/capec/Consequence/219164> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/21920170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/21920220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/21920210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/21920200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/21920201217> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-80> , <http://w3id.org/sepses/resource/capec/reference/REF-81> , <http://w3id.org/sepses/resource/capec/reference/REF-65> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/219ChildOf94> ;
        capec:hasRelatedWeakness       cwe-res:CWE-441 , cwe-res:CWE-610 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/21920140623> ;
        capec:likelihoodOfAttack       "High" ;
        capec:mitigation               "Design: Specify maximum number intermediate nodes for the request and require SSL connections with mutual authentication." , "Implementation: Use SSL for connections between all parties with mutual authentication." ;
        capec:prerequisite             "The targeted system must have multiple stages processing of XML content." ;
        capec:resourceRequired         "The attacker must be able to insert or compromise a system into the processing path for the transaction." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

