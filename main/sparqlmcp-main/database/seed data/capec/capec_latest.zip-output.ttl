<http://w3id.org/sepses/resource/capec/ExecutionFlow/2091>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Survey the application for stored user-controllable inputs] Using a browser or an automated tool, an adversary follows all public links and actions on a web site. They record all areas that allow a user to upload content through an HTTP POST request. This is typically found in blogs or forums." ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "Use a proxy tool to record all links visited during a manual traversal of the web application." , "Use a spidering tool to follow and record all links and analyze the web pages to file upload features" , "Use a browser to manually explore the website and analyze how it is constructed. Many browsers' plugins are available to facilitate the analysis or automate the discovery." .

capec-res:CAPEC-192  a                capec:CAPEC ;
        dct:description               "An adversary engages in activities to decipher and/or decode protocol information for a network or application communication protocol used for transmitting information between interconnected nodes or systems on a packet-switched data network. While this type of analysis involves the analysis of a networking protocol inherently, it does not require the presence of an actual or physical network." ;
        dct:identifier                "192" ;
        dct:title                     "Protocol Analysis" ;
        capec:abstraction             "Meta" ;
        capec:hasConsequence          <http://w3id.org/sepses/resource/capec/Consequence/192199> , <http://w3id.org/sepses/resource/capec/Consequence/192181> ;
        capec:hasModificationHistory  <http://w3id.org/sepses/resource/capec/modificationHistory/19220170501> , <http://w3id.org/sepses/resource/capec/modificationHistory/19220220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/19220151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/19220180731> ;
        capec:hasReference            <http://w3id.org/sepses/resource/capec/reference/REF-57> , <http://w3id.org/sepses/resource/capec/reference/REF-50> ;
        capec:hasRelatedWeakness      cwe-res:CWE-326 ;
        capec:hasSubmissionHistory    <http://w3id.org/sepses/resource/capec/submissionHistory/19220140623> ;
        capec:likelihoodOfAttack      "Low" ;
        capec:prerequisite            "Access to a binary executable." , "The ability to observe and interact with a communication channel between communicating processes." ;
        capec:resourceRequired        "Depending on the type of analysis, a variety of tools might be required, such as static code and/or dynamic analysis tools. Alternatively, the effort might require debugging programs such as ollydbg, SoftICE, or disassemblers like IDA Pro. In some instances, packet sniffing or packet analyzing programs such as TCP dump or Wireshark are necessary. Lastly, specific protocol analysis might require tools such as PDB (Protocol Debug), or packet injection tools like pcap or Nemesis." ;
        capec:status                  "Stable" ;
        capec:typicalSeverity         "Low" .

<http://w3id.org/sepses/resource/capec/relatedAttackPattern/585ChildOf582>
        a       capec:RelatedAttackPattern ;
        capec:relatedAttackPatternCAPECId
                capec-res:CAPEC-582 ;
        capec:relatedAttackPatternNature
                "ChildOf" .

capec-res:CAPEC-14  a                  capec:CAPEC ;
        dct:description                "This type of attack exploits a buffer overflow vulnerability in targeted client software through injection of malicious content from a custom-built hostile service. This hostile service is created to deliver the correct content to the client software. For example, if the client-side application is a browser, the service will host a webpage that the browser loads." ;
        dct:identifier                 "14" ;
        dct:title                      "Client-side Injection-induced Buffer Overflow" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/143> , <http://w3id.org/sepses/resource/capec/Consequence/14110> , <http://w3id.org/sepses/resource/capec/Consequence/1469> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/144> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/141> , <http://w3id.org/sepses/resource/capec/Consequence/1465> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/142> , <http://w3id.org/sepses/resource/capec/Consequence/14176> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/1420200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/1420210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/1420170109> , <http://w3id.org/sepses/resource/capec/modificationHistory/1420220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/1420211021> , <http://w3id.org/sepses/resource/capec/modificationHistory/1420180731> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-1> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/14ChildOf100> ;
        capec:hasRelatedWeakness       cwe-res:CWE-120 , cwe-res:CWE-697 , cwe-res:CWE-20 , cwe-res:CWE-74 , cwe-res:CWE-680 , cwe-res:CWE-353 , cwe-res:CWE-118 , cwe-res:CWE-119 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/1420140623> ;
        capec:indicator                "An example of indicator is when the client software crashes after executing code downloaded from a hostile server." ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Ensure all buffer uses are consistently bounds-checked." , "Use OS-level preventative functionality. Not a complete solution." , "The client software should have the latest patches and should be audited for vulnerabilities before being used to communicate with potentially hostile servers." , "Compiler-based canary mechanisms such as StackGuard, ProPolice and the Microsoft Visual Studio /GS flag. Unless this provides automatic bounds checking, it is not a complete solution." , "Use a language or compiler that performs automatic bounds checking." , "Use an abstraction library to abstract away risky APIs. Not a complete solution." , "The client software should not install untrusted code from a non-authenticated server." , "Perform input validation for length of buffer inputs." ;
        capec:prerequisite             "The targeted client software has a buffer overflow vulnerability." , "The targeted client software communicates with an external server." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

