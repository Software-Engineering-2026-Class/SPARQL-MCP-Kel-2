capec-res:CAPEC-93  a                  capec:CAPEC ;
        dct:description                "This attack targets the log files of the target host. The attacker injects, manipulates or forges malicious log entries in the log file, allowing them to mislead a log audit, cover traces of attack, or perform other malicious actions. The target host is not properly controlling log access. As a result tainted data is resulting in the log files leading to a failure in accountability, non-repudiation and incident forensics capability." ;
        dct:identifier                 "93" ;
        dct:title                      "Log Injection-Tampering-Forging" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/932> , <http://w3id.org/sepses/resource/capec/Consequence/9365> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/931> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/9320210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/9320151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/9320170501> , <http://w3id.org/sepses/resource/capec/modificationHistory/9320220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/9320200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/9320180731> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-551> , <http://w3id.org/sepses/resource/capec/reference/REF-552> , <http://w3id.org/sepses/resource/capec/reference/REF-131> , <http://w3id.org/sepses/resource/capec/reference/REF-550> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/93CanPrecede592> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/93ChildOf268> ;
        capec:hasRelatedWeakness       cwe-res:CWE-117 , cwe-res:CWE-75 , cwe-res:CWE-150 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/9320140623> ;
        capec:likelihoodOfAttack       "High" ;
        capec:mitigation               "Use static analysis tools to identify log forging vulnerabilities." , "Do not allow tainted data to be written in the log file without prior input validation. An allowlist may be used to properly validate the data." , "Carefully control access to physical log files." , "Avoid viewing logs with tools that may interpret control characters in the file, such as command-line shells." , "Use synchronization to control the flow of execution." ;
        capec:prerequisite             "The target host is logging the action and data of the user." , "The target host insufficiently protects access to the logs or logging mechanisms." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

capec-res:CAPEC-632  a                 capec:CAPEC ;
        dct:description                "An adversary registers a domain name containing a homoglyph, leading the registered domain to appear the same as a trusted domain. A homograph attack leverages the fact that different characters among various character sets look the same to the user. Homograph attacks must generally be combined with other attacks, such as phishing attacks, in order to direct Internet traffic to the adversary-controlled destinations." ;
        dct:identifier                 "632" ;
        dct:title                      "Homograph Attack via Homoglyphs" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/6321> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6322> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6323> , <http://w3id.org/sepses/resource/capec/Consequence/632256> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/63220201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/63220230124> , <http://w3id.org/sepses/resource/capec/modificationHistory/63220220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/63220180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/63220190404> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/632CanPrecede543> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/632CanPrecede89> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/632ChildOf616> ;
        capec:hasRelatedWeakness       cwe-res:CWE-1007 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/63220151109> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Authenticate all servers and perform redundant checks when using DNS hostnames." , "Utilize browsers that can warn users if URLs contain characters from different character sets." ;
        capec:prerequisite             "An adversary requires knowledge of popular or high traffic domains, that could be used to deceive potential targets." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

