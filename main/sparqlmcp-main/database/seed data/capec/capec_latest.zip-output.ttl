capec-res:CAPEC-274  a                 capec:CAPEC ;
        dct:description                "An attacker modifies the HTTP Verb (e.g. GET, PUT, TRACE, etc.) in order to bypass access restrictions. Some web environments allow administrators to restrict access based on the HTTP Verb used with requests. However, attackers can often provide a different HTTP Verb, or even provide a random string as a verb in order to bypass these protections. This allows the attacker to access data that should otherwise be protected." ;
        dct:identifier                 "274" ;
        dct:title                      "HTTP Verb Tampering" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/27420190930> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-118> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/274ChildOf220> ;
        capec:hasRelatedWeakness       cwe-res:CWE-302 , cwe-res:CWE-654 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/27420140623> ;
        capec:mitigation               "Design: Ensure that only legitimate HTTP verbs are allowed." , "Design: Do not use HTTP verbs as factors in access decisions." ;
        capec:prerequisite             "The targeted system must attempt to filter access based on the HTTP verb used in requests." ;
        capec:resourceRequired         "The attacker requires a tool that allows them to manually control the HTTP verb used to send messages to the targeted server." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

