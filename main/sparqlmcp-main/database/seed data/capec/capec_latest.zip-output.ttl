capec-res:CAPEC-217  a                 capec:CAPEC ;
        dct:description                "An adversary takes advantage of incorrectly configured SSL/TLS communications that enables access to data intended to be encrypted. The adversary may also use this type of attack to inject commands or other traffic into the encrypted stream to cause compromise of either the client or server." ;
        dct:identifier                 "217" ;
        dct:title                      "Exploiting Incorrectly Configured SSL/TLS" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/2171> , <http://w3id.org/sepses/resource/capec/Consequence/217134> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2172> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/2173> , <http://w3id.org/sepses/resource/capec/Consequence/21769> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/21720151207> , <http://w3id.org/sepses/resource/capec/modificationHistory/21720220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/21720210624> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/217ChildOf216> ;
        capec:hasRelatedWeakness       cwe-res:CWE-201 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/21720140623> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Only use TLS version 1.2+, as versions 1.0 and 1.1 are insecure." , "Do not use SSL, as all SSL versions have been broken and should not be used. If TLS is not an option for the client or server, consider setting timeouts on SSL sessions to extremely low values to lessen the potential impact." , "Configure TLS to use secure algorithms. The current recommendation is to use ECDH, ECDSA, AES256-GCM, and SHA384 for the most security." ;
        capec:prerequisite             "Access to the client/server stream." ;
        capec:resourceRequired         "The adversary needs the ability to sniff traffic, and optionally be able to route said traffic to a system where the sniffing of traffic can take place, and act upon the recovered traffic in real time." ;
        capec:status                   "Draft" .

