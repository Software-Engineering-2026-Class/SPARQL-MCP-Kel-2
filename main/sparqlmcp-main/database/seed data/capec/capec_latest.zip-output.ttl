capec-res:CAPEC-631  a                 capec:CAPEC ;
        dct:description                "An adversary registers a domain name that sounds the same as a trusted domain, but has a different spelling. A SoundSquatting attack takes advantage of a user's confusion of the two words to direct Internet traffic to adversary-controlled destinations. SoundSquatting does not require an attack against the trusted domain or complicated reverse engineering." ;
        dct:identifier                 "631" ;
        dct:title                      "SoundSquatting" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/6313> , <http://w3id.org/sepses/resource/capec/Consequence/631261> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6311> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/6312> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/63120201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/63120190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/63120180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/63120220929> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-491> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/631CanPrecede543> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/631CanPrecede89> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/631ChildOf616> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/63120151109> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Authenticate all servers and perform redundant checks when using DNS hostnames." , "Purchase potential SoundSquatted domains and forward to legitimate domain." ;
        capec:prerequisite             "An adversary requires knowledge of popular or high traffic domains, that could be used to deceive potential targets." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

