capec-res:CAPEC-188  a                capec:CAPEC ;
        dct:description               "An adversary discovers the structure, function, and composition of an object, resource, or system by using a variety of analysis techniques to effectively determine how the analyzed entity was constructed or operates. The goal of reverse engineering is often to duplicate the function, or a part of the function, of an object in order to duplicate or \"back engineer\" some aspect of its functioning. Reverse engineering techniques can be applied to mechanical objects, electronic devices, or software, although the methodology and techniques involved in each type of analysis differ widely." ;
        dct:identifier                "188" ;
        dct:title                     "Reverse Engineering" ;
        capec:abstraction             "Meta" ;
        capec:hasModificationHistory  <http://w3id.org/sepses/resource/capec/modificationHistory/18820151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/18820170501> , <http://w3id.org/sepses/resource/capec/modificationHistory/18820230124> , <http://w3id.org/sepses/resource/capec/modificationHistory/18820180731> ;
        capec:hasReference            <http://w3id.org/sepses/resource/capec/reference/REF-50> ;
        capec:hasRelatedWeakness      cwe-res:CWE-1278 ;
        capec:hasSubmissionHistory    <http://w3id.org/sepses/resource/capec/submissionHistory/18820140623> ;
        capec:likelihoodOfAttack      "Low" ;
        capec:mitigation              "Employ code obfuscation techniques to prevent the adversary from reverse engineering the targeted entity." ;
        capec:prerequisite            "Access to targeted system, resources, and information." ;
        capec:resourceRequired        "The technical resources necessary to engage in reverse engineering differ in accordance with the type of object, resource, or system being analyzed." ;
        capec:status                  "Stable" ;
        capec:typicalSeverity         "Low" .

