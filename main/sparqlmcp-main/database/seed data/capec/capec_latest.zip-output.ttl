capec-res:CAPEC-198  a                 capec:CAPEC ;
        dct:description                "An adversary distributes a link (or possibly some other query structure) with a request to a third party web server that is malformed and also contains a block of exploit code in order to have the exploit become live code in the resulting error page." ;
        dct:identifier                 "198" ;
        dct:title                      "XSS Targeting Error Pages" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/1983> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1984> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1981> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1982> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/19820170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/19820220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/19820210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/19820200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/19820170501> , <http://w3id.org/sepses/resource/capec/modificationHistory/19820220929> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/198ChildOf591> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/198ChildOf592> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/198ChildOf588> ;
        capec:hasRelatedWeakness       cwe-res:CWE-81 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/19820140623> ;
        capec:mitigation               "Implementation: Normalize, filter and use an allowlist for any input that will be used in error messages." , "Design: Use libraries and templates that minimize unfiltered input." , "Implementation: The victim should configure the browser to minimize active content from untrusted sources." ;
        capec:prerequisite             "The victim must be made to execute a query crafted by the adversary which results in the infected error report." , "A third party web server which fails to adequately sanitize messages sent in error pages." ;
        capec:resourceRequired         "None: No specialized resources are required to execute this type of attack." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

