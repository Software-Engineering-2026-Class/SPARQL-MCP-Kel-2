<http://w3id.org/sepses/resource/capec/ExecutionFlow/1703>
        a                            capec:AttackStep ;
        capec:attackStep             "3" ;
        capec:attackStepDescription  "[Identify Web Application Software] After the web server platform software has been identified, the attacker start to identify web application technologies such as ASP, .NET, PHP and Java on the server." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Examine Cookies that may contain server's software information." , "Examine the HTTP Response Headers. This may leak information about software signatures" , "Examine the file name extensions in URL, for example .php indicates PHP script interfaced with Apache server." , "Check error pages." .

