capec-res:CAPEC-474  a                 capec:CAPEC ;
        dct:description                "An attacker obtains an authoritative or reputable signer's private signature key by theft and then uses this key to forge signatures from the original signer to mislead a victim into performing actions that benefit the attacker." ;
        dct:identifier                 "474" ;
        dct:title                      "Signature Spoofing by Key Theft" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/47420201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/47420220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/47420190404> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-413> , <http://w3id.org/sepses/resource/capec/reference/REF-412> , <http://w3id.org/sepses/resource/capec/reference/REF-411> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/474ChildOf473> ;
        capec:hasRelatedWeakness       cwe-res:CWE-522 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/47420140623> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Ensure all services are patched and up to date" , "Restrict access to private keys from non-supervisory accounts" , "Restrict access to administrative personnel and processes only" , "Ensure all remote methods are secured" ;
        capec:prerequisite             "An authoritative or reputable signer is storing their private signature key with insufficient protection." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

