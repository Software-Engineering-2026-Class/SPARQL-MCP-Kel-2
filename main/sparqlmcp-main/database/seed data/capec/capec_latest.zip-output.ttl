capec-res:CAPEC-546  a                 capec:CAPEC ;
        dct:description                "An adversary obtains unauthorized information due to insecure or incomplete data deletion in a multi-tenant environment. If a cloud provider fails to completely delete storage and data from former cloud tenants' systems/resources, once these resources are allocated to new, potentially malicious tenants, the latter can probe the provided resources for sensitive information still there." ;
        dct:identifier                 "546" ;
        dct:title                      "Incomplete Data Deletion in a Multi-Tenant Environment" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/546185> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/54620200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/54620170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/54620211021> , <http://w3id.org/sepses/resource/capec/modificationHistory/54620151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/54620180731> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-461> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/546ChildOf545> ;
        capec:hasRelatedWeakness       cwe-res:CWE-1272 , cwe-res:CWE-1266 , cwe-res:CWE-284 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/54620140623> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Deletion of data should be completed promptly when requested." , "Cloud providers should completely delete data to render it irrecoverable and inaccessible from any layer and component of infrastructure resources." ;
        capec:prerequisite             "The cloud provider must not assuredly delete part or all of the sensitive data for which they are responsible.The adversary must have the ability to interact with the system." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

