capec-res:CAPEC-554  a                capec:CAPEC ;
        dct:description               "An adversary attacks a system by bypassing some or all functionality intended to protect it. Often, a system user will think that protection is in place, but the functionality behind those protections has been disabled by the adversary." ;
        dct:identifier                "554" ;
        dct:title                     "Functionality Bypass" ;
        capec:abstraction             "Meta" ;
        capec:hasModificationHistory  <http://w3id.org/sepses/resource/capec/modificationHistory/55420210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/55420190404> ;
        capec:hasRelatedWeakness      cwe-res:CWE-1299 , cwe-res:CWE-424 ;
        capec:hasSubmissionHistory    <http://w3id.org/sepses/resource/capec/submissionHistory/55420151207> ;
        capec:likelihoodOfAttack      "Medium" ;
        capec:status                  "Draft" ;
        capec:typicalSeverity         "High" .

