<http://w3id.org/sepses/resource/capec/reference/REF-35>
        a                               capec:Reference ;
        capec:referenceAuthor           "G. McGraw" , "G. Hoglund" ;
        capec:referencePublicationMonth
                "02" ;
        capec:referencePublicationYear  "2004" ;
        capec:referencePublisher        "Addison-Wesley" ;
        capec:referenceTitle            "Exploiting Software: How to Break Code" .

