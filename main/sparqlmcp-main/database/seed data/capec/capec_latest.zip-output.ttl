        capec:skillDescription   "Intelligence about the manufacturer's operating environment and infrastructure." ;
        capec:skillLevel         "Medium" .

capec-res:CAPEC-592  a                 capec:CAPEC ;
        dct:description                "An adversary utilizes a form of Cross-site Scripting (XSS) where a malicious script is persistently \"stored\" within the data storage of a vulnerable web application as valid input." ;
        dct:identifier                 "592" ;
        dct:title                      "Stored XSS" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/592310> , <http://w3id.org/sepses/resource/capec/Consequence/592197> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/5921> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/5924> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/5923> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/5922> , <http://w3id.org/sepses/resource/capec/Consequence/592306> , <http://w3id.org/sepses/resource/capec/Consequence/592167> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/59220190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/59220201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/59220190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/59220170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/59220200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/59220220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/59220220929> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-605> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/592ChildOf63> ;
        capec:hasRelatedWeakness       cwe-res:CWE-79 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/59220170415> ;
        capec:likelihoodOfAttack       "High" ;
        capec:mitigation               "Utilize strict type, character, and encoding enforcement." , "Ensure that all user-supplied input is validated before being stored." , "Use browser technologies that do not allow client-side scripting." ;
        capec:prerequisite             "An application that leverages a client-side web browser with scripting enabled." , "An application that fails to adequately sanitize or encode untrusted input." , "An application that stores information provided by the user in data storage of some kind." ;
        capec:resourceRequired         "None: No specialized resources are required to execute this type of attack." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "Very High" .

