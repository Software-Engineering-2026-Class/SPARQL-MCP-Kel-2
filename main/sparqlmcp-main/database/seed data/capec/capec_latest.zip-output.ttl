capec-res:CAPEC-240  a                capec:CAPEC ;
        dct:description               "An adversary exploits weaknesses in input validation by manipulating resource identifiers enabling the unintended modification or specification of a resource." ;
        dct:identifier                "240" ;
        dct:title                     "Resource Injection" ;
        capec:abstraction             "Meta" ;
        capec:hasConsequence          <http://w3id.org/sepses/resource/capec/Consequence/24069> , <http://w3id.org/sepses/resource/capec/Consequence/24065> ;
        capec:hasModificationHistory  <http://w3id.org/sepses/resource/capec/modificationHistory/24020151207> , <http://w3id.org/sepses/resource/capec/modificationHistory/24020201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/24020170501> ;
        capec:hasRelatedWeakness      cwe-res:CWE-99 ;
        capec:hasSubmissionHistory    <http://w3id.org/sepses/resource/capec/submissionHistory/24020140623> ;
        capec:likelihoodOfAttack      "High" ;
        capec:mitigation              "Perform input validation for all content." , "Enforce regular patching of software." , "Ensure all input content that is delivered to client is sanitized against an acceptable content specification." ;
        capec:prerequisite            "The target application allows the user to both specify the identifier used to access a system resource. Through this permission, the user gains the capability to perform actions on that resource (e.g., overwrite the file)" ;
        capec:status                  "Stable" ;
        capec:typicalSeverity         "High" .

