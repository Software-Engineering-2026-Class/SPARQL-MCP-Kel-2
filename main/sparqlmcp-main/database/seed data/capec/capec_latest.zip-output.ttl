capec-res:CAPEC-185  a                 capec:CAPEC ;
        dct:description                "An attacker uses deceptive methods to cause a user or an automated process to download and install dangerous code that originates from an attacker controlled source. There are several variations to this strategy of attack." ;
        dct:identifier                 "185" ;
        dct:title                      "Malicious Software Download" ;
        capec:abstraction              "Standard" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/18520200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/18520210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/18520220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/18520190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/18520190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/18520220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/18520201217> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/185CanPrecede662> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/185ChildOf184> ;
        capec:hasRelatedWeakness       cwe-res:CWE-494 ;
