capec-res:CAPEC-182  a                 capec:CAPEC ;
        dct:description                "An attacker tricks a victim to execute malicious flash content that executes commands or makes flash calls specified by the attacker. One example of this attack is cross-site flashing, an attacker controlled parameter to a reference call loads from content specified by the attacker." ;
        dct:identifier                 "182" ;
        dct:title                      "Flash Injection" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/18269> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1821> , <http://w3id.org/sepses/resource/capec/Consequence/182164> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1823> , <http://w3id.org/sepses/resource/capec/Consequence/182100> , <http://w3id.org/sepses/resource/capec/Consequence/18265> , <http://w3id.org/sepses/resource/capec/Consequence/182121> , <http://w3id.org/sepses/resource/capec/Consequence/182115> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1822> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/18220170501> , <http://w3id.org/sepses/resource/capec/modificationHistory/18220170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/18220180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/18220190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/18220220929> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-46> , <http://w3id.org/sepses/resource/capec/reference/REF-47> , <http://w3id.org/sepses/resource/capec/reference/REF-48> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/182CanAlsoBe248> , <http://w3id.org/sepses/resource/capec/relatedAttackPattern/182ChildOf137> ;
        capec:hasRelatedWeakness       cwe-res:CWE-697 , cwe-res:CWE-184 , cwe-res:CWE-20 ;
