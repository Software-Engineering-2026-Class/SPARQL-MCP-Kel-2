capec-res:CAPEC-442  a                 capec:CAPEC ;
        dct:description                "An adversary adds malicious logic, often in the form of a computer virus, to otherwise benign software. This logic is often hidden from the user of the software and works behind the scenes to achieve negative impacts. Many times, the malicious logic is inserted into empty space between legitimate code, and is then called when the software is executed. This pattern of attack focuses on software already fielded and used in operation as opposed to software that is still under development and part of the supply chain." ;
        dct:identifier                 "442" ;
        dct:title                      "Infected Software" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/44287> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/44220190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/44220151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/44220230124> , <http://w3id.org/sepses/resource/capec/modificationHistory/44220190930> , <http://w3id.org/sepses/resource/capec/modificationHistory/44220220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/44220180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/44220210624> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-387> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/442ChildOf441> ;
        capec:hasRelatedWeakness       cwe-res:CWE-506 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/44220140623> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "Leverage anti-virus products to detect and quarantine software with known virus." ;
        capec:prerequisite             "Access to the software currently deployed at a victim location. This access is often obtained by leveraging another attack pattern to gain permissions that the adversary wouldn't normally have." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "High" .

