capec-res:CAPEC-324  a                 capec:CAPEC ;
        dct:description                "This type of operating system probe attempts to determine an estimate for how predictable the sequence number generation algorithm is for a remote host. Statistical techniques, such as standard deviation, can be used to determine how predictable the sequence number generation is for a system. This result can then be compared to a database of operating system behaviors to determine a likely match for operating system and version." ;
        dct:identifier                 "324" ;
        dct:title                      "TCP (ISN) Sequence Predictability Probe" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/32469> , <http://w3id.org/sepses/resource/capec/Consequence/324177> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/32420180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/32420170501> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-128> , <http://w3id.org/sepses/resource/capec/reference/REF-33> , <http://w3id.org/sepses/resource/capec/reference/REF-212> , <http://w3id.org/sepses/resource/capec/reference/REF-130> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/324ChildOf312> ;
        capec:hasRelatedWeakness       cwe-res:CWE-200 ;
