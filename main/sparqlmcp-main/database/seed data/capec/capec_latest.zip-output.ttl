capec-res:CAPEC-523  a                 capec:CAPEC ;
        dct:description                "An attacker implants malicious software into the system in the supply chain distribution channel, with purpose of causing malicious disruption or allowing for additional compromise when the system is deployed." ;
        dct:identifier                 "523" ;
        dct:title                      "Malicious Software Implanted" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/5231> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/5233> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/5232> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/5234> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/52320151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/52320200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/52320220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/52320220222> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-439> , <http://w3id.org/sepses/resource/capec/reference/REF-716> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/523ChildOf439> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/52320140623> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Require SSL for update channels and implement certificate transparency based verification." , "Sign everything, including configuration files, XML files and packages." , "Develop an incident response process, disclose supply chain incidents and notify customers with accurate and timely information." , "Maintain a highly secure build and update infrastructure by immediately applying security patches for OS and software, implementing mandatory integrity controls to ensure only trusted tools run, and requiring multi-factor authentication for admins." , "Deploy strong code integrity policies to allow only authorized apps to run." , "Use endpoint detection and response solutions that can automaticalkly detect and remediate suspicious activities." ;
        capec:prerequisite             "Physical access to the system after it has left the manufacturer but before it is deployed at the victim location." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

