<http://w3id.org/sepses/resource/capec/ExecutionFlow/2372>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Analysis] The attacker analyzes the target application to get a list of cross code weaknesses in the standard libraries of the sandbox." ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "The attacker analyzes the target application to get a list of cross code weaknesses in the standard libraries of the sandbox." .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/151>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Assess Target Runtime Environment] In situations where the runtime environment is not implicitly known, the attacker makes connections to the target system and tries to determine the system's runtime environment. Knowing the environment is vital to choosing the correct delimiters." ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "TCP/IP Fingerprinting" , "Port mapping by exploring the operating system (netstat, sockstat, etc.)" , "Port mapping using network connection-based software (e.g., nmap, nessus, etc.)" , "Induce errors to find informative error messages" .

capec-res:CAPEC-473  a                 capec:CAPEC ;
        dct:description                "An attacker generates a message or datablock that causes the recipient to believe that the message or datablock was generated and cryptographically signed by an authoritative or reputable source, misleading a victim or victim operating system into performing malicious actions." ;
        dct:identifier                 "473" ;
        dct:title                      "Signature Spoof" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/473104> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/47320220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/47320190404> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/473ChildOf151> ;
        capec:hasRelatedWeakness       cwe-res:CWE-20 , cwe-res:CWE-290 , cwe-res:CWE-327 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/47320140623> ;
        capec:prerequisite             "The victim or victim system is dependent upon a cryptographic signature-based verification system for validation of one or more security events or actions." , "The validation can be bypassed via an attacker-provided signature that makes it appear that the legitimate authoritative or reputable source provided the signature." ;
        capec:status                   "Draft" .

