capec-res:CAPEC-498  a                 capec:CAPEC ;
        dct:description                "An adversary examines screenshot images created by iOS in an attempt to obtain sensitive information. This attack targets temporary screenshots created by the underlying OS while the application remains open in the background." ;
        dct:identifier                 "498" ;
        dct:title                      "Probe iOS Screenshots" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/49820230124> , <http://w3id.org/sepses/resource/capec/modificationHistory/49820151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/49820200730> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-426> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/498ChildOf545> ;
        capec:hasRelatedWeakness       cwe-res:CWE-359 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/49820140623> ;
        capec:mitigation               "To mitigate this type of an attack, an application that may display sensitive information should clear the screen contents before a screenshot is taken. This can be accomplished by setting the key window's hidden property to YES. This code to hide the contents should be placed in both the applicationWillResignActive() and applicationDidEnterBackground() methods." ;
        capec:prerequisite             "This type of an attack requires physical access to a device to either excavate the image files (potentially by leveraging a Jailbreak) or view the screenshots through the multitasking switcher (by double tapping the home button on the device)." ;
        capec:status                   "Draft" .

