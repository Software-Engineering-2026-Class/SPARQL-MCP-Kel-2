capec-res:CAPEC-641  a                 capec:CAPEC ;
        dct:description                "An adversary places a malicious version of a Dynamic-Link Library (DLL) in the Windows Side-by-Side (WinSxS) directory to trick the operating system into loading this malicious DLL instead of a legitimate DLL. Programs specify the location of the DLLs to load via the use of WinSxS manifests or DLL redirection and if they aren't used then Windows searches in a predefined set of directories to locate the file. If the applications improperly specify a required DLL or WinSxS manifests aren't explicit about the characteristics of the DLL to be loaded, they can be vulnerable to side-loading." ;
        dct:identifier                 "641" ;
        dct:title                      "DLL Side-Loading" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/641126> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/64120190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/64120200730> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-501> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/641ChildOf159> ;
        capec:hasRelatedWeakness       cwe-res:CWE-706 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/64120180731> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Prevent unknown DLLs from loading through using an allowlist policy." , "Use of sxstrace.exe on Windows as well as manual inspection of the manifests." , "Properly restrict the location of the software being used." , "Require code signing and avoid using relative paths for resources." , "Patch installed applications as soon as new updates become available." ;
        capec:prerequisite             "The target must fail to verify the integrity of the DLL before using them." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "High" .

