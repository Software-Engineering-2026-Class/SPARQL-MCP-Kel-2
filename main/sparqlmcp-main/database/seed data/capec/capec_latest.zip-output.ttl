<http://w3id.org/sepses/resource/capec/ExecutionFlow/272>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Examine application's file I/O behavior] Analyze the application's file I/O behavior to determine where it stores files, as well as the operations it performs to read/write files." ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "Watch temporary directories to see when temporary files are created, modified and deleted." , "Use debugging utility such as File Monitor to monitor the application's filesystem I/O calls" , "Use kernel tracing utility such as ktrace to monitor application behavior." , "Analyze source code for open-source systems like Linux, Apache, etc." .

capec-res:CAPEC-594  a                capec:CAPEC ;
        dct:description               "An adversary injects traffic into the target's network connection. The adversary is therefore able to degrade or disrupt the connection, and potentially modify the content. This is not a flooding attack, as the adversary is not focusing on exhausting resources. Instead, the adversary is crafting a specific input to affect the system in a particular way." ;
        dct:identifier                "594" ;
        dct:title                     "Traffic Injection" ;
        capec:abstraction             "Meta" ;
        capec:hasConsequence          <http://w3id.org/sepses/resource/capec/Consequence/594200> , <http://w3id.org/sepses/resource/capec/Consequence/594246> ;
        capec:hasModificationHistory  <http://w3id.org/sepses/resource/capec/modificationHistory/59420210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/59420190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/59420170501> ;
        capec:hasRelatedWeakness      cwe-res:CWE-940 ;
        capec:hasSubmissionHistory    <http://w3id.org/sepses/resource/capec/submissionHistory/59420170103> ;
        capec:prerequisite            "The target application must leverage an open communications channel." , "The channel on which the target communicates must be vulnerable to interception (e.g., adversary in the middle attack - CAPEC-94)." ;
        capec:resourceRequired        "A tool, such as a MITM Proxy, that is capable of generating and injecting custom inputs to be used in the attack." ;
        capec:status                  "Stable" .

