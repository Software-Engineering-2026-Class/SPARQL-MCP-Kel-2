capec-res:CAPEC-103  a                 capec:CAPEC ;
        dct:description                "An adversary tricks a victim into unknowingly initiating some action in one system while interacting with the UI from a seemingly completely different, usually an adversary controlled or intended, system." ;
        dct:identifier                 "103" ;
        dct:title                      "Clickjacking" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/ExecutionFlow/1031> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1033> , <http://w3id.org/sepses/resource/capec/Consequence/10365> , <http://w3id.org/sepses/resource/capec/Consequence/103134> , <http://w3id.org/sepses/resource/capec/Consequence/10369> , <http://w3id.org/sepses/resource/capec/ExecutionFlow/1032> , <http://w3id.org/sepses/resource/capec/Consequence/10377> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/10320201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/10320220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/10320170804> , <http://w3id.org/sepses/resource/capec/modificationHistory/10320200730> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-619> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/103ChildOf173> ;
        capec:hasRelatedWeakness       cwe-res:CWE-1021 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/10320140623> ;
        capec:likelihoodOfAttack       "Medium" ;
        capec:mitigation               "If using the Firefox browser, use the NoScript plug-in that will help forbid iFrames." , "Turn off JavaScript, Flash and disable CSS." , "When maintaining an authenticated session with a privileged target system, do not use the same browser to navigate to unfamiliar sites to perform other activities. Finish working with the target system and logout first before proceeding to other tasks." ;
        capec:prerequisite             "The victim has an active session with the target system." , "The victim is communicating with the target application via a web based UI and not a thick client" , "The victim uses a modern browser that supports UI elements like clickable buttons (i.e. not using an old text only browser)" , "The victim's browser security policies allow at least one of the following JavaScript, Flash, iFrames, ActiveX, or CSS." , "The target system's interaction window is open in the victim's browser and supports the ability for initiating sensitive actions on behalf of the user in the target system" ;
        capec:resourceRequired         "None: No specialized resources are required to execute this type of attack." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

<http://w3id.org/sepses/resource/capec/modificationHistory/40520170804>
        a                               capec:ModificationHistory ;
