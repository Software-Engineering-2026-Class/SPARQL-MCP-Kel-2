capec-res:CAPEC-633  a                 capec:CAPEC ;
        dct:description                "An adversary exploits a weakness in authentication to create an access token (or equivalent) that impersonates a different entity, and then associates a process/thread to that that impersonated token. This action causes a downstream user to make a decision or take action that is based on the assumed identity, and not the response that blocks the adversary." ;
        dct:identifier                 "633" ;
        dct:title                      "Token Impersonation" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/633219> , <http://w3id.org/sepses/resource/capec/Consequence/633214> , <http://w3id.org/sepses/resource/capec/Consequence/633265> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/63320190404> , <http://w3id.org/sepses/resource/capec/modificationHistory/63320200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/63320210624> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/633ChildOf194> ;
        capec:hasRelatedWeakness       cwe-res:CWE-287 , cwe-res:CWE-1270 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/63320180412> ;
        capec:prerequisite             "This pattern of attack is only applicable when a downstream user leverages tokens to verify identity, and then takes action based on that identity." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "Medium" .

<http://w3id.org/sepses/resource/capec/skillRequired/13283>
        a                        capec:SkillRequired ;
        capec:isSkillRequiredOf  capec-res:CAPEC-132 ;
        capec:skillDescription   "To identify the files and create the symlinks during the file operation time window" ;
        capec:skillLevel         "High" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/2342>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Find vulnerability in running process] The adversary looks for a vulnerability in the running process that would allow for arbitrary code execution with the privilege of the running process." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Look for a buffer overflow which may be exploited if an adversary can inject unvalidated data." , "Look for improper input validation" , "Utilize system utilities that support process control that have been inadequately secured" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/121>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Determine Nature of Messages] Determine the nature of messages being transported as well as the identifiers to be used as part of the attack" ;
        capec:attackStepPhase        "Explore" .

