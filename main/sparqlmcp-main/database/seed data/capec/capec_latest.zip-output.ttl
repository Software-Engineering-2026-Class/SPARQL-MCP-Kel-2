<http://w3id.org/sepses/resource/capec/ExecutionFlow/7012>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Lure victims] The adversary crafts a phishing campaign to lure unsuspecting victims into using the transparent browser." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "An adversary can create a convincing email with a link to download the web client and interact with the transparent browser." .

