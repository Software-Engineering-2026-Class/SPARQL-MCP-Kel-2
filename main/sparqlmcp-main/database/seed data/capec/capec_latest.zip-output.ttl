capec-res:CAPEC-655  a                 capec:CAPEC ;
        dct:description                "\n            An adversary adds data to a file to increase the file size beyond what security tools are capable of handling in an attempt to mask their actions.\n            In addition to this, adding data to a file also changes the file's hash, frustrating security tools that look for known bad files by their hash.\n         " ;
        dct:identifier                 "655" ;
        dct:title                      "Avoid Security Tool Identification by Adding Data" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/65565> , <http://w3id.org/sepses/resource/capec/Consequence/655117> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/65520210624> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/655ChildOf572> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/65520200730> ;
        capec:likelihoodOfAttack       "High" ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

