<http://w3id.org/sepses/resource/capec/skillRequired/68520>
        a                        capec:SkillRequired ;
        capec:isSkillRequiredOf  capec-res:CAPEC-68 ;
        capec:skillDescription   "Subverting code signing is not a trivial activity. Most code signing and verification schemes are based on use of cryptography and the attacker needs to have an understanding of these cryptographic operations in good detail. Additionally the attacker also needs to be aware of the way memory is assigned and accessed by the container since, often, the only way to subvert code signing would be to patch the code in memory. Finally, a knowledge of the platform specific mechanisms of signing and verifying code is a must." ;
        capec:skillLevel         "High" .

capec-res:CAPEC-176  a                capec:CAPEC ;
        dct:description               "An attacker manipulates files or settings external to a target application which affect the behavior of that application. For example, many applications use external configuration files and libraries - modification of these entities or otherwise affecting the application's ability to use them would constitute a configuration/environment manipulation attack." ;
        dct:identifier                "176" ;
        dct:title                     "Configuration/Environment Manipulation" ;
        capec:abstraction             "Meta" ;
        capec:hasModificationHistory  <http://w3id.org/sepses/resource/capec/modificationHistory/17620210624> , <http://w3id.org/sepses/resource/capec/modificationHistory/17620201217> , <http://w3id.org/sepses/resource/capec/modificationHistory/17620200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/17620190404> ;
        capec:hasRelatedWeakness      cwe-res:CWE-1328 , cwe-res:CWE-1304 , cwe-res:CWE-1234 , cwe-res:CWE-1233 , cwe-res:CWE-15 ;
        capec:hasSubmissionHistory    <http://w3id.org/sepses/resource/capec/submissionHistory/17620140623> ;
        capec:prerequisite            "The target application must consult external files or configuration controls to control its execution. All but the very simplest applications meet this requirement." ;
        capec:resourceRequired        "The attacker must have the access necessary to affect the files or other environment items the targeted application uses for its operations." ;
        capec:status                  "Draft" ;
        capec:typicalSeverity         "Medium" .

