<http://w3id.org/sepses/resource/capec/ExecutionFlow/5601>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Acquire known credentials] The adversary must obtain known credentials in order to access the target system, application, or service." ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "An adversary leverages a key logger or phishing attack to steal user credentials as they are provided." , "An adversary purchases breached username/password combinations or leaked hashed passwords from the dark web." , "An adversary gains access to a database and exfiltrates password hashes." , "An adversary conducts a sniffing attack to steal credentials as they are transmitted." , "An adversary examines outward-facing configuration and properties files to discover hardcoded credentials." .

