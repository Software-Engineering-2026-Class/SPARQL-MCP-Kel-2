capec-res:CAPEC-202  a                 capec:CAPEC ;
        dct:description                "An adversary creates a client application to interface with a target service where the client violates assumptions the service makes about clients. Services that have designated client applications (as opposed to services that use general client applications, such as IMAP or POP mail servers which can interact with any IMAP or POP client) may assume that the client will follow specific procedures." ;
        dct:identifier                 "202" ;
        dct:title                      "Create Malicious Client" ;
        capec:abstraction              "Standard" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/20220220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/20220190404> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/202ChildOf22> ;
        capec:hasRelatedWeakness       cwe-res:CWE-602 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/20220140623> ;
        capec:prerequisite             "The targeted service must make assumptions about the behavior of the client application that interacts with it, which can be abused by an adversary." ;
        capec:resourceRequired         "The adversary must be able to reverse engineer a client of the targeted service. However, the adversary does not need to reverse engineer all client functionality - they only need to recreate enough of the functionality to access the desired server functionality." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Medium" .

