<http://w3id.org/sepses/resource/capec/ExecutionFlow/163>
        a                            capec:AttackStep ;
        capec:attackStep             "3" ;
        capec:attackStepDescription  "[Determine username(s) to target] Determine username(s) whose passwords to crack." ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "Obtain username(s) by querying application/system (e.g. if upon a failed login attempt, the system indicates whether the entered username was valid or not)" , "Obtain username(s) by sniffing network packets." , "Obtain usernames from filesystem (e.g. list of directories in C:\\Documents and Settings\\ in Windows, and list in /etc/passwd in UNIX-like systems)" .

