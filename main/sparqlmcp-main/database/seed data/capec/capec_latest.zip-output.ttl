capec-res:CAPEC-617  a                 capec:CAPEC ;
        dct:description                "In this attack scenario, the attacker imitates a cellular base station with their own \"rogue\" base station equipment. Since cellular devices connect to whatever station has the strongest signal, the attacker can easily convince a targeted cellular device (e.g. the retransmission device) to talk to the rogue base station." ;
        dct:identifier                 "617" ;
        dct:title                      "Cellular Rogue Base Station" ;
        capec:abstraction              "Detailed" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/617158> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/61720180731> , <http://w3id.org/sepses/resource/capec/modificationHistory/61720200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/61720220929> , <http://w3id.org/sepses/resource/capec/modificationHistory/61720190930> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/617ChildOf616> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/61720151109> ;
        capec:mitigation               "Passively monitor cellular network connection for real-time threat detection and logging for manual review." ;
        capec:prerequisite             "None" ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "Low" .

