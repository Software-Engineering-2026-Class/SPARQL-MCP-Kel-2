<http://w3id.org/sepses/resource/capec/ExecutionFlow/401>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Identify attacker-writable terminals] Determine if users TTYs are writable by the attacker." ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "Determine the permissions for the TTYs found on the system. Any that allow user write to the TTY may be vulnerable." , "Attempt to write to other user TTYs. This approach could leave a trail or alert a user." .

<http://w3id.org/sepses/resource/capec/modificationHistory/26620170109>
        a                               capec:ModificationHistory ;
        capec:modificationComment       "Updated Related_Attack_Patterns" ;
        capec:modificationDate          "2017-01-09" ;
        capec:modificationName          "CAPEC Content Team" ;
        capec:modificationOrganization  "The MITRE Corporation" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/2432>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Probe identified potential entry points for XSS targeting HTML attributes] The adversary uses the entry points gathered in the \"Explore\" phase as a target list and injects various malicious expressions as input, hoping to embed them as HTML attributes." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Inject single and double quotes into URL parameters or other inputs to see if they are filtered out. Also use URL encoding to bypass filters." , "Use single or double quotes to close attribute evaluation and enter a new attribute that contains an expression." .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/5682>
        a                            capec:AttackStep ;
        capec:attackStep             "2" ;
        capec:attackStepDescription  "[Deploy keylogger] Once a user is identified, an adversary will deploy a keylogger to the user's system in one of many ways." ;
        capec:attackStepPhase        "Experiment" ;
        capec:attackStepTechnique    "Get a user to click on a malicious URL that directs them to a webpage that will install a keylogger without their knowledge" , "Conceal a keylogger behind fake software and get the user to download the software" , "Send a phishing email with a malicious attachment that installs a keylogger on a user's system" , "Gain access to the user's system through a vulnerability and manually install a keylogger" .

<http://w3id.org/sepses/resource/capec/ExecutionFlow/211>
        a                            capec:AttackStep ;
        capec:attackStep             "1" ;
        capec:attackStepDescription  "[Survey the application for Indicators of Susceptibility] Using a variety of methods, until one is found that applies to the target, the adversary probes for cookies, session tokens, or entry points that bypass identifiers altogether." ;
        capec:attackStepPhase        "Explore" ;
        capec:attackStepTechnique    "Attack known bad interfaces" , "Spider all available pages" , "Search outward-facing configuration and properties files for identifiers." .

capec-res:CAPEC-533  a                 capec:CAPEC ;
        dct:description                "An attacker introduces malicious code to the victim's system by altering the payload of a software update, allowing for additional compromise or site disruption at the victim location. These manual, or user-assisted attacks, vary from requiring the user to download and run an executable, to as streamlined as tricking the user to click a URL. Attacks which aim at penetrating a specific network infrastructure often rely upon secondary attack methods to achieve the desired impact. Spamming, for example, is a common method employed as an secondary attack vector. Thus the attacker has in their arsenal a choice of initial attack vectors ranging from traditional SMTP/POP/IMAP spamming and its varieties, to web-application mechanisms which commonly implement both chat and rich HTML messaging within the user interface." ;
        dct:identifier                 "533" ;
        dct:title                      "Malicious Manual Software Update" ;
        capec:abstraction              "Detailed" ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/53320200730> , <http://w3id.org/sepses/resource/capec/modificationHistory/53320151109> , <http://w3id.org/sepses/resource/capec/modificationHistory/53320220222> , <http://w3id.org/sepses/resource/capec/modificationHistory/53320190404> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-710> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/533ChildOf186> ;
        capec:hasRelatedWeakness       cwe-res:CWE-494 ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/53320140623> ;
        capec:likelihoodOfAttack       "Low" ;
        capec:mitigation               "Only accept software updates from an official source." ;
        capec:prerequisite             "Advanced knowledge about the download and update installation processes." , "Advanced knowledge about the deployed system and its various software subcomponents and processes." ;
        capec:status                   "Draft" ;
        capec:typicalSeverity          "High" .

