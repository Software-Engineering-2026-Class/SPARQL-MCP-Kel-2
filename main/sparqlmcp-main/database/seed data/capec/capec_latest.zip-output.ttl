        a                        capec:Consequence ;
        capec:consequenceImpact  "Read Data" ;
        capec:consequenceNote    "Extract long-term secret keys (e.g. keys used for VPN or WiFi authentication and encryption) to enable decryption of intercepted VOIP traffic." ;
        capec:consequenceScope   "Access Control" , "Confidentiality" .

capec-res:CAPEC-417  a                 capec:CAPEC ;
        dct:description                "The adversary uses social engineering to exploit the target's perception of the relationship between the adversary and themselves. This goal is to persuade the target to unknowingly perform an action or divulge information that is advantageous to the adversary." ;
        dct:identifier                 "417" ;
        dct:title                      "Influence Perception" ;
        capec:abstraction              "Standard" ;
        capec:hasConsequence           <http://w3id.org/sepses/resource/capec/Consequence/417345> ;
        capec:hasModificationHistory   <http://w3id.org/sepses/resource/capec/modificationHistory/41720170804> ;
        capec:hasReference             <http://w3id.org/sepses/resource/capec/reference/REF-360> , <http://w3id.org/sepses/resource/capec/reference/REF-348> ;
        capec:hasRelatedAttackPattern  <http://w3id.org/sepses/resource/capec/relatedAttackPattern/417ChildOf416> ;
        capec:hasSubmissionHistory     <http://w3id.org/sepses/resource/capec/submissionHistory/41720140623> ;
        capec:likelihoodOfAttack       "High" ;
        capec:mitigation               "An organization should provide regular, robust cybersecurity training to its employees to prevent social engineering attacks." ;
        capec:prerequisite             "The adversary must have the means and knowledge of how to communicate with the target in some manner." ;
        capec:resourceRequired         "There are no necessary resources required for this attack." ;
        capec:status                   "Stable" ;
        capec:typicalSeverity          "Low" .

